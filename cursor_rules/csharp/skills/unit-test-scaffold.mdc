### 3. Testando Handlers (Use Cases)

```csharp
// tests/Unit/Application/Commands/CreateUserCommandHandlerTests.cs
namespace Company.Product.Unit.Tests.Application.Commands;

public class CreateUserCommandHandlerTests
{
    // ── Fixtures ─────────────────────────────────────────────
    private readonly Mock<IUserRepository> _userRepositoryMock;
    private readonly Mock<IUnitOfWork>     _unitOfWorkMock;
    private readonly Mock<IMapper>         _mapperMock;
    private readonly ILogger<CreateUserCommandHandler> _logger;
    private readonly CreateUserCommandHandler _handler;

    public CreateUserCommandHandlerTests()
    {
        _userRepositoryMock = new Mock<IUserRepository>();
        _unitOfWorkMock     = new Mock<IUnitOfWork>();
        _mapperMock         = new Mock<IMapper>();
        _logger             = new NullLogger<CreateUserCommandHandler>();

        _handler = new CreateUserCommandHandler(
            _userRepositoryMock.Object,
            _unitOfWorkMock.Object,
            _mapperMock.Object,
            _logger);
    }

    // ── Cenário: e-mail disponível → deve criar usuário ──────
    [Fact]
    public async Task Handle_UniqueEmail_CreatesUserAndReturnsSuccess()
    {
        // Arrange
        var command  = new CreateUserCommandBuilder().Build();
        var user     = new UserBuilder()
            .WithEmail(command.Email)
            .WithFirstName(command.FirstName)
            .Build();
        var expected = new UserResponse { Id = user.Id, Email = user.Email };

        _userRepositoryMock
            .Setup(r => r.ExistsAsync(It.IsAny<Expression<Func<User, bool>>>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(false);

        _mapperMock
            .Setup(m => m.Map<UserResponse>(It.IsAny<User>()))
            .Returns(expected);

        // Act
        var result = await _handler.Handle(command, CancellationToken.None);

        // Assert
        result.IsSuccess.Should().BeTrue();
        result.Value.Email.Should().Be(expected.Email);

        _userRepositoryMock.Verify(
            r => r.AddAsync(It.IsAny<User>(), It.IsAny<CancellationToken>()),
            Times.Once);
        _unitOfWorkMock.Verify(
            u => u.SaveChangesAsync(It.IsAny<CancellationToken>()),
            Times.Once);
    }

    // ── Cenário: e-mail duplicado → deve retornar Conflict ───
    [Fact]
    public async Task Handle_DuplicateEmail_ReturnsConflictFailure()
    {
        // Arrange
        var command = new CreateUserCommandBuilder().Build();

        _userRepositoryMock
            .Setup(r => r.ExistsAsync(It.IsAny<Expression<Func<User, bool>>>(), It.IsAny<CancellationToken>()))
            .ReturnsAsync(true);

        // Act
        var result = await _handler.Handle(command, CancellationToken.None);

        // Assert
        result.IsFailure.Should().BeTrue();
        result.Error.Type.Should().Be(ErrorType.Conflict);

        _userRepositoryMock.Verify(
            r => r.AddAsync(It.IsAny<User>(), It.IsAny<CancellationToken>()),
            Times.Never);
    }
}
```

### 4. Testando Entidades de Domínio

```csharp
// tests/Unit/Domain/Entities/UserTests.cs
namespace Company.Product.Unit.Tests.Domain.Entities;

public class UserTests
{
    [Fact]
    public void Constructor_ValidData_CreatesUserWithCorrectProperties()
    {
        // Arrange
        var id         = Guid.NewGuid();
        var firstName  = "João";
        var lastName   = "Silva";
        var email      = "joao@email.com";
        var dob        = DateTime.UtcNow.AddYears(-30);

        // Act
        var user = new User(id, firstName, lastName, email, dob);

        // Assert
        user.Id.Should().Be(id);
        user.FirstName.Should().Be(firstName);
        user.Email.Should().Be(email);
    }

    [Theory]
    [InlineData("")]
    [InlineData("  ")]
    [InlineData(null)]
    public void Constructor_EmptyFirstName_ThrowsValidationException(string firstName)
    {
        // Act
        var act = () => new User(Guid.NewGuid(), firstName, "Silva", "joao@email.com",
            DateTime.UtcNow.AddYears(-20));

        // Assert
        act.Should().Throw<ValidationException>()
            .Which.Errors.Should().ContainSingle(e => e.PropertyName == "FirstName");
    }

    [Fact]
    public void Constructor_EmptyId_GeneratesNewGuid()
    {
        var user = new User(Guid.Empty, "João", "Silva", "j@e.com",
            DateTime.UtcNow.AddYears(-20));

        user.Id.Should().NotBeEmpty();
    }
}
```

### 5. Testando Validadores

```csharp
// tests/Unit/Validators/CreateUserCommandValidatorTests.cs
namespace Company.Product.Unit.Tests.Validators;

public class CreateUserCommandValidatorTests
{
    private readonly CreateUserCommandValidator _validator = new();

    [Fact]
    public void Validate_ValidCommand_PassesValidation()
    {
        var command = new CreateUserCommandBuilder().Build();

        var result = _validator.Validate(command);

        result.IsValid.Should().BeTrue();
    }

    [Theory]
    [InlineData("")]
    [InlineData("  ")]
    public void Validate_EmptyEmail_FailsWithEmailRequiredError(string email)
    {
        var command = new CreateUserCommandBuilder().WithEmail(email).Build();

        var result = _validator.Validate(command);

        result.IsValid.Should().BeFalse();
        result.Errors.Should().Contain(e =>
            e.PropertyName == "Email" && e.ErrorMessage.Contains("required"));
    }

    [Fact]
    public void Validate_InvalidEmailFormat_FailsWithFormatError()
    {
        var command = new CreateUserCommandBuilder().WithEmail("not-an-email").Build();

        var result = _validator.Validate(command);

        result.IsValid.Should().BeFalse();
        result.Errors.Should().Contain(e => e.PropertyName == "Email");
    }
}
```

### 6. Theory com MemberData — múltiplos cenários

```csharp
public class ProductPricingTests
{
    public static IEnumerable<object[]> DiscountScenarios()
    {
        yield return new object[] { 100.00m, 0.10m, 90.00m };  // 10% desconto
        yield return new object[] { 200.00m, 0.20m, 160.00m }; // 20% desconto
        yield return new object[] { 50.00m,  0.00m, 50.00m };  // sem desconto
    }

    [Theory]
    [MemberData(nameof(DiscountScenarios))]
    public void ApplyDiscount_VariousPercentages_ReturnsCorrectPrice(
        decimal originalPrice,
        decimal discountRate,
        decimal expectedPrice)
    {
        // Arrange
        var product = new ProductBuilder().WithPrice(originalPrice).Build();

        // Act
        product.ApplyDiscount(discountRate);

        // Assert
        product.Price.Should().Be(expectedPrice);
    }
}
```

