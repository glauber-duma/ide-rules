## Passo a Passo

### 1. Interface (Application Layer)

```csharp
// Application/Common/IDapperRepository.cs
namespace Company.Product.Application.Common;

public interface IDapperRepository<TClass, TType>
    where TClass : class
{
    Task<TClass?> GetByIdAsync(TType id, CancellationToken ct = default);

    Task<IEnumerable<TClass>> ListAsync(
        string? whereClause,
        object? parameters = null,
        CancellationToken ct = default);

    Task<PagedResult<TClass>> PagedAsync(
        string? whereClause,
        object? parameters,
        int page,
        int pageSize,
        CancellationToken ct = default);

    Task AddAsync(TClass entity, CancellationToken ct = default);

    Task UpdateAsync(TClass entity, CancellationToken ct = default);

    Task DeleteAsync(TType id, CancellationToken ct = default);
}

// Application/Common/PagedResult.cs
// ⚠️ Definido em repository-efcore — não duplicar no projeto
```

### 2. Implementação Genérica (Infrastructure Layer)

```csharp
// Infrastructure/Data/DapperRepository.cs
namespace Company.Product.Infrastructure.Data;

public class DapperRepository<TClass, TType> : IDapperRepository<TClass, TType>
    where TClass : class
{
    private readonly IDbConnection _connection;
    private readonly string _tableName;

    public DapperRepository(IDbConnection connection, string tableName)
    {
        _connection = connection;
        _tableName  = tableName;
    }

    public Task<TClass?> GetByIdAsync(TType id, CancellationToken ct = default)
        => _connection.QuerySingleOrDefaultAsync<TClass>(
            $"SELECT * FROM {_tableName} WHERE Id = @Id",
            new { Id = id });

    public Task<IEnumerable<TClass>> ListAsync(
        string? whereClause,
        object? parameters = null,
        CancellationToken ct = default)
    {
        var sql = $"SELECT * FROM {_tableName}";
        if (!string.IsNullOrWhiteSpace(whereClause))
            sql += $" WHERE {whereClause}";

        return _connection.QueryAsync<TClass>(sql, parameters);
    }

    public async Task<PagedResult<TClass>> PagedAsync(
        string? whereClause,
        object? parameters,
        int page,
        int pageSize,
        CancellationToken ct = default)
    {
        var sqlWhere = string.IsNullOrWhiteSpace(whereClause)
            ? string.Empty
            : $"WHERE {whereClause}";

        var sqlCount = $"SELECT COUNT(1) FROM {_tableName} {sqlWhere}";
        var sqlData  = $"""
            SELECT * FROM {_tableName} {sqlWhere}
            ORDER BY Id
            OFFSET @Skip ROWS FETCH NEXT @Take ROWS ONLY
            """;

        // Parâmetros de paginação mesclados com os parâmetros do filtro
        var pagedParams = new DynamicParameters(parameters);
        pagedParams.Add("Skip", (page - 1) * pageSize);
        pagedParams.Add("Take", pageSize);

        var total = await _connection.ExecuteScalarAsync<int>(sqlCount, parameters);
        var items = await _connection.QueryAsync<TClass>(sqlData, pagedParams);

        return new PagedResult<TClass>(items.ToList(), total, page, pageSize);
    }

    public Task AddAsync(TClass entity, CancellationToken ct = default)
        => _connection.ExecuteAsync(InsertSql, entity);

    public Task UpdateAsync(TClass entity, CancellationToken ct = default)
        => _connection.ExecuteAsync(UpdateSql, entity);

    public Task DeleteAsync(TType id, CancellationToken ct = default)
        => _connection.ExecuteAsync(
            $"DELETE FROM {_tableName} WHERE Id = @Id",
            new { Id = id });

    // ⚠️ Repositório concreto DEVE sobrescrever com as colunas reais da tabela
    protected virtual string InsertSql =>
        throw new NotImplementedException($"InsertSql not implemented for {_tableName}");

    protected virtual string UpdateSql =>
        throw new NotImplementedException($"UpdateSql not implemented for {_tableName}");
}
```

### 3. Repositório Específico (quando SQL customizado é necessário)

```csharp
// Application/Interfaces/IProductRepository.cs
public interface IProductRepository : IDapperRepository<Product, Guid>
{
    Task<IEnumerable<Product>> GetActiveByPriceRangeAsync(
        decimal minPrice, decimal maxPrice, CancellationToken ct = default);
}

// Infrastructure/Data/Repositories/ProductRepository.cs
public class ProductRepository
    : DapperRepository<Product, Guid>, IProductRepository
{
    private readonly IDbConnection _connection;

    public ProductRepository(IDbConnection connection)
        : base(connection, "Products") => _connection = connection;

    // ✅ Implementar as colunas reais da tabela
    protected override string InsertSql =>
        "INSERT INTO Products (Id, Name, Price, IsActive) VALUES (@Id, @Name, @Price, @IsActive)";

    protected override string UpdateSql =>
        "UPDATE Products SET Name = @Name, Price = @Price, IsActive = @IsActive WHERE Id = @Id";

    public Task<IEnumerable<Product>> GetActiveByPriceRangeAsync(
        decimal minPrice, decimal maxPrice, CancellationToken ct = default)
        => _connection.QueryAsync<Product>(
            """
            SELECT * FROM Products
            WHERE IsActive = 1 AND Price BETWEEN @MinPrice AND @MaxPrice
            ORDER BY Price
            """,
            new { MinPrice = minPrice, MaxPrice = maxPrice });
}
```

### 4. Conexão e Registro em DI

```csharp
// Infrastructure/DependencyInjection.cs
public static class InfrastructureServiceExtensions
{
    public static IServiceCollection AddInfrastructureDapper(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        // Registrar IDbConnection como Scoped (uma por request)
        services.AddScoped<IDbConnection>(_ =>
            new SqlConnection(
                configuration.GetConnectionString("DefaultConnection")));

        // Repositório genérico (quando não há repositório específico)
        // Registrar manualmente por tabela:
        services.AddScoped<IDapperRepository<Product, Guid>>(sp =>
            new DapperRepository<Product, Guid>(
                sp.GetRequiredService<IDbConnection>(), "Products"));

        // Repositório específico
        services.AddScoped<IProductRepository, ProductRepository>();

        return services;
    }
}
```

