## Exemplos de Uso

### Cenário 1 — Handler de Query simples

```csharp
public class GetProductsQueryHandler
    : IRequestHandler<GetProductsQuery, Result<IEnumerable<ProductDto>>>
{
    private readonly IDapperRepository<Product, Guid> _repository;

    public GetProductsQueryHandler(IDapperRepository<Product, Guid> repository)
        => _repository = repository;

    public async Task<Result<IEnumerable<ProductDto>>> Handle(
        GetProductsQuery request, CancellationToken ct)
    {
        var products = await _repository.ListAsync(
            whereClause: "IsActive = 1",
            parameters: null,
            ct: ct);

        return Result.Success(products.Select(ProductDto.FromDomain));
    }
}
```

### Cenário 2 — Query com filtro dinâmico

```csharp
public async Task<Result<IEnumerable<ProductDto>>> Handle(
    SearchProductsQuery request, CancellationToken ct)
{
    var whereClause  = "Name LIKE @Search AND IsActive = @IsActive";
    var parameters   = new { Search = $"%{request.Term}%", IsActive = true };

    var products = await _repository.ListAsync(whereClause, parameters, ct);

    return Result.Success(products.Select(ProductDto.FromDomain));
}
```

### Cenário 3 — Paginação com filtro

```csharp
public async Task<Result<PagedResult<ProductDto>>> Handle(
    GetProductsPagedQuery request, CancellationToken ct)
{
    var paged = await _repository.PagedAsync(
        whereClause: "IsActive = 1",
        parameters: null,
        page: request.Page,
        pageSize: request.PageSize,
        ct: ct);

    var dtos = paged.Items.Select(ProductDto.FromDomain).ToList();
    return Result.Success(
        new PagedResult<ProductDto>(dtos, paged.Total, paged.Page, paged.PageSize));
}
```

