## Exemplos de Uso

### Cenário 1 — Entidade simples (CRUD)

```csharp
// Criação — valida no construtor
var product = new Product(
    Guid.NewGuid(),
    "Notebook Dell",
    "Notebook para desenvolvimento",
    price: 4_500.00m,
    stockQuantity: 10
);

// Mutação — revalida após alterar estado
product.UpdatePrice(4_200.00m);
product.UpdateStock(8);
product.Deactivate();
```

### Cenário 2 — Entidade com domain events

```csharp
public class Order : EntityBase
{
    private readonly List<IDomainEvent> _domainEvents = [];
    public IReadOnlyList<IDomainEvent> DomainEvents => _domainEvents.AsReadOnly();

    #region Properties
    public Guid CustomerId { get; private set; }
    public OrderStatus Status { get; private set; }
    public decimal TotalAmount { get; private set; }
    #endregion

    private Order() { }

    public Order(Guid id, Guid customerId, decimal totalAmount) : base(id)
    {
        CustomerId = customerId;
        TotalAmount = totalAmount;
        Status = OrderStatus.Pending;
        new OrderValidator().ValidateAndThrow(this);
        _domainEvents.Add(new OrderCreatedEvent(id, customerId));
    }

    public void Complete()
    {
        Status = OrderStatus.Completed;
        UpdatedAt = DateTime.UtcNow;
        _domainEvents.Add(new OrderCompletedEvent(Id, CustomerId));
    }

    public void ClearDomainEvents() => _domainEvents.Clear();
}
```

