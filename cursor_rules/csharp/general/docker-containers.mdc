## 2. 📋 Dockerfile - ASP.NET Core API

### 2.1. Template Completo (Multi-stage + Non-root)

```dockerfile
# syntax=docker/dockerfile:1.4
# ==================================================
# Stage 1: Build
# ==================================================
FROM mcr.microsoft.com/dotnet/sdk:9.0-alpine AS build
WORKDIR /src

# Copia apenas arquivos de projeto primeiro (melhor cache)
COPY ["src/Api/Api.csproj", "src/Api/"]
COPY ["src/Application/Application.csproj", "src/Application/"]
COPY ["src/Domain/Domain.csproj", "src/Domain/"]
COPY ["src/Infrastructure/Infrastructure.csproj", "src/Infrastructure/"]

# Restore como camada separada (cache)
RUN dotnet restore "src/Api/Api.csproj" \
    --runtime linux-musl-x64

# Copia todo o código fonte
COPY . .

# Build e publish
WORKDIR "/src/src/Api"
RUN dotnet publish "Api.csproj" \
    --configuration Release \
    --runtime linux-musl-x64 \
    --self-contained false \
    --no-restore \
    --output /app/publish \
    /p:PublishTrimmed=false \
    /p:PublishSingleFile=false

# ==================================================
# Stage 2: Runtime
# ==================================================
FROM mcr.microsoft.com/dotnet/aspnet:9.0-alpine AS runtime

# Metadata
LABEL maintainer="seu-email@empresa.com"
LABEL description="API .NET 9 - Production Ready"
LABEL version="1.0.0"

# Instalar dependências de segurança (se necessário)
RUN apk add --no-cache \
    ca-certificates \
    tzdata \
    && update-ca-certificates

# Criar usuário non-root
RUN addgroup -g 1000 appgroup \
    && adduser -u 1000 -G appgroup -s /bin/sh -D appuser

# Configurar diretórios com permissões corretas
WORKDIR /app
RUN chown -R appuser:appgroup /app

# Copiar binários do stage build
COPY --from=build --chown=appuser:appgroup /app/publish .

# Configurar timezone (opcional)
ENV TZ=America/Sao_Paulo

# Configurar variáveis de ambiente .NET
ENV ASPNETCORE_URLS=http://+:8080 \
    DOTNET_RUNNING_IN_CONTAINER=true \
    DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false

# Expor porta (apenas documentação)
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/healthz || exit 1

# Trocar para usuário non-root
USER appuser

# Entrypoint
ENTRYPOINT ["dotnet", "Api.dll"]
```

### 2.2. Dockerfile - Console App / Worker

```dockerfile
# syntax=docker/dockerfile:1.4
FROM mcr.microsoft.com/dotnet/sdk:9.0-alpine AS build
WORKDIR /src

COPY ["src/Worker/Worker.csproj", "src/Worker/"]
RUN dotnet restore "src/Worker/Worker.csproj" --runtime linux-musl-x64

COPY . .
WORKDIR "/src/src/Worker"
RUN dotnet publish "Worker.csproj" \
    --configuration Release \
    --runtime linux-musl-x64 \
    --self-contained false \
    --no-restore \
    --output /app/publish

FROM mcr.microsoft.com/dotnet/runtime:9.0-alpine AS runtime

LABEL maintainer="seu-email@empresa.com"
LABEL description="Worker .NET 9"

RUN apk add --no-cache ca-certificates tzdata \
    && update-ca-certificates

RUN addgroup -g 1000 appgroup \
    && adduser -u 1000 -G appgroup -s /bin/sh -D appuser

WORKDIR /app
RUN chown -R appuser:appgroup /app

COPY --from=build --chown=appuser:appgroup /app/publish .

ENV TZ=America/Sao_Paulo \
    DOTNET_RUNNING_IN_CONTAINER=true

USER appuser

ENTRYPOINT ["dotnet", "Worker.dll"]
```

### 2.3. Otimizações Importantes

```dockerfile
# ❌ EVITE - Instalar pacotes desnecessários
RUN apt-get update && apt-get install -y \
    curl wget vim nano htop git

# ✅ CORRETO - Apenas o essencial
RUN apk add --no-cache ca-certificates tzdata

# ❌ EVITE - Múltiplos layers desnecessários
RUN dotnet restore
RUN dotnet build
RUN dotnet publish

# ✅ CORRETO - Combine quando possível
RUN dotnet restore && \
    dotnet build && \
    dotnet publish

# ❌ EVITE - Root user em produção
USER root
ENTRYPOINT ["dotnet", "Api.dll"]

# ✅ CORRETO - Non-root user
USER appuser
ENTRYPOINT ["dotnet", "Api.dll"]

# ❌ EVITE - Secrets hardcoded
ENV DATABASE_PASSWORD="senha123"
ENV JWT_SECRET="meu-secret-super-secreto"

# ✅ CORRETO - Use secrets managers ou variáveis de ambiente em tempo de execução
# Configurar via docker-compose, Kubernetes secrets, Azure Key Vault, etc.
```

