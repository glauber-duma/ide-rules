## 5. 🔒 Security Scanning

### 5.1. Trivy (Recomendado)

```bash
# Instalar Trivy (macOS)
brew install aquasecurity/trivy/trivy

# Scan de vulnerabilidades na imagem
trivy image myapp-api:latest

# Scan com severidade HIGH e CRITICAL apenas
trivy image --severity HIGH,CRITICAL myapp-api:latest

# Scan com output JSON
trivy image --format json --output trivy-report.json myapp-api:latest

# Scan de Dockerfile
trivy config Dockerfile

# Scan de docker-compose.yml
trivy config docker-compose.yml

# CI/CD: Fail build se encontrar vulnerabilidades CRITICAL
trivy image --exit-code 1 --severity CRITICAL myapp-api:latest
```

### 5.2. Snyk

```bash
# Instalar Snyk CLI
npm install -g snyk

# Autenticar
snyk auth

# Scan de imagem Docker
snyk container test myapp-api:latest

# Scan com severidade HIGH apenas
snyk container test myapp-api:latest --severity-threshold=high

# Monitoramento contínuo
snyk container monitor myapp-api:latest

# Test Dockerfile
snyk iac test Dockerfile
```

### 5.3. Docker Scout (Nativo Docker Desktop)

```bash
# Habilitar Docker Scout
docker scout quickview

# Scan de imagem
docker scout cves myapp-api:latest

# Comparar com versão anterior
docker scout compare --to myapp-api:previous myapp-api:latest

# Recomendações de atualização de base image
docker scout recommendations myapp-api:latest
```

### 5.4. GitHub Actions - Security Scan Pipeline

```yaml
# .github/workflows/docker-security-scan.yml
name: Docker Security Scan

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
  schedule:
    # Scan diário às 2am UTC
    - cron: '0 2 * * *'

jobs:
  scan:
    name: Security Scan
    runs-on: ubuntu-latest
    
    permissions:
      contents: read
      security-events: write
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
      
      - name: Build Docker image
        run: |
          docker build -t myapp-api:${{ github.sha }} \
            -f src/Api/Dockerfile .
      
      - name: Run Trivy vulnerability scanner
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: 'myapp-api:${{ github.sha }}'
          format: 'sarif'
          output: 'trivy-results.sarif'
          severity: 'CRITICAL,HIGH'
          exit-code: '1'  # Fail pipeline se encontrar vulnerabilidades
      
      - name: Upload Trivy results to GitHub Security
        uses: github/codeql-action/upload-sarif@v3
        if: always()
        with:
          sarif_file: 'trivy-results.sarif'
      
      - name: Run Snyk scan
        uses: snyk/actions/docker@master
        env:
          SNYK_TOKEN: ${{ secrets.SNYK_TOKEN }}
        with:
          image: 'myapp-api:${{ github.sha }}'
          args: --severity-threshold=high
      
      - name: Notify on failure
        if: failure()
        run: |
          echo "::error::Security vulnerabilities found! Check Security tab for details."
```

### 5.5. GitLab CI - Security Scan Pipeline

```yaml
# .gitlab-ci.yml
stages:
  - build
  - security
  - deploy

variables:
  IMAGE_NAME: $CI_REGISTRY_IMAGE/api
  IMAGE_TAG: $CI_COMMIT_SHORT_SHA

build:
  stage: build
  image: docker:latest
  services:
    - docker:dind
  before_script:
    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY
  script:
    - docker build -t $IMAGE_NAME:$IMAGE_TAG -f src/Api/Dockerfile .
    - docker push $IMAGE_NAME:$IMAGE_TAG
  only:
    - main
    - develop

container_scanning:
  stage: security
  image: aquasec/trivy:latest
  services:
    - docker:dind
  variables:
    GIT_STRATEGY: none
  script:
    # Scan com Trivy
    - trivy image --exit-code 1 --severity CRITICAL,HIGH $IMAGE_NAME:$IMAGE_TAG
    # Gerar relatório
    - trivy image --format json --output trivy-report.json $IMAGE_NAME:$IMAGE_TAG
  artifacts:
    reports:
      container_scanning: trivy-report.json
    expire_in: 1 week
  allow_failure: false
  only:
    - main
    - develop

sast:
  stage: security
  image: returntocorp/semgrep:latest
  script:
    - semgrep --config=auto --json --output=semgrep-report.json
  artifacts:
    reports:
      sast: semgrep-report.json
  allow_failure: true
```

