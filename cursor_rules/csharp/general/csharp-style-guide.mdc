        .CreateHistogram("user_creation_duration_seconds", "User creation duration");

    private static readonly Gauge ActiveUsersGauge = Metrics
        .CreateGauge("active_users_count", "Number of active users");

    public async Task CreateUserAsync(UserRequest request)
