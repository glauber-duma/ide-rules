### 2.1. Organização de Members

```csharp
// ✅ CORRETO - Estrutura organizada com regions

public class UserService : IUserService, IDisposable
{
    #region Fields
    private readonly IUserRepository _userRepository;
    private readonly ILogger<UserService> _logger;
    private readonly IMapper _mapper;
    private readonly IValidator<UserRequest> _validator;
    private bool _disposed = false;
    #endregion

    #region Properties
    public string ServiceName { get; } = "UserService";
    public int MaxRetries { get; set; } = 3;
    #endregion

    #region Constructors
    public UserService(
        IUserRepository userRepository,
        ILogger<UserService> logger,
        IMapper mapper,
        IValidator<UserRequest> validator)
    {
        _userRepository = userRepository ?? throw new ArgumentNullException(nameof(userRepository));
        _logger = logger ?? throw new ArgumentNullException(nameof(logger));
        _mapper = mapper ?? throw new ArgumentNullException(nameof(mapper));
        _validator = validator ?? throw new ArgumentNullException(nameof(validator));
    }
    #endregion

    #region Public Methods
    public async Task<UserResponse> GetUserAsync(int id)
    {
        _logger.LogInformation("Getting user with ID: {UserId}", id);

        var user = await _userRepository.GetByIdAsync(id);
        if (user == null)
        {
            throw new NotFoundException($"User with ID {id} not found");
        }

        return _mapper.Map<UserResponse>(user);
    }

    public async Task<List<UserResponse>> GetAllUsersAsync()
    {
        _logger.LogInformation("Getting all users");

        var users = await _userRepository.GetAllAsync();
        return _mapper.Map<List<UserResponse>>(users);
    }

    public async Task CreateUserAsync(UserRequest request)
    {
        _logger.LogInformation("Creating new user");

        await ValidateRequestAsync(request);

        var user = _mapper.Map<UserEntity>(request);
        user.CreatedAt = DateTime.UtcNow;

        await _userRepository.AddAsync(user);
        await _userRepository.SaveChangesAsync();

        _logger.LogInformation("User created with ID: {UserId}", user.Id);
    }

    public async Task UpdateUserAsync(int id, UserRequest request)
    {
        _logger.LogInformation("Updating user with ID: {UserId}", id);

        await ValidateRequestAsync(request);

        var user = await _userRepository.GetByIdAsync(id);
        if (user == null)
        {
            throw new NotFoundException($"User with ID {id} not found");
        }

        _mapper.Map(request, user);
        user.UpdatedAt = DateTime.UtcNow;

        _userRepository.Update(user);
        await _userRepository.SaveChangesAsync();

        _logger.LogInformation("User updated: {UserId}", id);
    }

    public async Task DeleteUserAsync(int id)
    {
        _logger.LogInformation("Deleting user with ID: {UserId}", id);

        var user = await _userRepository.GetByIdAsync(id);
        if (user == null)
        {
            throw new NotFoundException($"User with ID {id} not found");
        }

        _userRepository.Delete(user);
        await _userRepository.SaveChangesAsync();

        _logger.LogInformation("User deleted: {UserId}", id);
    }
    #endregion

    #region Private Methods
    private async Task ValidateRequestAsync(UserRequest request)
    {
        var validationResult = await _validator.ValidateAsync(request);
        if (!validationResult.IsValid)
        {
            var errors = string.Join(", ", validationResult.Errors.Select(e => e.ErrorMessage));
            throw new ValidationException($"Validation failed: {errors}");
        }
    }

    private bool UserExists(int id)
    {
        return _userRepository.Exists(id);
    }
    #endregion

    #region IDisposable
    public void Dispose()
    {
        Dispose(true);
        GC.SuppressFinalize(this);
    }

    protected virtual void Dispose(bool disposing)
    {
        if (!_disposed)
        {
            if (disposing)
            {
                // Dispose managed resources
            }
            _disposed = true;
        }
    }
    #endregion
}
```

### 2.2. Builder Pattern (Modernizado)

```csharp
// ✅ CORRETO - Init-only properties com collection expressions (C# 12)
public record EmailMessage
{
    public required string From { get; init; }
    public required string To { get; init; }
    public required string Subject { get; init; }
    public required string Body { get; init; }
    public List<string> Cc { get; init; } = [];
    public List<string> Bcc { get; init; } = [];
    public List<Attachment> Attachments { get; init; } = [];
    public EmailPriority Priority { get; init; }
    public bool IsHtml { get; init; }
}

// ✅ CORRETO - Uso com object initializer (mais simples que Builder)
var email = new EmailMessage
{
    From = "sender@example.com",
    To = "recipient@example.com",
    Subject = "Important Message",
    Body = "This is the email body",
    Cc = ["cc1@example.com", "cc2@example.com"],
    Priority = EmailPriority.High,
    IsHtml = true
};

// ✅ CORRETO - Builder pattern tradicional quando há validação complexa
public class EmailMessage
{
    public string From { get; init; } = string.Empty;
    public string To { get; init; } = string.Empty;
    public string Subject { get; init; } = string.Empty;
    public string Body { get; init; } = string.Empty;
    public List<string> Cc { get; init; } = [];
    public List<string> Bcc { get; init; } = [];
    public List<Attachment> Attachments { get; init; } = [];
    public EmailPriority Priority { get; init; }
    public bool IsHtml { get; init; }
}

// Builder para a entidade
public class EmailMessageBuilder
{
    private readonly EmailMessage _message;

    public EmailMessageBuilder()
    {
        _message = new EmailMessage();
    }

    public EmailMessageBuilder From(string from)
    {
        _message.From = from;
        return this;
    }

    public EmailMessageBuilder To(string to)
    {
        _message.To = to;
        return this;
    }

    public EmailMessageBuilder Subject(string subject)
    {
        _message.Subject = subject;
        return this;
    }

    public EmailMessageBuilder Body(string body)
    {
        _message.Body = body;
        return this;
    }

    public EmailMessageBuilder AddCc(params string[] cc)
    {
        foreach (var address in cc)
            _message.Cc.Add(address);
        return this;
    }

    public EmailMessageBuilder AddBcc(params string[] bcc)
    {
        foreach (var address in bcc)
            _message.Bcc.Add(address);
        return this;
    }

    public EmailMessageBuilder AddAttachment(params Attachment[] attachments)
    {
        foreach (var attachment in attachments)
            _message.Attachments.Add(attachment);
        return this;
    }

    public EmailMessageBuilder WithPriority(EmailPriority priority)
    {
        _message.Priority = priority;
        return this;
    }

    public EmailMessageBuilder AsHtml(bool isHtml = true)
    {
        _message.IsHtml = isHtml;
        return this;
    }

    public EmailMessage Build()
    {
        // Validações antes de construir
        if (string.IsNullOrWhiteSpace(_message.From))
            throw new InvalidOperationException("From address is required");

        if (string.IsNullOrWhiteSpace(_message.To))
            throw new InvalidOperationException("To address is required");

        if (string.IsNullOrWhiteSpace(_message.Subject))
            throw new InvalidOperationException("Subject is required");

        return _message;
    }
}

// Uso do Builder
var email = new EmailMessageBuilder()
    .From("sender@example.com")
    .To("recipient@example.com")
    .Subject("Important Message")
    .Body("This is the email body")
    .AddCc("cc@example.com")
    .WithPriority(EmailPriority.High)
    .AsHtml()
    .Build();
```

### 2.3. Fluent Interface e Collection Expressions

```csharp
// ✅ CORRETO - Collection expressions (C# 12)
List<string> names = ["Alice", "Bob", "Charlie"];
int[] numbers = [1, 2, 3, 4, 5];
string[] empty = [];

// ✅ CORRETO - Spread operator em collections
