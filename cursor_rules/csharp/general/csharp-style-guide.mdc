## 2. 📐 Estrutura de Classes e Records

### 2.0. Primary Constructors (C# 12)

```csharp
// ✅ CORRETO - Primary constructors para classes (C# 12)
public class UserService(IUserRepository repository, ILogger<UserService> logger) : IUserService
{
    // Parâmetros do primary constructor são automaticamente campos
    public async Task<User> GetUserAsync(int id)
    {
        logger.LogInformation("Getting user {UserId}", id);
        return await repository.GetByIdAsync(id);
    }
}

// ✅ CORRETO - Primary constructor com validação
public class EmailService(IEmailSender sender, ILogger<EmailService> logger) : IEmailService
{
    private readonly IEmailSender _sender = sender ?? throw new ArgumentNullException(nameof(sender));
    private readonly ILogger<EmailService> _logger = logger ?? throw new ArgumentNullException(nameof(logger));

    public async Task SendAsync(string to, string subject, string body)
    {        _logger.LogInformation("Sending email to {Recipient}", to);
        await _sender.SendEmailAsync(to, subject, body);
    }
}

// ✅ CORRETO - Primary constructor com propriedades adicionais
public class CacheService(IMemoryCache cache, IOptions<CacheOptions> options) : ICacheService
{
    private readonly CacheOptions _options = options.Value;
    public int DefaultExpirationMinutes { get; init; } = 30;

    public void Set<T>(string key, T value)
    {
        var expiration = TimeSpan.FromMinutes(_options.ExpirationMinutes ?? DefaultExpirationMinutes);
        cache.Set(key, value, expiration);
    }
}

// ✅ CORRETO - Records com primary constructor (padrão)
public record UserDto(int Id, string Name, string Email);

// ❌ EVITE - Constructor tradicional quando primary é mais limpo
public class UserService : IUserService
{
    private readonly IUserRepository _repository;
    private readonly ILogger<UserService> _logger;

    public UserService(IUserRepository repository, ILogger<UserService> logger)
