// ✅ CORRETO - Interface fluente para configuração
public class QueryBuilder<T> where T : class
{
    private readonly List<string> _includes = [];
    private readonly List<string> _orderBy = [];
    private int? _take;
    private int? _skip;

    public QueryBuilder<T> Include(string navigationProperty)
    {
        _includes.Add(navigationProperty);
        return this;
    }

    public QueryBuilder<T> OrderBy(string property)
    {
        _orderBy.Add(property);
        return this;
    }

    public QueryBuilder<T> Take(int count)
    {
        _take = count;
        return this;
    }

    public QueryBuilder<T> Skip(int count)
    {
        _skip = count;
        return this;
    }

    public IQueryable<T> Build(IQueryable<T> query)
    {
        foreach (var include in _includes)
        {
            // Apply includes
        }

        foreach (var orderBy in _orderBy)
        {
            // Apply ordering
        }

        if (_skip.HasValue)
        {
            query = query.Skip(_skip.Value);
        }

        if (_take.HasValue)
        {
            query = query.Take(_take.Value);
        }

        return query;
    }
}

// Uso da interface fluente
var query = new QueryBuilder<User>()
    .Include("Orders")
    .Include("Address")
    .OrderBy("LastName")
    .Skip(10)
    .Take(20)
    .Build(dbContext.Users);
