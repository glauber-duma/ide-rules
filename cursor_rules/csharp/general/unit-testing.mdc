## 3. 📦 xUnit Fundamentals

### 3.1. Facts vs Theories

```csharp
// ✅ CORRETO - Use [Fact] para testes simples sem parâmetros
[Fact]
public void Constructor_WithValidParameters_CreatesInstance()
{
    var user = new User(1, "John", "Doe");
    
    user.Should().NotBeNull();
    user.Id.Should().Be(1);
}

// ✅ CORRETO - Use [Theory] para testes parametrizados
[Theory]
[InlineData(1, 2, 3)]
[InlineData(10, 20, 30)]
[InlineData(-5, 5, 0)]
[InlineData(0, 0, 0)]
public void Add_MultipleScenarios_ReturnsCorrectSum(int a, int b, int expected)
{
    var calculator = new Calculator();
    
    var result = calculator.Add(a, b);
    
    result.Should().Be(expected);
}
```

### 3.2. InlineData para Cenários Múltiplos

```csharp
// ✅ CORRETO - InlineData para validações
[Theory]
[InlineData("")]
[InlineData(null)]
[InlineData("   ")]
public void Validate_EmptyOrNullEmail_ReturnsFalse(string email)
{
    var validator = new EmailValidator();
    
    var result = validator.IsValid(email);
    
    result.Should().BeFalse();
}

// ✅ CORRETO - InlineData com múltiplos parâmetros
[Theory]
[InlineData("john@example.com", true)]
[InlineData("invalid-email", false)]
[InlineData("@example.com", false)]
[InlineData("john@", false)]
[InlineData("john.doe@company.co.uk", true)]
public void IsValidEmail_VariousFormats_ReturnsExpectedResult(string email, bool expected)
{
    var validator = new EmailValidator();
    
    var result = validator.IsValid(email);
    
    result.Should().Be(expected);
}
```

### 3.3. MemberData e ClassData

```csharp
// ✅ CORRETO - MemberData para cenários complexos
public class UserServiceTests
{
    public static IEnumerable<object[]> GetUserTestData()
    {
        yield return new object[] 
        { 
            new User { Id = 1, Name = "John", Email = "john@example.com" },
            true 
        };
        yield return new object[] 
        { 
            new User { Id = 2, Name = "Jane", Email = "invalid-email" },
            false 
        };
    }

    [Theory]
    [MemberData(nameof(GetUserTestData))]
    public void ValidateUser_VariousUsers_ReturnsExpectedResult(User user, bool expected)
    {
        var validator = new UserValidator();
        
        var result = validator.IsValid(user);
        
        result.Should().Be(expected);
    }
}

// ✅ CORRETO - ClassData para reutilização entre testes
public class CalculatorTestData : IEnumerable<object[]>
{
    public IEnumerator<object[]> GetEnumerator()
    {
        yield return new object[] { 1, 2, 3 };
        yield return new object[] { 10, 20, 30 };
        yield return new object[] { -5, 5, 0 };
    }

    IEnumerator IEnumerable.GetEnumerator() => GetEnumerator();
}

public class CalculatorTests
{
    [Theory]
    [ClassData(typeof(CalculatorTestData))]
    public void Add_MultipleScenarios_ReturnsSum(int a, int b, int expected)
    {
        var calculator = new Calculator();
        
        var result = calculator.Add(a, b);
        
        result.Should().Be(expected);
    }
}
```

