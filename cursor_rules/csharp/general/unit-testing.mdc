## 9. 📋 Boas Práticas

### 9.1. Princípios FIRST

```csharp
// F - Fast (Rápido)
// ✅ Use mocks ao invés de dependências reais
// ✅ Evite I/O (arquivo, rede, banco real)

// I - Independent (Independente)
// ✅ Cada teste deve poder rodar isoladamente
[Fact]
public void Test1_IndependentTest()
{
    var calculator = new Calculator();
    calculator.Add(1, 2).Should().Be(3);
}

[Fact]
public void Test2_AlsoIndependent()
{
    var calculator = new Calculator();
    calculator.Multiply(2, 3).Should().Be(6);
}

// R - Repeatable (Repetível)
// ✅ Não dependa de data/hora atual diretamente
// ❌ INCORRETO
[Fact]
public void BadTest_DependsOnCurrentDate()
{
    var tomorrow = DateTime.Now.AddDays(1);  // ❌ Não repetível
}

// ✅ CORRETO - Use abstrações
[Fact]
public void GoodTest_UsesAbstractedTime()
{
    var clockMock = new Mock<ISystemClock>();
    clockMock.Setup(c => c.UtcNow).Returns(new DateTime(2026, 1, 1));
    
    var service = new DateService(clockMock.Object);
    var tomorrow = service.GetTomorrow();
    
    tomorrow.Should().Be(new DateTime(2026, 1, 2));
}

// S - Self-Validating (Auto-validável)
// ✅ Assert claro, sem necessidade de inspeção manual

// T - Timely (Oportuno)
// ✅ Escreva testes junto com o código (TDD)
```

### 9.2. Testes Focados (Single Responsibility)

```csharp
// ✅ CORRETO - Um teste, uma responsabilidade
[Fact]
public void CalculateTotal_WithItems_ReturnsSum()
{
    var order = new Order();
    order.AddItem(new OrderItem { Price = 10, Quantity = 2 });
    order.AddItem(new OrderItem { Price = 5, Quantity = 3 });
    
    order.Total.Should().Be(35);
}

[Fact]
public void CalculateTotal_WithDiscount_AppliesDiscount()
{
    var order = new Order { Discount = 0.10m };
    order.AddItem(new OrderItem { Price = 100, Quantity = 1 });
    
    order.Total.Should().Be(90);
}

// ❌ INCORRETO - Teste fazendo múltiplas verificações não relacionadas
[Fact]
public void BadTest_TestingTooMuch()
{
    var order = new Order();
    order.AddItem(new OrderItem { Price = 10 });
    order.Total.Should().Be(10);  // Testando total
    
    order.Status = OrderStatus.Shipped;
    order.ShippedAt.Should().NotBeNull();  // Testando status (não relacionado)
    
    order.Customer.Name.Should().NotBeEmpty();  // Testando customer (não relacionado)
}
```

### 9.3. Avoid Test Code Duplication

```csharp
// ✅ CORRETO - Helper methods para reduzir duplicação
public class UserServiceTests
{
    private UserService CreateService(Mock<IUserRepository>? repositoryMock = null)
    {
        repositoryMock ??= new Mock<IUserRepository>();
        var loggerMock = new Mock<ILogger<UserService>>();
        return new UserService(repositoryMock.Object, loggerMock.Object);
    }

    private User CreateTestUser(int id = 1, string name = "John")
    {
        return new User { Id = id, Name = name, Email = $"{name.ToLower()}@example.com" };
    }

    [Fact]
    public async Task Test1_UsesHelpers()
    {
        var user = CreateTestUser();
        var repositoryMock = new Mock<IUserRepository>();
        repositoryMock.Setup(r => r.GetByIdAsync(1, It.IsAny<CancellationToken>()))
            .ReturnsAsync(user);
        
        var service = CreateService(repositoryMock);
        
        var result = await service.GetUserAsync(1);
        result.Should().Be(user);
    }
}
```

