## 5. 🎲 Bogus - Geração de Dados Fake

### 5.1. Faker Básico

```csharp
// ✅ CORRETO - Faker para gerar dados simples
[Fact]
public void CreateUser_RandomData_Success()
{
    // Arrange
    var faker = new Faker();
    var name = faker.Name.FullName();
    var email = faker.Internet.Email();
    var birthDate = faker.Date.Past(30);

    var user = new User
    {
        Name = name,
        Email = email,
        BirthDate = birthDate
    };

    // Act & Assert
    user.Name.Should().NotBeEmpty();
    user.Email.Should().Contain("@");
}

// ✅ CORRETO - Faker tipado com regras
[Fact]
public void GenerateUsers_WithBogus_CreatesValidUsers()
{
    // Arrange
    var userFaker = new Faker<User>()
        .RuleFor(u => u.Id, f => f.Random.Int(1, 1000))
        .RuleFor(u => u.FirstName, f => f.Name.FirstName())
        .RuleFor(u => u.LastName, f => f.Name.LastName())
        .RuleFor(u => u.Email, (f, u) => f.Internet.Email(u.FirstName, u.LastName))
        .RuleFor(u => u.BirthDate, f => f.Date.Past(50, DateTime.Now.AddYears(-18)))
        .RuleFor(u => u.CreatedAt, f => f.Date.Recent());

    // Act
    var users = userFaker.Generate(10);

    // Assert
    users.Should().HaveCount(10);
    users.Should().OnlyContain(u => !string.IsNullOrEmpty(u.Email));
    users.Should().OnlyContain(u => u.Email.Contains("@"));
}
```

### 5.2. Builders com Bogus

```csharp
// ✅ CORRETO - Builder combinado com Faker
public class UserBuilder
{
    private static readonly Faker<User> _faker = new Faker<User>()
        .RuleFor(u => u.Id, f => f.Random.Int(1, 1000))
        .RuleFor(u => u.FirstName, f => f.Name.FirstName())
        .RuleFor(u => u.LastName, f => f.Name.LastName())
        .RuleFor(u => u.Email, (f, u) => f.Internet.Email(u.FirstName, u.LastName))
        .RuleFor(u => u.BirthDate, f => f.Date.Past(50, DateTime.Now.AddYears(-18)))
        .RuleFor(u => u.IsActive, f => f.Random.Bool())
        .RuleFor(u => u.CreatedAt, f => f.Date.Recent());

    private User _user;

    public UserBuilder()
    {
        _user = _faker.Generate();
    }

    public UserBuilder WithId(int id)
    {
        _user.Id = id;
        return this;
    }

    public UserBuilder WithEmail(string email)
    {
        _user.Email = email;
        return this;
    }

    public UserBuilder WithInactiveStatus()
    {
        _user.IsActive = false;
        return this;
    }

    public User Build() => _user;
}

// Uso nos testes
[Fact]
public void ProcessUser_InactiveUser_ThrowsException()
{
    // Arrange
    var user = new UserBuilder()
        .WithInactiveStatus()
        .Build();

    var service = new UserService();

    // Act & Assert
    service.Invoking(s => s.ProcessUser(user))
        .Should().Throw<InvalidOperationException>();
}
```

### 5.3. Datasets com Bogus

```csharp
// ✅ CORRETO - Gerar lista de dados para testes
public class OrderTestFixture
{
    public List<Order> GenerateOrders(int count)
    {
        var orderFaker = new Faker<Order>()
            .RuleFor(o => o.Id, f => f.Random.Guid())
            .RuleFor(o => o.OrderNumber, f => f.Random.AlphaNumeric(10).ToUpper())
            .RuleFor(o => o.CustomerId, f => f.Random.Int(1, 1000))
            .RuleFor(o => o.TotalAmount, f => f.Finance.Amount(10, 1000))
            .RuleFor(o => o.Status, f => f.PickRandom<OrderStatus>())
            .RuleFor(o => o.CreatedAt, f => f.Date.Recent(30))
            .RuleFor(o => o.Items, f => GenerateOrderItems(f.Random.Int(1, 5)));

        return orderFaker.Generate(count);
    }

    private List<OrderItem> GenerateOrderItems(int count)
    {
        var itemFaker = new Faker<OrderItem>()
            .RuleFor(i => i.ProductId, f => f.Random.Guid())
            .RuleFor(i => i.ProductName, f => f.Commerce.ProductName())
            .RuleFor(i => i.Quantity, f => f.Random.Int(1, 10))
            .RuleFor(i => i.UnitPrice, f => f.Finance.Amount(5, 500))
            .RuleFor(i => i.Discount, f => f.Random.Decimal(0, 0.3m));

        return itemFaker.Generate(count);
    }
}

[Fact]
public void CalculateTotalDiscount_MultipleOrders_ReturnsCorrectSum()
{
    // Arrange
    var fixture = new OrderTestFixture();
    var orders = fixture.GenerateOrders(20);
    var service = new OrderService();

    // Act
    var totalDiscount = service.CalculateTotalDiscount(orders);

    // Assert
    totalDiscount.Should().BeGreaterThanOrEqualTo(0);
}
```

