## 2. 🧪 Padrão AAA (Arrange, Act, Assert)

```csharp
// ✅ CORRETO - Estrutura AAA clara com comentários/separação
[Fact]
public async Task GetUserAsync_ValidId_ReturnsUser()
{
    // Arrange
    var userId = 1;
    var expectedUser = new User { Id = userId, Name = "John Doe" };
    
    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.GetByIdAsync(userId, It.IsAny<CancellationToken>()))
        .ReturnsAsync(expectedUser);
    
    var service = new UserService(repositoryMock.Object);

    // Act
    var result = await service.GetUserAsync(userId);

    // Assert
    result.Should().NotBeNull();
    result.Id.Should().Be(userId);
    result.Name.Should().Be("John Doe");
}

// ✅ CORRETO - AAA sem comentários quando óbvio
[Fact]
public void Add_TwoNumbers_ReturnsSum()
{
    var calculator = new Calculator();
    
    var result = calculator.Add(2, 3);
    
    result.Should().Be(5);
}

// ❌ INCORRETO - Estrutura confusa sem separação clara
[Fact]
public async Task GetUserAsyncTest()
{
    var repositoryMock = new Mock<IUserRepository>();
    var service = new UserService(repositoryMock.Object);
    repositoryMock.Setup(r => r.GetByIdAsync(1, It.IsAny<CancellationToken>()))
        .ReturnsAsync(new User { Id = 1, Name = "John" });
    var result = await service.GetUserAsync(1);
    result.Should().NotBeNull();
}
```

