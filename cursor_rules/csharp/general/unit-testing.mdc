## 4. 🎭 Moq - Mocking e Verificação

### 4.1. Setup Básico

```csharp
// ✅ CORRETO - Setup simples com retorno
[Fact]
public async Task GetUserAsync_ValidId_ReturnsUser()
{
    // Arrange
    var userId = 1;
    var expectedUser = new User { Id = userId, Name = "John" };
    
    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.GetByIdAsync(userId, It.IsAny<CancellationToken>()))
        .ReturnsAsync(expectedUser);

    var service = new UserService(repositoryMock.Object);

    // Act
    var result = await service.GetUserAsync(userId);

    // Assert
    result.Should().Be(expectedUser);
}

// ✅ CORRETO - Setup com Exception
[Fact]
public async Task GetUserAsync_RepositoryThrows_PropagatesException()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.GetByIdAsync(It.IsAny<int>(), It.IsAny<CancellationToken>()))
        .ThrowsAsync(new DatabaseException("Connection failed"));

    var service = new UserService(repositoryMock.Object);

    // Act & Assert
    await service.Invoking(s => s.GetUserAsync(1))
        .Should().ThrowAsync<DatabaseException>()
        .WithMessage("Connection failed");
}
```

### 4.2. It.Is e It.IsAny

```csharp
// ✅ CORRETO - It.Is para match específico
[Fact]
public async Task CreateUserAsync_ValidUser_CallsRepositoryWithCorrectUser()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>();
    var service = new UserService(repositoryMock.Object);
    var userRequest = new UserRequest { Name = "John", Email = "john@example.com" };

    // Act
    await service.CreateUserAsync(userRequest);

    // Assert
    repositoryMock.Verify(
        r => r.AddAsync(
            It.Is<User>(u => u.Name == "John" && u.Email == "john@example.com"),
            It.IsAny<CancellationToken>()),
        Times.Once);
}

// ✅ CORRETO - It.IsAny para parâmetros irrelevantes
[Fact]
public async Task DeleteUserAsync_ValidId_CallsRepository()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.GetByIdAsync(It.IsAny<int>(), It.IsAny<CancellationToken>()))
        .ReturnsAsync(new User { Id = 1 });

    var service = new UserService(repositoryMock.Object);

    // Act
    await service.DeleteUserAsync(1);

    // Assert
    repositoryMock.Verify(
        r => r.DeleteAsync(It.IsAny<User>(), It.IsAny<CancellationToken>()),
        Times.Once);
}
```

### 4.3. Verify - Verificação de Chamadas

```csharp
// ✅ CORRETO - Verify com Times
[Fact]
public async Task ProcessOrderAsync_ValidOrder_SendsEmailOnce()
{
    // Arrange
    var emailServiceMock = new Mock<IEmailService>();
    var service = new OrderService(emailServiceMock.Object);
    var order = new Order { Id = 1, CustomerEmail = "customer@example.com" };

    // Act
    await service.ProcessOrderAsync(order);

    // Assert
    emailServiceMock.Verify(
        e => e.SendEmailAsync(
            "customer@example.com",
            It.IsAny<string>(),
            It.IsAny<string>(),
            It.IsAny<CancellationToken>()),
        Times.Once);
}

// ✅ CORRETO - Verify que método NÃO foi chamado
[Fact]
public async Task ProcessOrderAsync_InvalidOrder_DoesNotSendEmail()
{
    // Arrange
    var emailServiceMock = new Mock<IEmailService>();
    var service = new OrderService(emailServiceMock.Object);
    var invalidOrder = new Order { Id = 0 };

    // Act
    await service.ProcessOrderAsync(invalidOrder);

    // Assert
    emailServiceMock.Verify(
        e => e.SendEmailAsync(
            It.IsAny<string>(),
            It.IsAny<string>(),
            It.IsAny<string>(),
            It.IsAny<CancellationToken>()),
        Times.Never);
}

// ✅ CORRETO - VerifyAll para garantir todos os setups foram usados
[Fact]
public async Task ComplexScenario_AllMocksUsed()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>(MockBehavior.Strict);
    repositoryMock
        .Setup(r => r.GetByIdAsync(1, It.IsAny<CancellationToken>()))
        .ReturnsAsync(new User { Id = 1 });

    var service = new UserService(repositoryMock.Object);

    // Act
    await service.GetUserAsync(1);

    // Assert
    repositoryMock.VerifyAll();
}
```

### 4.4. Callback para Capturar Argumentos

```csharp
// ✅ CORRETO - Callback para verificar argumento capturado
[Fact]
public async Task CreateUserAsync_ValidUser_SetsCreatedAtTimestamp()
{
    // Arrange
    User? capturedUser = null;
    
    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.AddAsync(It.IsAny<User>(), It.IsAny<CancellationToken>()))
        .Callback<User, CancellationToken>((user, ct) => capturedUser = user)
        .Returns(Task.CompletedTask);

    var service = new UserService(repositoryMock.Object);
    var userRequest = new UserRequest { Name = "John" };

    // Act
    await service.CreateUserAsync(userRequest);

    // Assert
    capturedUser.Should().NotBeNull();
    capturedUser!.CreatedAt.Should().BeCloseTo(DateTime.UtcNow, TimeSpan.FromSeconds(1));
}

// ✅ CORRETO - Callback para simular side effects
[Fact]
public async Task ProcessPaymentAsync_Success_UpdatesOrderStatus()
{
    // Arrange
    var order = new Order { Id = 1, Status = OrderStatus.Pending };
    
    var paymentServiceMock = new Mock<IPaymentService>();
    paymentServiceMock
        .Setup(p => p.ProcessAsync(It.IsAny<PaymentRequest>()))
        .Callback(() => order.Status = OrderStatus.Paid)
        .ReturnsAsync(new PaymentResult { Success = true });

    var service = new OrderService(paymentServiceMock.Object);

    // Act
    await service.ProcessPaymentAsync(order);

    // Assert
    order.Status.Should().Be(OrderStatus.Paid);
}
```

### 4.5. MockBehavior

```csharp
// ✅ CORRETO - MockBehavior.Strict para garantir todos os métodos têm setup
[Fact]
public void StrictMock_UnmockedMethod_ThrowsException()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>(MockBehavior.Strict);
    repositoryMock
        .Setup(r => r.GetByIdAsync(1, It.IsAny<CancellationToken>()))
        .ReturnsAsync(new User { Id = 1 });

    // Act & Assert
    // Chamar método não mockado lança exceção
    var service = new UserService(repositoryMock.Object);
    
    // Isso vai funcionar
    Assert.NotNull(service.GetUserAsync(1));
    
    // Isso lançaria exceção se não tivesse setup
    // await service.GetAllUsersAsync();  // ❌ MockException!
}

// ✅ CORRETO - MockBehavior.Loose (padrão) permite métodos sem setup
[Fact]
public async Task LooseMock_UnmockedMethod_ReturnsDefault()
{
    // Arrange
    var repositoryMock = new Mock<IUserRepository>(MockBehavior.Loose);
    // Não precisa setup para todos os métodos

    var service = new UserService(repositoryMock.Object);

    // Act
    var result = await service.GetUserAsync(999);  // Retorna null (default)

    // Assert
    result.Should().BeNull();
}
```

