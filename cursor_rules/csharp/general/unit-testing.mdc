// ✅ CORRETO - Testar timeout com CancellationToken
[Fact]
public async Task LongRunningOperation_CancellationRequested_ThrowsOperationCanceledException()
{
    // Arrange
    var service = new UserService();
    var cts = new CancellationTokenSource();
    cts.Cancel();

    // Act & Assert
    await service.Invoking(s => s.ProcessAllUsersAsync(cts.Token))
        .Should().ThrowAsync<OperationCanceledException>();
}

// ✅ CORRETO - Testar operações paralelas
[Fact]
public async Task ProcessMultipleUsers_Parallel_AllSucceed()
{
    // Arrange
    var service = new UserService();
    var users = Enumerable.Range(1, 10)
        .Select(i => new User { Id = i, Name = $"User{i}" })
        .ToList();

    // Act
    var tasks = users.Select(u => service.ProcessUserAsync(u));
    var results = await Task.WhenAll(tasks);

    // Assert
    results.Should().HaveCount(10);
    results.Should().OnlyContain(r => r.Success);
}
