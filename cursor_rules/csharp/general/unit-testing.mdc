## 6. 💎 FluentAssertions

### 6.1. Assertions Básicas

```csharp
// ✅ CORRETO - FluentAssertions para legibilidade
[Fact]
public void User_Properties_ShouldHaveExpectedValues()
{
    // Arrange & Act
    var user = new User
    {
        Id = 1,
        Name = "John Doe",
        Email = "john@example.com",
        IsActive = true
    };

    // Assert
    user.Id.Should().Be(1);
    user.Name.Should().Be("John Doe");
    user.Email.Should().Contain("@");
    user.Email.Should().EndWith(".com");
    user.IsActive.Should().BeTrue();
}

// ✅ CORRETO - Comparação de objetos
[Fact]
public void CreateUser_ValidData_ReturnsSameValues()
{
    // Arrange
    var userRequest = new UserRequest
    {
        FirstName = "John",
        LastName = "Doe",
        Email = "john@example.com"
    };

    var service = new UserService();

    // Act
    var result = service.CreateUser(userRequest);

    // Assert
    result.Should().NotBeNull();
    result.Should().BeEquivalentTo(new
    {
        FirstName = "John",
        LastName = "Doe",
        Email = "john@example.com"
    });
}
```

### 6.2. Collections

```csharp
// ✅ CORRETO - Assertions para coleções
[Fact]
public async Task GetAllUsersAsync_ReturnsMultipleUsers()
{
    // Arrange
    var users = new List<User>
    {
        new() { Id = 1, Name = "John" },
        new() { Id = 2, Name = "Jane" },
        new() { Id = 3, Name = "Bob" }
    };

    var repositoryMock = new Mock<IUserRepository>();
    repositoryMock
        .Setup(r => r.GetAllAsync(It.IsAny<CancellationToken>()))
        .ReturnsAsync(users);

    var service = new UserService(repositoryMock.Object);

    // Act
    var result = await service.GetAllUsersAsync();

    // Assert
    result.Should().HaveCount(3);
    result.Should().Contain(u => u.Name == "John");
    result.Should().OnlyContain(u => u.Id > 0);
    result.Should().BeInAscendingOrder(u => u.Id);
}

// ✅ CORRETO - BeEquivalentTo para comparação complexa
[Fact]
public void GetUsers_ReturnsExpectedCollection()
{
    // Arrange
    var expectedUsers = new[]
    {
        new User { Id = 1, Name = "John", Email = "john@example.com" },
        new User { Id = 2, Name = "Jane", Email = "jane@example.com" }
    };

    var service = new UserService();

    // Act
    var result = service.GetUsers();

    // Assert
    result.Should().BeEquivalentTo(expectedUsers, options => options
        .Excluding(u => u.CreatedAt)
        .WithStrictOrdering());
}
