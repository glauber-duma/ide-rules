[HttpDelete("{id:guid}")]
[ProducesResponseType(StatusCodes.Status204NoContent)]
[ProducesResponseType(typeof(ApiProblemDetails), StatusCodes.Status404NotFound)]
public async Task<IActionResult> DeleteProduct(Guid id)
