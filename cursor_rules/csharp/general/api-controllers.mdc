### 7.7. Bulk Operations

```csharp
/// <summary>
/// Cria múltiplos produtos em lote
/// </summary>
/// <param name="commands">Lista de produtos a criar</param>
/// <returns>Resultado da operação em lote</returns>
/// <response code="200">Operação concluída (pode ter falhas parciais)</response>
/// <response code="400">Dados inválidos</response>
[HttpPost("bulk")]
[ProducesResponseType(typeof(BulkOperationResult<ProductDto>), StatusCodes.Status200OK)]
[ProducesResponseType(typeof(ApiProblemDetails), StatusCodes.Status400BadRequest)]
public async Task<IActionResult> BulkCreateProducts([FromBody] List<CreateProductCommand> commands)
{
    var result = await _mediator.Send(new BulkCreateProductsCommand(commands));
    return HandleResult(result);
}

public class BulkOperationResult<T>
{
    public int TotalRequested { get; init; }
    public int SuccessCount { get; init; }
    public int FailureCount { get; init; }
    public List<T> SuccessItems { get; init; } = [];
    public List<BulkOperationError> Errors { get; init; } = [];
}

public record BulkOperationError(int Index, string Message);
```

