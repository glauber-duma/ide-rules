### 2.2 Config/DependencyInjection.cs

```csharp
// src/Config/DependencyInjection.cs
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.Options;
using Serilog;
using YourProjectName.Core.Interfaces;
using YourProjectName.Data;
using YourProjectName.Data.Repositories;
using YourProjectName.Services;
using YourProjectName.Utils;

namespace YourProjectName.Config;

public static class DependencyInjection
{
    /// <summary>
    /// Registra serviços de negócio da aplicação
    /// </summary>
    public static IServiceCollection AddApplicationServices(this IServiceCollection services)
    {
        services.AddScoped<IUserService, UserService>();
        services.AddScoped<IOrderService, OrderService>();
        
        return services;
    }

    /// <summary>
    /// Configura infraestrutura de dados com Entity Framework Core e PostgreSQL
    /// </summary>
    public static IServiceCollection AddInfrastructure(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        var connectionString = configuration.GetConnectionString("DefaultConnection")
            ?? throw new InvalidOperationException("Connection string 'DefaultConnection' not found");

        services.AddDbContext<AppDbContext>(options =>
        {
            options.UseNpgsql(
                connectionString,
                npgsqlOptions =>
                {
                    npgsqlOptions.EnableRetryOnFailure(
                        maxRetryCount: 3,
                        maxRetryDelay: TimeSpan.FromSeconds(30),
                        errorCodesToAdd: null);
                    
                    npgsqlOptions.CommandTimeout(60);
                    npgsqlOptions.MigrationsHistoryTable("__EFMigrationsHistory");
                });

            var environment = Environment.GetEnvironmentVariable("DOTNET_ENVIRONMENT") ?? "Production";
            if (environment == "Development")
            {
                options.EnableSensitiveDataLogging();
                options.EnableDetailedErrors();
            }
        });

        // Registrar repositórios
        services.AddScoped(typeof(IBaseRepository<>), typeof(BaseRepository<>));
        services.AddScoped<IUserRepository, UserRepository>();
        services.AddScoped<IOrderRepository, OrderRepository>();

        return services;
    }

    /// <summary>
    /// Configura logging estruturado com Serilog
    /// </summary>
    public static IServiceCollection AddLogging(
        this IServiceCollection services,
        IConfiguration configuration)
    {
        var appSettings = configuration.GetSection("AppSettings").Get<AppSettings>();

        Log.Logger = new LoggerConfiguration()
            .MinimumLevel.Information()
            .MinimumLevel.Override("Microsoft", Serilog.Events.LogEventLevel.Warning)
            .MinimumLevel.Override("System", Serilog.Events.LogEventLevel.Warning)
            .Enrich.FromLogContext()
            .Enrich.WithMachineName()
            .Enrich.WithThreadId()
            .Enrich.WithProperty("Application", appSettings?.ApplicationName ?? "BatchApp")
            .Enrich.WithProperty("Version", appSettings?.Version ?? "1.0.0")
            .WriteTo.Console(
                outputTemplate: "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}")
            .WriteTo.File(
                path: "logs/batch-.log",
                rollingInterval: RollingInterval.Day,
                outputTemplate: "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
                retainedFileCountLimit: 30,
                fileSizeLimitBytes: 10_000_000,
                rollOnFileSizeLimit: true)
            .CreateLogger();

        services.AddSerilog();

        return services;
    }

    /// <summary>
    /// Registra classes utilitárias
    /// </summary>
    public static IServiceCollection AddUtilities(this IServiceCollection services)
    {
        services.AddSingleton<IDateTimeProvider, DateTimeProvider>();
        
        return services;
    }
}
```

### 2.3 Program.cs

```csharp
// Program.cs
using System.CommandLine;
using System.Reflection;
using Microsoft.Extensions.Configuration;
using Microsoft.Extensions.DependencyInjection;
using Microsoft.Extensions.Hosting;
using Microsoft.Extensions.Options;
using Serilog;
using YourProjectName.Config;
using YourProjectName.Core.Interfaces;

namespace YourProjectName;

public class Program
{
    public static async Task<int> Main(string[] args)
    {
        try
        {
            // Criar host para carregar configurações
            var tempHost = CreateHostBuilder(args).Build();
            var config = tempHost.Services.GetRequiredService<IConfiguration>();
            var appSettings = config.GetSection("AppSettings").Get<AppSettings>();

            // Exibir banner
            DisplayBanner(appSettings);

            // Configurar comandos CLI
            var rootCommand = new RootCommand("Batch Console Application for processing data in batches");

            // Comando: process
            var processCommand = new Command("process", "Process pending orders in batches");
            
            var batchSizeOption = new Option<int>(
                name: "--batch-size",
                description: "Number of records to process per batch",
                getDefaultValue: () => appSettings?.BatchSize ?? 100);
            
            var dryRunOption = new Option<bool>(
                name: "--dry-run",
                description: "Run without making changes to the database",
                getDefaultValue: () => false);

            processCommand.AddOption(batchSizeOption);
            processCommand.AddOption(dryRunOption);

            processCommand.SetHandler(async (batchSize, dryRun) =>
            {
                using var host = CreateHostBuilder(args).Build();
                await ProcessBatchAsync(host.Services, batchSize, dryRun);
            }, batchSizeOption, dryRunOption);

            rootCommand.AddCommand(processCommand);

            // Comando: migrate
            var migrateCommand = new Command("migrate", "Apply database migrations");
            
            migrateCommand.SetHandler(async () =>
            {
                using var host = CreateHostBuilder(args).Build();
                await MigrateDatabaseAsync(host.Services);
            });

            rootCommand.AddCommand(migrateCommand);

            return await rootCommand.InvokeAsync(args);
        }
        catch (Exception ex)
        {
            Log.Fatal(ex, "Application terminated unexpectedly");
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine($"\n❌ Fatal Error: {ex.Message}");
            Console.ResetColor();
            return 1;
        }
        finally
        {
            Log.CloseAndFlush();
        }
    }

    private static IHostBuilder CreateHostBuilder(string[] args) =>
        Host.CreateDefaultBuilder(args)
            .ConfigureAppConfiguration((context, config) =>
            {
                config.SetBasePath(Directory.GetCurrentDirectory());
                config.AddJsonFile("appsettings.json", optional: false, reloadOnChange: true);
                config.AddJsonFile(
                    $"appsettings.{context.HostingEnvironment.EnvironmentName}.json",
                    optional: true,
                    reloadOnChange: true);
                config.AddEnvironmentVariables();
                config.AddCommandLine(args);
            })
            .ConfigureServices((context, services) =>
            {
                // Configurar AppSettings
                services.Configure<AppSettings>(context.Configuration.GetSection("AppSettings"));
                services.AddSingleton(sp => sp.GetRequiredService<IOptions<AppSettings>>().Value);

                // Adicionar serviços
                services.AddLogging(context.Configuration);
                services.AddInfrastructure(context.Configuration);
                services.AddApplicationServices();
                services.AddUtilities();
            })
            .UseSerilog();

    private static void DisplayBanner(AppSettings? appSettings)
    {
        var assembly = Assembly.GetExecutingAssembly();
        var version = appSettings?.Version ?? assembly.GetName().Version?.ToString() ?? "1.0.0";
        var buildDate = File.GetLastWriteTime(assembly.Location);
        var appName = appSettings?.ApplicationName ?? "Batch Console Application";

        Console.ForegroundColor = ConsoleColor.Cyan;
        Console.WriteLine("╔═══════════════════════════════════════════════════════════════╗");
        Console.WriteLine("║                                                               ║");
        Console.WriteLine($"║  {appName,-59} ║");
        Console.WriteLine("║                                                               ║");
        Console.WriteLine("╠═══════════════════════════════════════════════════════════════╣");
        Console.ForegroundColor = ConsoleColor.White;
        Console.WriteLine($"║  Version:      {version,-46} ║");
        Console.WriteLine($"║  Build Date:   {buildDate:yyyy-MM-dd HH:mm:ss,-35} ║");
        Console.WriteLine($"║  Author:       {"Glauber Duma",-46} ║");
        Console.WriteLine($"║  Environment:  {Environment.GetEnvironmentVariable("DOTNET_ENVIRONMENT") ?? "Production",-46} ║");
        Console.ForegroundColor = ConsoleColor.Cyan;
        Console.WriteLine("║                                                               ║");
        Console.WriteLine("╚═══════════════════════════════════════════════════════════════╝");
        Console.ResetColor();
        Console.WriteLine();
    }

    private static async Task ProcessBatchAsync(
        IServiceProvider services,
        int batchSize,
        bool dryRun)
    {
        using var scope = services.CreateScope();
        var logger = scope.ServiceProvider.GetRequiredService<ILogger<Program>>();
        var orderService = scope.ServiceProvider.GetRequiredService<IOrderService>();

        logger.LogInformation(
            "Starting batch process - BatchSize: {BatchSize}, DryRun: {DryRun}",
            batchSize,
            dryRun);

        var startTime = DateTime.UtcNow;

        try
        {
            await orderService.ProcessOrdersAsync(batchSize, dryRun);
            
            var duration = DateTime.UtcNow - startTime;
            logger.LogInformation(
                "Batch process completed successfully in {Duration:mm\\:ss\\.fff}",
                duration);

            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine($"\n✓ Batch process completed successfully in {duration:mm\\:ss\\.fff}");
            Console.ResetColor();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Batch process failed");
            
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine($"\n✗ Batch process failed: {ex.Message}");
            Console.ResetColor();
            
            throw;
        }
    }

    private static async Task MigrateDatabaseAsync(IServiceProvider services)
    {
        using var scope = services.CreateScope();
        var logger = scope.ServiceProvider.GetRequiredService<ILogger<Program>>();
        var context = scope.ServiceProvider.GetRequiredService<Data.AppDbContext>();

        logger.LogInformation("Applying database migrations...");

        try
        {
            await context.Database.MigrateAsync();
            
            logger.LogInformation("Database migrations applied successfully");
            
            Console.ForegroundColor = ConsoleColor.Green;
            Console.WriteLine("\n✓ Database migrations applied successfully");
            Console.ResetColor();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Failed to apply database migrations");
            
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine($"\n✗ Failed to apply migrations: {ex.Message}");
            Console.ResetColor();
            
            throw;
        }
    }
}
