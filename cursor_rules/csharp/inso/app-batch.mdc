### ✅ DO: Use transactions para operações em lote

```csharp
// ✅ CORRETO - Transaction garante atomicidade
public async Task ProcessBatchAsync(List<OrderEntity> orders)
{
    using var transaction = await _context.Database.BeginTransactionAsync();
    
    try
    {
        foreach (var order in orders)
        {
            order.Status = OrderStatus.Completed;
            order.ProcessedAt = DateTime.UtcNow;
        }
        
        await _context.SaveChangesAsync();
        await transaction.CommitAsync();
        
        _logger.LogInformation("Batch processed successfully - {Count} orders", orders.Count);
    }
    catch (Exception ex)
    {
        await transaction.RollbackAsync();
        _logger.LogError(ex, "Failed to process batch");
        throw;
    }
}

// ❌ INCORRETO - Sem transaction, estado inconsistente em falha
public async Task ProcessBatchAsync(List<OrderEntity> orders)
{
    foreach (var order in orders)
    {
        order.Status = OrderStatus.Completed;
        await _context.SaveChangesAsync();  // Parcialmente persistido se falhar!
    }
}
```

