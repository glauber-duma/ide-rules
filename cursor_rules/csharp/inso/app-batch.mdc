### 5.2 Services/OrderService.cs

```csharp
// src/Services/OrderService.cs
using Microsoft.Extensions.Logging;
using Polly;
using Polly.Retry;
using System.Diagnostics;
using YourProjectName.Config;
using YourProjectName.Core.Entities;
using YourProjectName.Core.Interfaces;
using YourProjectName.Data.Repositories;

namespace YourProjectName.Services;

/// <summary>
/// Serviço de pedidos com processamento em lote
/// </summary>
public class OrderService : IOrderService
{
    private readonly IOrderRepository _orderRepository;
    private readonly ILogger<OrderService> _logger;
    private readonly AppSettings _appSettings;
    private readonly AsyncRetryPolicy _retryPolicy;

    public OrderService(
        IOrderRepository orderRepository,
        ILogger<OrderService> logger,
        AppSettings appSettings)
    {
        _orderRepository = orderRepository ?? throw new ArgumentNullException(nameof(orderRepository));
        _logger = logger ?? throw new ArgumentNullException(nameof(logger));
        _appSettings = appSettings ?? throw new ArgumentNullException(nameof(appSettings));

        // Configurar política de retry com Polly
        _retryPolicy = Policy
            .Handle<Exception>()
            .WaitAndRetryAsync(
                retryCount: _appSettings.MaxRetryAttempts,
                sleepDurationProvider: retryAttempt =>
                    TimeSpan.FromSeconds(_appSettings.RetryDelaySeconds * Math.Pow(2, retryAttempt - 1)),
                onRetry: (exception, timeSpan, retryCount, context) =>
                {
                    _logger.LogWarning(
                        exception,
                        "Retry {RetryCount}/{MaxRetries} after {Delay:0.00}s - {Message}",
                        retryCount,
                        _appSettings.MaxRetryAttempts,
                        timeSpan.TotalSeconds,
                        exception.Message);
                });
    }

    public async Task<OrderEntity?> GetOrderByIdAsync(int id, CancellationToken cancellationToken = default)
    {
        _logger.LogInformation("Getting order with ID: {OrderId}", id);

        try
        {
            return await _orderRepository.GetByIdAsync(id, cancellationToken);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting order with ID: {OrderId}", id);
            throw;
        }
    }

    public async Task<IEnumerable<OrderEntity>> GetPendingOrdersAsync(
        int batchSize,
        CancellationToken cancellationToken = default)
    {
        _logger.LogInformation("Getting pending orders with batch size: {BatchSize}", batchSize);

        try
        {
            return await _orderRepository.GetPendingOrdersAsync(batchSize, cancellationToken);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error getting pending orders");
            throw;
        }
    }

    public async Task ProcessOrdersAsync(
        int batchSize,
        bool dryRun,
        CancellationToken cancellationToken = default)
    {
        _logger.LogInformation(
            "Starting order processing - BatchSize: {BatchSize}, DryRun: {DryRun}",
            batchSize,
            dryRun);

        var stopwatch = Stopwatch.StartNew();
        var processedCount = 0;
        var failedCount = 0;
        var skippedCount = 0;

        try
        {
            var pendingOrders = await GetPendingOrdersAsync(batchSize, cancellationToken);
            var ordersList = pendingOrders.ToList();

            if (!ordersList.Any())
            {
                _logger.LogInformation("No pending orders to process");
                return;
            }

            _logger.LogInformation("Found {OrderCount} pending orders to process", ordersList.Count);

            // Processar em paralelo com limite de concorrência
            var parallelOptions = new ParallelOptions
            {
                MaxDegreeOfParallelism = Environment.ProcessorCount,
                CancellationToken = cancellationToken
            };

            await Parallel.ForEachAsync(ordersList, parallelOptions, async (order, ct) =>
            {
                try
                {
                    await ProcessSingleOrderAsync(order, dryRun, ct);
                    Interlocked.Increment(ref processedCount);

                    if (_appSettings.EnableDetailedLogging)
                    {
                        _logger.LogDebug(
                            "Order {OrderNumber} processed successfully ({Processed}/{Total})",
                            order.OrderNumber,
                            processedCount,
                            ordersList.Count);
                    }
                }
                catch (OperationCanceledException)
                {
                    Interlocked.Increment(ref skippedCount);
                    _logger.LogWarning("Order {OrderNumber} processing cancelled", order.OrderNumber);
                }
                catch (Exception ex)
                {
                    Interlocked.Increment(ref failedCount);
                    _logger.LogError(
                        ex,
                        "Failed to process order {OrderNumber}",
                        order.OrderNumber);
                }
            });

            stopwatch.Stop();

            _logger.LogInformation(
                "Batch processing completed - Processed: {Processed}, Failed: {Failed}, Skipped: {Skipped}, Duration: {Duration:mm\\:ss\\.fff}",
                processedCount,
                failedCount,
                skippedCount,
                stopwatch.Elapsed);

            // Estatísticas
            var remainingPending = await _orderRepository.CountByStatusAsync(OrderStatus.Pending, cancellationToken);
            _logger.LogInformation("Remaining pending orders: {Count}", remainingPending);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Critical error during batch processing");
            throw;
        }
    }

    private async Task ProcessSingleOrderAsync(
        OrderEntity order,
        bool dryRun,
        CancellationToken cancellationToken)
    {
        await _retryPolicy.ExecuteAsync(async () =>
        {
            _logger.LogDebug(
                "Processing order {OrderNumber} - Amount: {Amount:C}, Customer: {CustomerName}",
                order.OrderNumber,
                order.TotalAmount,
                order.User?.FullName ?? "Unknown");

            if (dryRun)
            {
                _logger.LogInformation(
                    "[DRY RUN] Would process order {OrderNumber}",
                    order.OrderNumber);
                return;
            }

            // Simular processamento (substituir com lógica real)
            await Task.Delay(100, cancellationToken);

            // Validação de negócio
            if (order.TotalAmount <= 0)
            {
                throw new InvalidOperationException($"Order {order.OrderNumber} has invalid amount: {order.TotalAmount}");
            }

            // Atualizar status
            await _orderRepository.UpdateOrderStatusAsync(
                order.Id,
                OrderStatus.Completed,
                "Processed successfully by batch job",
                cancellationToken);

            _logger.LogDebug("Order {OrderNumber} marked as completed", order.OrderNumber);
        });
    }

    public async Task<int> CreateOrderAsync(OrderEntity order, CancellationToken cancellationToken = default)
    {
        _logger.LogInformation("Creating new order for user {UserId}", order.UserId);

        try
        {
            order.OrderNumber = GenerateOrderNumber();
            order.OrderDate = DateTime.UtcNow;
            order.Status = OrderStatus.Pending;
            order.CreatedAt = DateTime.UtcNow;

            await _orderRepository.AddAsync(order, cancellationToken);

            _logger.LogInformation(
                "Order created successfully - OrderNumber: {OrderNumber}, OrderId: {OrderId}, Amount: {Amount:C}",
                order.OrderNumber,
                order.Id,
                order.TotalAmount);

            return order.Id;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error creating order for user {UserId}", order.UserId);
            throw;
        }
    }

    public async Task UpdateOrderStatusAsync(
        int orderId,
        OrderStatus status,
        string? notes = null,
        CancellationToken cancellationToken = default)
    {
        _logger.LogInformation(
            "Updating order {OrderId} status to {Status}",
            orderId,
            status);

        try
        {
            await _orderRepository.UpdateOrderStatusAsync(orderId, status, notes, cancellationToken);

            _logger.LogInformation("Order status updated successfully: {OrderId}", orderId);
        }
        catch (Exception ex)
        {
            _logger.LogError(
                ex,
                "Error updating order {OrderId} status to {Status}",
                orderId,
                status);
            throw;
        }
    }

    private string GenerateOrderNumber()
    {
        return $"ORD-{DateTime.UtcNow:yyyyMMddHHmmss}-{Guid.NewGuid():N}"[..30];
    }
}
