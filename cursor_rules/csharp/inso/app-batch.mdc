### ❌ DON'T: Não use variáveis estáticas para estado compartilhado

```csharp
// ❌ INCORRETO - Estado estático compartilhado
public class OrderProcessor
{
    private static int _processedCount = 0;  // Não thread-safe!
    private static List<OrderEntity> _cache = new();  // Memory leak!
    
    public async Task ProcessAsync(OrderEntity order)
    {
        _processedCount++;  // Race condition!
        _cache.Add(order);  // Nunca limpa!
    }
}

// ✅ CORRETO - Estado local ou thread-safe
public class OrderProcessor
{
    private int _processedCount = 0;  // Instância
    
    public async Task ProcessBatchAsync(List<OrderEntity> orders)
    {
        var processedCount = 0;  // Local
        
        await Parallel.ForEachAsync(orders, async (order, ct) =>
        {
            await ProcessAsync(order);
            Interlocked.Increment(ref processedCount);  // Thread-safe!
        });
    }
}
```

