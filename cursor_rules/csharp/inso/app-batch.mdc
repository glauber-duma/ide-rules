### 6.3 Utils/RetryHelper.cs

```csharp
// src/Utils/RetryHelper.cs
using Microsoft.Extensions.Logging;
using Polly;
using Polly.Retry;

namespace YourProjectName.Utils;

/// <summary>
/// Helper para criar políticas de retry com Polly
/// </summary>
public static class RetryHelper
{
    /// <summary>
    /// Cria uma política de retry com exponential backoff
    /// </summary>
    public static AsyncRetryPolicy CreateRetryPolicy(
        ILogger logger,
        int maxRetries = 3,
        int baseDelaySeconds = 1)
    {
        return Policy
            .Handle<Exception>()
            .WaitAndRetryAsync(
                retryCount: maxRetries,
                sleepDurationProvider: retryAttempt =>
                    TimeSpan.FromSeconds(baseDelaySeconds * Math.Pow(2, retryAttempt - 1)),
                onRetry: (exception, timeSpan, retryCount, context) =>
                {
                    logger.LogWarning(
                        exception,
                        "Retry {RetryCount}/{MaxRetries} after {Delay:0.00}s - {Message}",
                        retryCount,
                        maxRetries,
                        timeSpan.TotalSeconds,
                        exception.Message);
                });
    }

    /// <summary>
    /// Cria uma política de retry para exceções específicas
    /// </summary>
    public static AsyncRetryPolicy CreateRetryPolicy<TException>(
        ILogger logger,
        int maxRetries = 3,
        int baseDelaySeconds = 1)
        where TException : Exception
    {
        return Policy
            .Handle<TException>()
            .WaitAndRetryAsync(
                retryCount: maxRetries,
                sleepDurationProvider: retryAttempt =>
                    TimeSpan.FromSeconds(baseDelaySeconds * Math.Pow(2, retryAttempt - 1)),
                onRetry: (exception, timeSpan, retryCount, context) =>
                {
                    logger.LogWarning(
                        exception,
                        "Retry {RetryCount}/{MaxRetries} after {Delay:0.00}s - {ExceptionType}: {Message}",
                        retryCount,
                        maxRetries,
                        timeSpan.TotalSeconds,
                        typeof(TException).Name,
                        exception.Message);
                });
    }

    /// <summary>
    /// Executa uma ação com retry
    /// </summary>
    public static async Task<T> ExecuteWithRetryAsync<T>(
        Func<Task<T>> action,
        ILogger logger,
        int maxRetries = 3,
        int baseDelaySeconds = 1)
    {
        var policy = CreateRetryPolicy(logger, maxRetries, baseDelaySeconds);
        return await policy.ExecuteAsync(action);
    }

    /// <summary>
    /// Executa uma ação com retry (sem retorno)
    /// </summary>
    public static async Task ExecuteWithRetryAsync(
        Func<Task> action,
        ILogger logger,
        int maxRetries = 3,
        int baseDelaySeconds = 1)
    {
        var policy = CreateRetryPolicy(logger, maxRetries, baseDelaySeconds);
        await policy.ExecuteAsync(action);
    }
}
