### Pipeline de execucao com tracing manual e retry simples
```csharp
public class ImportOrchestrator
{
  private readonly IMediator _mediator;
  private readonly ActivitySource _source = new("BatchJobs");

  public ImportOrchestrator(IMediator mediator) => _mediator = mediator;

  public async Task RunAsync(string file, CancellationToken ct)
  {
    using var activity = _source.StartActivity("import-customers");
    var retryPolicy = Policy.Handle<IOException>().WaitAndRetryAsync(3, i => TimeSpan.FromSeconds(i));
    await retryPolicy.ExecuteAsync(async () => await _mediator.Send(new ImportCustomersCommand(file), ct));
  }
}
```

