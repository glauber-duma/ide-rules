    description="Retorna lista paginada de usuários com filtros opcionais.",
    responses={
        200: {
            "description": "Lista de usuários",
            "model": PaginatedResponse[UserListResponse],
        },
        401: {
            "description": "Não autenticado",
        },
    },
)
async def list_users(
    filters: UserFilterParams = Depends(),
    current_user: User = Depends(get_current_active_user),
    db: AsyncSession = Depends(get_db),
) -> PaginatedResponse[UserListResponse]:
    """
    Lista usuários com paginação e filtros.
    
    **Filtros disponíveis:**
    - search: Busca por email, username ou nome
    - role: Filtrar por role (admin, user, moderator)
    - status: Filtrar por status (active, inactive, suspended)
    - is_verified: Filtrar por verificação de email
    - created_after: Usuários criados após data
    - created_before: Usuários criados antes de data
    - sort_by: Campo para ordenação
    - sort_order: Direção (asc/desc)
    - page: Número da página
    - page_size: Itens por página (max 100)
    """
    user_service = UserService(db)
    
    # Buscar usuários com filtros
    users, total = await user_service.list_users(filters)
    
    # Calcular informações de paginação
    total_pages = (total + filters.page_size - 1) // filters.page_size
    
    from app.api.v1.schemas.common import PageInfo
    
    return PaginatedResponse[UserListResponse](
        items=[UserListResponse.model_validate(user) for user in users],
        pagination=PageInfo(
            page=filters.page,
            page_size=filters.page_size,
            total_items=total,
            total_pages=total_pages,
            has_next=filters.page < total_pages,
            has_previous=filters.page > 1,
        ),
    )


