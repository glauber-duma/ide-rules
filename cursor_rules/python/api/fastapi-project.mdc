# src/app/api/v1/schemas/user.py
"""
Schemas Pydantic para o domínio de usuários.
Define estruturas de request e response para operações de usuário.
"""

import re
from datetime import datetime
from typing import Optional
from uuid import UUID

from pydantic import EmailStr, Field, field_validator, model_validator

from app.api.v1.schemas.common import (
    BaseSchema,
    FilterParams,
    PaginationParams,
    TimestampSchema,
)


# ==================== ENUMS ====================

class UserRole(str):
    """Roles disponíveis para usuários."""
    ADMIN = "admin"
    USER = "user"
    MODERATOR = "moderator"


class UserStatus(str):
    """Status possíveis de um usuário."""
    ACTIVE = "active"
    INACTIVE = "inactive"
    SUSPENDED = "suspended"
    PENDING = "pending"


# ==================== REQUEST SCHEMAS ====================

class UserCreateRequest(BaseSchema):
    """
    Schema para criação de usuário.
    """
    email: EmailStr = Field(
        description="Email do usuário (único)",
        examples=["usuario@example.com"],
    )
    
    username: str = Field(
        min_length=3,
        max_length=50,
        pattern="^[a-zA-Z0-9_-]+$",
        description="Nome de usuário (único, alfanumérico com _ e -)",
        examples=["usuario_exemplo"],
    )
    
    password: str = Field(
        min_length=8,
        max_length=100,
        description="Senha do usuário (mínimo 8 caracteres)",
        examples=["SenhaSegura123!"],
    )
    
    full_name: str = Field(
        min_length=3,
        max_length=100,
        description="Nome completo do usuário",
        examples=["João da Silva"],
    )
    
    phone: Optional[str] = Field(
        default=None,
        pattern=r"^\+?[1-9]\d{1,14}$",
        description="Telefone no formato E.164",
        examples=["+5511999999999"],
    )
    
    @field_validator("password")
    @classmethod
    def validate_password_strength(cls, v: str) -> str:
        """
        Valida a força da senha.
        Deve conter: maiúscula, minúscula, número e caractere especial.
        """
        if not re.search(r"[A-Z]", v):
            raise ValueError("Senha deve conter pelo menos uma letra maiúscula")
        
        if not re.search(r"[a-z]", v):
            raise ValueError("Senha deve conter pelo menos uma letra minúscula")
        
        if not re.search(r"\d", v):
            raise ValueError("Senha deve conter pelo menos um número")
        
        if not re.search(r"[!@#$%^&*(),.?\":{}|<>]", v):
            raise ValueError("Senha deve conter pelo menos um caractere especial")
        
        return v
    
    @field_validator("username")
    @classmethod
    def validate_username(cls, v: str) -> str:
        """Normaliza username para lowercase."""
        return v.lower()
    
    @field_validator("email")
    @classmethod
    def validate_email(cls, v: str) -> str:
        """Normaliza email para lowercase."""
        return v.lower()


class UserUpdateRequest(BaseSchema):
    """
    Schema para atualização de usuário.
    Todos os campos são opcionais.
    """
    full_name: Optional[str] = Field(
        default=None,
        min_length=3,
        max_length=100,
        description="Nome completo do usuário",
        examples=["João da Silva"],
    )
    
    phone: Optional[str] = Field(
        default=None,
        pattern=r"^\+?[1-9]\d{1,14}$",
        description="Telefone no formato E.164",
        examples=["+5511999999999"],
    )
    
    bio: Optional[str] = Field(
        default=None,
        max_length=500,
        description="Biografia do usuário",
        examples=["Desenvolvedor Python apaixonado por tecnologia"],
    )
    
    avatar_url: Optional[str] = Field(
        default=None,
        max_length=500,
        description="URL do avatar do usuário",
        examples=["https://example.com/avatar.jpg"],
    )
    
    @model_validator(mode="after")
    def check_at_least_one_field(self) -> "UserUpdateRequest":
        """Valida que pelo menos um campo foi fornecido."""
        if not any([
            self.full_name,
            self.phone,
            self.bio,
            self.avatar_url,
        ]):
            raise ValueError("Pelo menos um campo deve ser fornecido para atualização")
        
        return self


class UserChangePasswordRequest(BaseSchema):
    """
    Schema para alteração de senha.
    """
    current_password: str = Field(
        description="Senha atual do usuário",
        examples=["SenhaAtual123!"],
    )
    
    new_password: str = Field(
        min_length=8,
        max_length=100,
        description="Nova senha do usuário",
        examples=["NovaSenha456!"],
    )
    
    confirm_password: str = Field(
        description="Confirmação da nova senha",
        examples=["NovaSenha456!"],
    )
    
    @model_validator(mode="after")
    def validate_passwords_match(self) -> "UserChangePasswordRequest":
        """Valida que a nova senha e confirmação são iguais."""
        if self.new_password != self.confirm_password:
            raise ValueError("Nova senha e confirmação não correspondem")
        
        if self.current_password == self.new_password:
            raise ValueError("Nova senha deve ser diferente da senha atual")
        
        return self
    
    @field_validator("new_password")
    @classmethod
    def validate_password_strength(cls, v: str) -> str:
        """Valida a força da nova senha."""
        if not re.search(r"[A-Z]", v):
            raise ValueError("Senha deve conter pelo menos uma letra maiúscula")
        
        if not re.search(r"[a-z]", v):
            raise ValueError("Senha deve conter pelo menos uma letra minúscula")
        
        if not re.search(r"\d", v):
            raise ValueError("Senha deve conter pelo menos um número")
        
        if not re.search(r"[!@#$%^&*(),.?\":{}|<>]", v):
            raise ValueError("Senha deve conter pelo menos um caractere especial")
        
        return v


