### 2.2. Configurações com Pydantic Settings

```python
# src/app/core/configs/config.py
"""
Configurações da aplicação usando Pydantic Settings.
Carrega variáveis de ambiente e fornece validação de tipos.
"""

from functools import lru_cache
from typing import Any, List, Literal, Optional

from pydantic import (
    AnyHttpUrl,
    EmailStr,
    Field,
    PostgresDsn,
    RedisDsn,
    field_validator,
    model_validator,
)
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """
    Configurações principais da aplicação.
    
    Todas as configurações podem ser sobrescritas via variáveis de ambiente.
    """
    
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=True,
        extra="ignore",
    )
    
    # ==================== APLICAÇÃO ====================
    PROJECT_NAME: str = Field(
        default="FastAPI Project",
        description="Nome do projeto",
    )
    
    PROJECT_DESCRIPTION: str = Field(
        default="API REST moderna com FastAPI",
        description="Descrição do projeto",
    )
    
    VERSION: str = Field(
        default="1.0.0",
        description="Versão da aplicação",
    )
    
    ENVIRONMENT: Literal["development", "staging", "production"] = Field(
        default="development",
        description="Ambiente de execução",
    )
    
    DEBUG: bool = Field(
        default=False,
        description="Modo debug",
    )
    
    HOST: str = Field(
        default="0.0.0.0",
        description="Host para bind do servidor",
    )
    
    PORT: int = Field(
        default=8000,
        ge=1,
        le=65535,
        description="Porta do servidor",
    )
    
    # ==================== API ====================
    API_V1_PREFIX: str = Field(
        default="/api/v1",
        description="Prefixo para rotas da API v1",
    )
    
    API_V2_PREFIX: str = Field(
        default="/api/v2",
        description="Prefixo para rotas da API v2",
    )
    
    # ==================== CORS ====================
    CORS_ORIGINS: List[str] = Field(
        default=["http://localhost:3000", "http://localhost:8000"],
        description="Origens permitidas para CORS",
    )
    
    CORS_METHODS: List[str] = Field(
        default=["*"],
        description="Métodos HTTP permitidos",
    )
    
    CORS_HEADERS: List[str] = Field(
        default=["*"],
        description="Headers permitidos",
    )
    
    ALLOWED_HOSTS: List[str] = Field(
        default=["localhost", "127.0.0.1"],
        description="Hosts confiáveis",
    )
    
    # ==================== SEGURANÇA ====================
    SECRET_KEY: str = Field(
        ...,
        min_length=32,
        description="Chave secreta para JWT e criptografia",
    )
    
    ALGORITHM: str = Field(
        default="HS256",
        description="Algoritmo de criptografia JWT",
    )
    
    ACCESS_TOKEN_EXPIRE_MINUTES: int = Field(
        default=30,
        ge=1,
        description="Tempo de expiração do token de acesso (minutos)",
    )
    
    REFRESH_TOKEN_EXPIRE_DAYS: int = Field(
        default=7,
        ge=1,
        description="Tempo de expiração do token de refresh (dias)",
    )
    
    PASSWORD_MIN_LENGTH: int = Field(
        default=8,
        ge=6,
        description="Tamanho mínimo da senha",
    )
    
    # ==================== BANCO DE DADOS ====================
    DATABASE_URL: PostgresDsn = Field(
        ...,
        description="URL de conexão com PostgreSQL",
    )
    
    DATABASE_POOL_SIZE: int = Field(
        default=10,
        ge=1,
        le=100,
        description="Tamanho do pool de conexões",
    )
    
    DATABASE_MAX_OVERFLOW: int = Field(
        default=20,
        ge=0,
        description="Conexões adicionais além do pool",
    )
    
    DATABASE_POOL_TIMEOUT: int = Field(
        default=30,
        ge=1,
        description="Timeout para obter conexão do pool (segundos)",
    )
    
    DATABASE_ECHO: bool = Field(
        default=False,
        description="Log de queries SQL",
    )
    
    # ==================== REDIS ====================
    REDIS_URL: Optional[RedisDsn] = Field(
        default=None,
        description="URL de conexão com Redis",
    )
    
    REDIS_TTL: int = Field(
        default=300,
        ge=1,
        description="TTL padrão do cache (segundos)",
    )
    
    REDIS_MAX_CONNECTIONS: int = Field(
        default=10,
        ge=1,
        description="Máximo de conexões no pool Redis",
    )
    
    # ==================== LOGGING ====================
    LOG_LEVEL: Literal["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] = Field(
        default="INFO",
        description="Nível de log",
    )
    
    LOG_FORMAT: str = Field(
        default="json",
        description="Formato do log (json ou text)",
    )
    
    LOG_FILE: Optional[str] = Field(
        default=None,
        description="Caminho do arquivo de log",
    )
    
    # ==================== RATE LIMITING ====================
    RATE_LIMIT_ENABLED: bool = Field(
        default=True,
        description="Ativar rate limiting",
    )
    
    RATE_LIMIT_PER_MINUTE: int = Field(
        default=60,
        ge=1,
        description="Requisições permitidas por minuto",
    )
    
    # ==================== EMAIL ====================
    SMTP_HOST: Optional[str] = Field(
        default=None,
        description="Host do servidor SMTP",
    )
    
    SMTP_PORT: int = Field(
        default=587,
        ge=1,
        le=65535,
        description="Porta do servidor SMTP",
    )
    
    SMTP_USER: Optional[str] = Field(
        default=None,
        description="Usuário SMTP",
    )
    
    SMTP_PASSWORD: Optional[str] = Field(
        default=None,
        description="Senha SMTP",
    )
    
    SMTP_FROM_EMAIL: Optional[EmailStr] = Field(
        default=None,
        description="Email remetente padrão",
    )
    
    SMTP_FROM_NAME: Optional[str] = Field(
        default=None,
        description="Nome do remetente",
    )
    
    # ==================== MONITORAMENTO ====================
    SENTRY_DSN: Optional[str] = Field(
        default=None,
        description="DSN do Sentry para monitoramento de erros",
    )
    
    ENABLE_METRICS: bool = Field(
        default=True,
        description="Habilitar coleta de métricas",
    )
    
    # ==================== VALIDADORES ====================
    
    @field_validator("CORS_ORIGINS", mode="before")
    @classmethod
    def parse_cors_origins(cls, v: Any) -> List[str]:
        """Converte string separada por vírgula em lista."""
        if isinstance(v, str):
            return [origin.strip() for origin in v.split(",")]
        return v
    
    @field_validator("ALLOWED_HOSTS", mode="before")
    @classmethod
    def parse_allowed_hosts(cls, v: Any) -> List[str]:
        """Converte string separada por vírgula em lista."""
        if isinstance(v, str):
            return [host.strip() for host in v.split(",")]
        return v
    
    @model_validator(mode="after")
    def validate_settings(self) -> "Settings":
        """Validações customizadas após inicialização."""
        # Em produção, certas configurações são obrigatórias
        if self.ENVIRONMENT == "production":
            if self.DEBUG:
                raise ValueError("DEBUG não pode estar ativo em produção")
            
            if not self.SENTRY_DSN:
                import warnings
                warnings.warn(
                    "SENTRY_DSN não configurado em produção. "
                    "Monitoramento de erros desabilitado."
                )
        
        return self
    
    # ==================== PROPRIEDADES COMPUTADAS ====================
    
    @property
    def is_production(self) -> bool:
        """Verifica se está em ambiente de produção."""
        return self.ENVIRONMENT == "production"
    
    @property
    def is_development(self) -> bool:
        """Verifica se está em ambiente de desenvolvimento."""
        return self.ENVIRONMENT == "development"
    
    @property
    def database_url_sync(self) -> str:
        """Retorna URL do banco de dados para uso síncrono."""
        return str(self.DATABASE_URL).replace("postgresql+asyncpg://", "postgresql://")


@lru_cache()
def get_settings() -> Settings:
    """
    Retorna instância singleton das configurações.
    O decorator @lru_cache garante que só será criada uma vez.
    
    Returns:
        Settings: Instância das configurações
    """
    return Settings()


# Instância global das configurações
settings = get_settings()
