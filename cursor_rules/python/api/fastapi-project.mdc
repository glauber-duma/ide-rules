# src/app/api/v1/schemas/common.py
"""
Schemas base e padrões comuns reutilizáveis em toda a aplicação.
Define estruturas de resposta padronizadas e classes base.
"""

from datetime import datetime
from typing import Any, Dict, Generic, List, Optional, TypeVar
from uuid import UUID

from pydantic import BaseModel, ConfigDict, Field, field_validator


# ==================== CONFIGURAÇÃO BASE ====================

class BaseSchema(BaseModel):
    """
    Schema base para todos os schemas da aplicação.
    Define configurações comuns e validações.
    """
    
    model_config = ConfigDict(
        # Permite usar modelos ORM diretamente
        from_attributes=True,
        # Valida atribuições após inicialização
        validate_assignment=True,
        # Usa enum values em vez de enum objects
        use_enum_values=True,
        # Serialização de campos extras
        extra="forbid",
        # Permite campos populados pelo ORM
        populate_by_name=True,
        # Serialização customizada para datas
        json_encoders={
            datetime: lambda v: v.isoformat(),
            UUID: lambda v: str(v),
        },
    )


# ==================== SCHEMAS DE TIMESTAMP ====================

class TimestampSchema(BaseSchema):
    """
    Schema base que inclui campos de auditoria temporal.
    """
    created_at: datetime = Field(
        description="Data e hora de criação do registro",
        examples=["2026-01-23T10:30:00Z"],
    )
    
    updated_at: datetime = Field(
        description="Data e hora da última atualização",
        examples=["2026-01-23T15:45:00Z"],
    )


class SoftDeleteSchema(TimestampSchema):
    """
    Schema base para entidades com soft delete.
    """
    deleted_at: Optional[datetime] = Field(
        default=None,
        description="Data e hora da exclusão lógica",
        examples=["2026-01-23T20:00:00Z"],
    )
    
    is_active: bool = Field(
        default=True,
        description="Indica se o registro está ativo",
        examples=[True],
    )


# ==================== SCHEMAS DE PAGINAÇÃO ====================

class PaginationParams(BaseSchema):
    """
    Parâmetros de paginação para listagem de recursos.
    """
    page: int = Field(
        default=1,
        ge=1,
        description="Número da página (começa em 1)",
        examples=[1],
    )
    
    page_size: int = Field(
        default=20,
        ge=1,
        le=100,
        description="Quantidade de itens por página",
        examples=[20],
    )
    
    @property
    def offset(self) -> int:
        """Calcula o offset para a query."""
        return (self.page - 1) * self.page_size
    
    @property
    def limit(self) -> int:
        """Retorna o limite de itens."""
        return self.page_size


class PageInfo(BaseSchema):
    """
    Informações de paginação na resposta.
    """
    page: int = Field(
        description="Página atual",
        examples=[1],
    )
    
    page_size: int = Field(
        description="Tamanho da página",
        examples=[20],
    )
    
    total_items: int = Field(
        description="Total de itens disponíveis",
        examples=[150],
    )
    
    total_pages: int = Field(
        description="Total de páginas",
        examples=[8],
    )
    
    has_next: bool = Field(
        description="Indica se existe próxima página",
        examples=[True],
    )
    
    has_previous: bool = Field(
        description="Indica se existe página anterior",
        examples=[False],
    )


T = TypeVar("T")


class PaginatedResponse(BaseSchema, Generic[T]):
    """
    Resposta paginada genérica.
    
    Usage:
        PaginatedResponse[UserResponse](
            items=[...],
            pagination=PageInfo(...)
        )
    """
    items: List[T] = Field(
        description="Lista de itens da página atual",
    )
    
    pagination: PageInfo = Field(
        description="Informações de paginação",
    )


