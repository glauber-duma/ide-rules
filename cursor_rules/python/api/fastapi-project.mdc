### 4.2. Dependencies Pattern

```python
# src/app/api/v1/dependencies.py
"""
Dependências reutilizáveis para endpoints da API.
Implementa padrões de injeção de dependência, autenticação e autorização.
"""

from typing import AsyncGenerator, Optional

from fastapi import Depends, HTTPException, status
from fastapi.security import HTTPAuthorizationCredentials, HTTPBearer
from jose import JWTError, jwt
from sqlalchemy.ext.asyncio import AsyncSession

from app.core.configs.config import settings
from app.core.configs.database import database_manager
from app.data.models.user import User
from app.data.repositories.user_repository import UserRepository


# ==================== SEGURANÇA ====================

security = HTTPBearer(
    scheme_name="Bearer Token",
    description="JWT Bearer token obtido no endpoint de login",
    auto_error=True,
)


# ==================== DATABASE ====================

async def get_db() -> AsyncGenerator[AsyncSession, None]:
    """
    Dependência para obter sessão do banco de dados.
    
    Yields:
        AsyncSession: Sessão do SQLAlchemy
        
    Usage:
        @app.get("/users")
        async def get_users(db: AsyncSession = Depends(get_db)):
            # usar db aqui
    """
    async with database_manager.get_session() as session:
        try:
            yield session
            await session.commit()
        except Exception:
            await session.rollback()
            raise
        finally:
            await session.close()


# ==================== AUTENTICAÇÃO ====================

async def get_current_user(
    credentials: HTTPAuthorizationCredentials = Depends(security),
    db: AsyncSession = Depends(get_db),
) -> User:
    """
    Dependência para obter o usuário autenticado pelo token JWT.
    
    Args:
        credentials: Credenciais do header Authorization
        db: Sessão do banco de dados
        
    Returns:
        User: Usuário autenticado
        
    Raises:
        HTTPException: Se token inválido ou usuário não encontrado
        
    Usage:
        @app.get("/profile")
        async def get_profile(user: User = Depends(get_current_user)):
            return user
    """
    credentials_exception = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Não foi possível validar as credenciais",
        headers={"WWW-Authenticate": "Bearer"},
    )
    
    try:
        # Decodificar token JWT
        token = credentials.credentials
        payload = jwt.decode(
            token,
            settings.SECRET_KEY,
            algorithms=[settings.ALGORITHM],
        )
        
        # Extrair user_id do payload
        user_id: str = payload.get("sub")
        if user_id is None:
            raise credentials_exception
            
    except JWTError:
        raise credentials_exception
    
    # Buscar usuário no banco
    user_repository = UserRepository(db)
    user = await user_repository.get_by_id(user_id)
    
    if user is None:
        raise credentials_exception
    
    return user


async def get_current_active_user(
    current_user: User = Depends(get_current_user),
) -> User:
    """
    Dependência para garantir que o usuário está ativo.
    
    Args:
        current_user: Usuário autenticado
        
    Returns:
        User: Usuário ativo
        
    Raises:
        HTTPException: Se usuário inativo
        
    Usage:
        @app.get("/protected")
        async def protected_route(user: User = Depends(get_current_active_user)):
            return {"message": "Protected resource"}
    """
    if not current_user.is_active:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Usuário inativo",
        )
    
    return current_user


async def get_current_verified_user(
    current_user: User = Depends(get_current_active_user),
) -> User:
    """
    Dependência para garantir que o usuário tem email verificado.
    
    Args:
        current_user: Usuário ativo
        
    Returns:
        User: Usuário verificado
        
    Raises:
        HTTPException: Se email não verificado
        
    Usage:
        @app.post("/sensitive-action")
        async def sensitive_action(user: User = Depends(get_current_verified_user)):
            # Apenas usuários verificados podem executar esta ação
    """
    if not current_user.is_verified:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Email não verificado. Verifique seu email para continuar.",
        )
    
    return current_user


# ==================== AUTORIZAÇÃO ====================

async def get_current_admin_user(
    current_user: User = Depends(get_current_active_user),
) -> User:
    """
    Dependência para garantir que o usuário é administrador.
    
    Args:
        current_user: Usuário ativo
        
    Returns:
        User: Usuário administrador
        
    Raises:
        HTTPException: Se usuário não é admin
        
    Usage:
        @app.delete("/users/{user_id}")
        async def delete_user(
            user_id: UUID,
            admin: User = Depends(get_current_admin_user)
        ):
            # Apenas admins podem executar
    """
    from app.api.v1.schemas.user import UserRole
    
    if current_user.role != UserRole.ADMIN:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Acesso negado. Permissão de administrador necessária.",
        )
    
    return current_user


async def get_current_moderator_or_admin(
    current_user: User = Depends(get_current_active_user),
) -> User:
    """
    Dependência para garantir que o usuário é moderador ou administrador.
    
    Args:
        current_user: Usuário ativo
        
    Returns:
        User: Usuário moderador ou admin
        
    Raises:
        HTTPException: Se usuário não tem permissão
    """
    from app.api.v1.schemas.user import UserRole
    
    allowed_roles = [UserRole.ADMIN, UserRole.MODERATOR]
    
    if current_user.role not in allowed_roles:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Acesso negado. Permissão de moderador ou administrador necessária.",
        )
    
    return current_user


# ==================== VALIDAÇÃO DE RECURSOS ====================

class ResourceOwnerOrAdmin:
    """
    Dependência para validar se o usuário é dono do recurso ou admin.
    
    Usage:
        verify_owner = ResourceOwnerOrAdmin("user_id")
        
        @app.patch("/posts/{post_id}")
        async def update_post(
            post_id: UUID,
            db: AsyncSession = Depends(get_db),
            current_user: User = Depends(verify_owner)
        ):
            # Apenas o dono do post ou admin pode atualizar
    """
    
    def __init__(self, resource_id_field: str):
        """
        Args:
            resource_id_field: Nome do campo que contém o ID do dono do recurso
        """
        self.resource_id_field = resource_id_field
    
    async def __call__(
        self,
        resource_id: str,
        current_user: User = Depends(get_current_active_user),
        db: AsyncSession = Depends(get_db),
    ) -> User:
        """
        Valida se o usuário tem permissão no recurso.
        
        Args:
            resource_id: ID do recurso
            current_user: Usuário atual
            db: Sessão do banco
            
        Returns:
            User: Usuário autorizado
            
        Raises:
            HTTPException: Se não autorizado
        """
        from app.api.v1.schemas.user import UserRole
        
        # Admin sempre tem acesso
        if current_user.role == UserRole.ADMIN:
            return current_user
        
        # Verificar se é o dono do recurso
        # Esta lógica deve ser adaptada para cada tipo de recurso
        if str(getattr(current_user, self.resource_id_field, None)) != resource_id:
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail="Você não tem permissão para acessar este recurso.",
            )
        
        return current_user


# ==================== RATE LIMITING ====================

class RateLimiter:
    """
    Dependência para rate limiting.
    
    Usage:
        rate_limiter = RateLimiter(max_requests=10, window_seconds=60)
        
        @app.post("/login", dependencies=[Depends(rate_limiter)])
        async def login():
            # Limitado a 10 requisições por minuto
    """
    
    def __init__(self, max_requests: int, window_seconds: int):
        """
        Args:
            max_requests: Número máximo de requisições
            window_seconds: Janela de tempo em segundos
        """
        self.max_requests = max_requests
        self.window_seconds = window_seconds
        self.requests: dict = {}
    
    async def __call__(self, request) -> None:
        """
        Valida o rate limit.
        
        Args:
            request: Request do FastAPI
            
        Raises:
            HTTPException: Se exceder o limite
        """
        from datetime import datetime, timedelta
        
        # Obter IP do cliente
        client_ip = request.client.host
        
        # Limpar requisições antigas
        now = datetime.utcnow()
        if client_ip in self.requests:
            self.requests[client_ip] = [
                req_time
                for req_time in self.requests[client_ip]
                if now - req_time < timedelta(seconds=self.window_seconds)
            ]
        else:
            self.requests[client_ip] = []
        
        # Verificar limite
        if len(self.requests[client_ip]) >= self.max_requests:
            raise HTTPException(
                status_code=status.HTTP_429_TOO_MANY_REQUESTS,
                detail=f"Muitas requisições. Tente novamente em {self.window_seconds} segundos.",
            )
        
        # Registrar requisição
        self.requests[client_ip].append(now)


# ==================== CACHE ====================

class CacheControl:
    """
    Dependência para controle de cache HTTP.
    
    Usage:
        cache = CacheControl(max_age=3600)
        
        @app.get("/public-data", dependencies=[Depends(cache)])
        async def get_public_data():
            # Resposta será cacheada por 1 hora
    """
    
    def __init__(self, max_age: int, public: bool = True):
        """
        Args:
            max_age: Tempo de cache em segundos
            public: Se True, permite cache público
        """
        self.max_age = max_age
        self.public = public
    
    async def __call__(self, response) -> None:
        """
        Adiciona headers de cache.
        
        Args:
            response: Response do FastAPI
        """
        cache_control = f"{'public' if self.public else 'private'}, max-age={self.max_age}"
        response.headers["Cache-Control"] = cache_control


# ==================== PAGINAÇÃO ====================

class PaginationParams:
    """
    Dependência para parâmetros de paginação.
    
    Usage:
        @app.get("/items")
        async def list_items(pagination: PaginationParams = Depends()):
            # pagination.page, pagination.page_size
    """
    
    def __init__(
        self,
        page: int = 1,
        page_size: int = 20,
    ):
        """
        Args:
            page: Número da página (mínimo 1)
            page_size: Tamanho da página (1-100)
        """
        self.page = max(1, page)
        self.page_size = min(100, max(1, page_size))
    
    @property
    def offset(self) -> int:
        """Calcula o offset para a query."""
        return (self.page - 1) * self.page_size
    
    @property
    def limit(self) -> int:
        """Retorna o limite de itens."""
        return self.page_size
