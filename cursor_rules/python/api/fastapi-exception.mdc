# FastAPI - Tratamento de Exceções

## 1. Objetivo

Esta rule estabelece padrões e melhores práticas para tratamento de exceções em aplicações FastAPI, visando:

- **Consistência**: Padronizar respostas de erro em toda a aplicação com estrutura uniforme
- **Rastreabilidade**: Implementar sistema de correlação e contexto para debugging eficiente
- **Clareza**: Fornecer mensagens de erro claras e acionáveis para clientes da API
- **Segurança**: Evitar exposição de informações sensíveis em mensagens de erro
- **Observabilidade**: Integrar logging estruturado com níveis apropriados de detalhe
- **Manutenibilidade**: Organizar exceções de forma hierárquica e semântica
- **Debugging**: Facilitar identificação e resolução de problemas em produção

## 2. Hierarquia de Exceções

### 🗂️ Estrutura de Arquivos

```
src/
├── api/
│   ├── core/
│   │   ├── exceptions/
│   │   │   ├── __init__.py              # Exporta todas as exceções
│   │   │   ├── base.py                  # Exceções base
│   │   │   ├── business.py              # Exceções de regras de negócio
│   │   │   ├── auth.py                  # Exceções de autenticação/autorização
│   │   │   ├── validation.py            # Exceções de validação
│   │   │   └── external.py              # Exceções de serviços externos
│   │   │
│   │   ├── handlers/
│   │   │   ├── __init__.py              # Exporta handlers
│   │   │   ├── exception_handlers.py   # Handlers globais
│   │   │   ├── http_handlers.py         # Handlers HTTP específicos
│   │   │   └── async_handlers.py        # Handlers assíncronos
│   │   │
│   │   ├── responses/
│   │   │   ├── __init__.py              # Exporta response builders
│   │   │   ├── error_responses.py       # Builders de erro
│   │   │   └── success_responses.py     # Builders de sucesso
│   │   │
│   │   ├── middleware/
│   │   │   ├── __init__.py
│   │   │   ├── error_middleware.py      # Middleware de erro
│   │   │   └── correlation_middleware.py # Middleware de correlação
│   │   │
│   │   └── context.py                   # Contexto de requisição
│   │
│   └── main.py                          # Registro de handlers
```

### 🏗️ Exceções Base

```python
# src/api/core/exceptions/base.py
"""Exceções base da aplicação."""

from typing import Any, Dict, Optional
from datetime import datetime
from fastapi import status


class AppException(Exception):
    """
    Exceção base para todas as exceções da aplicação.
    
    Todas as exceções customizadas devem herdar desta classe.
    """
    
    def __init__(
        self,
        message: str,
        error_code: str,
        status_code: int = status.HTTP_500_INTERNAL_SERVER_ERROR,
        details: Optional[Dict[str, Any]] = None,
        headers: Optional[Dict[str, str]] = None,
    ):
        """
        Args:
            message: Mensagem de erro amigável para o cliente
            error_code: Código único de erro para identificação
            status_code: Status HTTP apropriado
            details: Informações adicionais sobre o erro
            headers: Headers HTTP customizados (opcional)
        """
        self.message = message
        self.error_code = error_code
        self.status_code = status_code
        self.details = details or {}
        self.headers = headers or {}
        self.timestamp = datetime.utcnow()
        
        super().__init__(self.message)
    
    def to_dict(self) -> Dict[str, Any]:
        """Converte exceção para dicionário."""
        error_dict = {
            "error": {
                "message": self.message,
                "code": self.error_code,
                "timestamp": self.timestamp.isoformat(),
            }
        }
        
        if self.details:
            error_dict["error"]["details"] = self.details
        
        return error_dict
    
    def __str__(self) -> str:
        return f"{self.error_code}: {self.message}"
    
    def __repr__(self) -> str:
        return (
            f"{self.__class__.__name__}("
            f"message={self.message!r}, "
            f"error_code={self.error_code!r}, "
            f"status_code={self.status_code})"
        )


class NotFoundError(AppException):
    """Exceção base para recursos não encontrados."""
    
    def __init__(
        self,
        resource: str,
        identifier: Any,
        details: Optional[Dict[str, Any]] = None
    ):
        message = f"{resource} não encontrado"
        error_code = f"{resource.upper()}_NOT_FOUND"
        
        details = details or {}
        details.update({
            "resource": resource,
            "identifier": str(identifier)
        })
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_404_NOT_FOUND,
            details=details
        )


class ConflictError(AppException):
    """Exceção base para conflitos de recursos."""
    
    def __init__(
        self,
        resource: str,
        field: str,
        value: Any,
        details: Optional[Dict[str, Any]] = None
    ):
        message = f"{resource} já existe com {field}={value}"
        error_code = f"{resource.upper()}_CONFLICT"
        
        details = details or {}
        details.update({
            "resource": resource,
            "field": field,
            "value": str(value)
        })
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_409_CONFLICT,
            details=details
        )


class ValidationError(AppException):
    """Exceção base para erros de validação."""
    
    def __init__(
        self,
        message: str,
        field: Optional[str] = None,
        details: Optional[Dict[str, Any]] = None
    ):
        error_code = "VALIDATION_ERROR"
        
        details = details or {}
        if field:
            details["field"] = field
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details=details
        )


class PermissionDeniedError(AppException):
    """Exceção para negação de permissão."""
    
    def __init__(
        self,
        message: str = "Você não tem permissão para realizar esta ação",
        required_permission: Optional[str] = None,
        details: Optional[Dict[str, Any]] = None
    ):
        error_code = "PERMISSION_DENIED"
        
        details = details or {}
        if required_permission:
            details["required_permission"] = required_permission
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_403_FORBIDDEN,
            details=details
        )


class RateLimitExceededError(AppException):
    """Exceção para limite de taxa excedido."""
    
    def __init__(
        self,
        retry_after: int,
        details: Optional[Dict[str, Any]] = None
    ):
        message = f"Limite de requisições excedido. Tente novamente em {retry_after} segundos"
        error_code = "RATE_LIMIT_EXCEEDED"
        
        details = details or {}
        details["retry_after"] = retry_after
        
        headers = {"Retry-After": str(retry_after)}
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_429_TOO_MANY_REQUESTS,
            details=details,
            headers=headers
        )


class ServiceUnavailableError(AppException):
    """Exceção para serviço indisponível."""
    
    def __init__(
        self,
        service_name: str,
        details: Optional[Dict[str, Any]] = None
    ):
        message = f"Serviço {service_name} temporariamente indisponível"
        error_code = "SERVICE_UNAVAILABLE"
        
        details = details or {}
        details["service"] = service_name
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            details=details
        )
```

## 3. Exceções Específicas por Domínio

### 🔐 **Exceções de Autenticação e Autorização**

```python
# src/api/core/exceptions/auth.py
"""Exceções relacionadas à autenticação e autorização."""

from typing import Optional, Dict, Any
from fastapi import status

from .base import AppException


class AuthenticationError(AppException):
    """Exceção base para erros de autenticação."""
    
    def __init__(
        self,
        message: str = "Falha na autenticação",
        error_code: str = "AUTHENTICATION_ERROR",
        details: Optional[Dict[str, Any]] = None
    ):
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status.HTTP_401_UNAUTHORIZED,
            details=details,
            headers={"WWW-Authenticate": "Bearer"}
        )


class InvalidCredentialsError(AuthenticationError):
    """Credenciais inválidas."""
    
    def __init__(self):
        super().__init__(
            message="Email ou senha inválidos",
            error_code="INVALID_CREDENTIALS"
        )


class TokenExpiredError(AuthenticationError):
    """Token expirado."""
    
    def __init__(self, token_type: str = "access"):
        super().__init__(
            message=f"Token de {token_type} expirado",
            error_code="TOKEN_EXPIRED",
            details={"token_type": token_type}
        )


class TokenInvalidError(AuthenticationError):
    """Token inválido."""
    
    def __init__(self, reason: Optional[str] = None):
        details = {"reason": reason} if reason else None
        super().__init__(
            message="Token inválido ou malformado",
            error_code="TOKEN_INVALID",
            details=details
        )


class TokenRevokedError(AuthenticationError):
    """Token revogado."""
    
    def __init__(self):
        super().__init__(
            message="Token foi revogado",
            error_code="TOKEN_REVOKED"
        )


class InsufficientPermissionsError(AppException):
    """Permissões insuficientes."""
    
    def __init__(
        self,
        required_permission: str,
        current_permissions: Optional[list] = None
    ):
        details = {
            "required_permission": required_permission
        }
        if current_permissions:
            details["current_permissions"] = current_permissions
        
        super().__init__(
            message=f"Permissão necessária: {required_permission}",
            error_code="INSUFFICIENT_PERMISSIONS",
            status_code=status.HTTP_403_FORBIDDEN,
            details=details
        )


class AccountLockedError(AuthenticationError):
    """Conta bloqueada."""
    
    def __init__(self, reason: str, unlock_at: Optional[str] = None):
        details = {"reason": reason}
        if unlock_at:
            details["unlock_at"] = unlock_at
        
        super().__init__(
            message="Conta bloqueada",
            error_code="ACCOUNT_LOCKED",
            details=details
        )


class AccountInactiveError(AuthenticationError):
    """Conta inativa."""
    
    def __init__(self):
        super().__init__(
            message="Conta inativa. Por favor, ative sua conta",
            error_code="ACCOUNT_INACTIVE"
        )


class InvalidRefreshTokenError(AuthenticationError):
    """Refresh token inválido."""
    
    def __init__(self):
        super().__init__(
            message="Refresh token inválido ou expirado",
            error_code="INVALID_REFRESH_TOKEN"
        )


class MFARequiredError(AuthenticationError):
    """MFA obrigatório."""
    
    def __init__(self, mfa_methods: list):
        super().__init__(
            message="Autenticação de dois fatores necessária",
            error_code="MFA_REQUIRED",
            details={"available_methods": mfa_methods}
        )


class InvalidMFACodeError(AuthenticationError):
    """Código MFA inválido."""
    
    def __init__(self, attempts_remaining: Optional[int] = None):
        details = {}
        if attempts_remaining is not None:
            details["attempts_remaining"] = attempts_remaining
        
        super().__init__(
            message="Código de autenticação inválido",
            error_code="INVALID_MFA_CODE",
            details=details
        )
```

### 💼 **Exceções de Regras de Negócio**

```python
# src/api/core/exceptions/business.py
"""Exceções relacionadas às regras de negócio."""

from typing import Optional, Dict, Any
from fastapi import status

from .base import AppException, NotFoundError, ConflictError


class UserNotFoundError(NotFoundError):
    """Usuário não encontrado."""
    
    def __init__(self, user_id: Any):
        super().__init__(
            resource="User",
            identifier=user_id
        )


class UserAlreadyExistsError(ConflictError):
    """Usuário já existe."""
    
    def __init__(self, email: str):
        super().__init__(
            resource="User",
            field="email",
            value=email
        )


class ProductNotFoundError(NotFoundError):
    """Produto não encontrado."""
    
    def __init__(self, product_id: Any):
        super().__init__(
            resource="Product",
            identifier=product_id
        )


class InsufficientStockError(AppException):
    """Estoque insuficiente."""
    
    def __init__(
        self,
        product_id: Any,
        requested: int,
        available: int
    ):
        super().__init__(
            message="Estoque insuficiente para completar a operação",
            error_code="INSUFFICIENT_STOCK",
            status_code=status.HTTP_409_CONFLICT,
            details={
                "product_id": str(product_id),
                "requested": requested,
                "available": available
            }
        )


class InvalidOrderStatusError(AppException):
    """Status de pedido inválido."""
    
    def __init__(
        self,
        current_status: str,
        attempted_status: str,
        allowed_transitions: list
    ):
        super().__init__(
            message=f"Não é possível mudar status de {current_status} para {attempted_status}",
            error_code="INVALID_ORDER_STATUS_TRANSITION",
            status_code=status.HTTP_400_BAD_REQUEST,
            details={
                "current_status": current_status,
                "attempted_status": attempted_status,
                "allowed_transitions": allowed_transitions
            }
        )


class PaymentFailedError(AppException):
    """Falha no pagamento."""
    
    def __init__(
        self,
        reason: str,
        transaction_id: Optional[str] = None
    ):
        details = {"reason": reason}
        if transaction_id:
            details["transaction_id"] = transaction_id
        
        super().__init__(
            message="Falha ao processar pagamento",
            error_code="PAYMENT_FAILED",
            status_code=status.HTTP_402_PAYMENT_REQUIRED,
            details=details
        )


class QuotaExceededError(AppException):
    """Cota excedida."""
    
    def __init__(
        self,
        resource: str,
        limit: int,
        current: int
    ):
        super().__init__(
            message=f"Limite de {resource} excedido",
            error_code="QUOTA_EXCEEDED",
            status_code=status.HTTP_403_FORBIDDEN,
            details={
                "resource": resource,
                "limit": limit,
                "current": current
            }
        )


class InvalidBusinessRuleError(AppException):
    """Regra de negócio violada."""
    
    def __init__(
        self,
        rule_name: str,
        violation_reason: str,
        details: Optional[Dict[str, Any]] = None
    ):
        details = details or {}
        details.update({
            "rule": rule_name,
            "reason": violation_reason
        })
        
        super().__init__(
            message=f"Violação de regra de negócio: {rule_name}",
            error_code="BUSINESS_RULE_VIOLATION",
            status_code=status.HTTP_400_BAD_REQUEST,
            details=details
        )


class ResourceLockError(AppException):
    """Recurso bloqueado."""
    
    def __init__(
        self,
        resource: str,
        resource_id: Any,
        locked_by: Optional[str] = None
    ):
        details = {
            "resource": resource,
            "resource_id": str(resource_id)
        }
        if locked_by:
            details["locked_by"] = locked_by
        
        super().__init__(
            message=f"{resource} está bloqueado e não pode ser modificado",
            error_code="RESOURCE_LOCKED",
            status_code=status.HTTP_423_LOCKED,
            details=details
        )
```

### ✅ **Exceções de Validação**

```python
# src/api/core/exceptions/validation.py
"""Exceções relacionadas à validação de dados."""

from typing import Optional, Dict, Any, List
from fastapi import status

from .base import AppException


class InvalidInputError(AppException):
    """Entrada inválida."""
    
    def __init__(
        self,
        field: str,
        message: str,
        value: Any = None
    ):
        details = {"field": field}
        if value is not None:
            details["provided_value"] = str(value)
        
        super().__init__(
            message=message,
            error_code="INVALID_INPUT",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details=details
        )


class InvalidEmailFormatError(InvalidInputError):
    """Formato de email inválido."""
    
    def __init__(self, email: str):
        super().__init__(
            field="email",
            message="Formato de email inválido",
            value=email
        )


class InvalidDateRangeError(AppException):
    """Range de datas inválido."""
    
    def __init__(self, start_date: str, end_date: str, reason: str):
        super().__init__(
            message=f"Range de datas inválido: {reason}",
            error_code="INVALID_DATE_RANGE",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details={
                "start_date": start_date,
                "end_date": end_date,
                "reason": reason
            }
        )


class MissingRequiredFieldError(AppException):
    """Campo obrigatório ausente."""
    
    def __init__(self, field: str):
        super().__init__(
            message=f"Campo obrigatório ausente: {field}",
            error_code="MISSING_REQUIRED_FIELD",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details={"field": field}
        )


class InvalidFileTypeError(AppException):
    """Tipo de arquivo inválido."""
    
    def __init__(
        self,
        provided_type: str,
        allowed_types: List[str]
    ):
        super().__init__(
            message=f"Tipo de arquivo não permitido: {provided_type}",
            error_code="INVALID_FILE_TYPE",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details={
                "provided_type": provided_type,
                "allowed_types": allowed_types
            }
        )


class FileTooLargeError(AppException):
    """Arquivo muito grande."""
    
    def __init__(
        self,
        file_size: int,
        max_size: int
    ):
        super().__init__(
            message=f"Arquivo muito grande. Máximo permitido: {max_size} bytes",
            error_code="FILE_TOO_LARGE",
            status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
            details={
                "file_size": file_size,
                "max_size": max_size,
                "max_size_mb": round(max_size / (1024 * 1024), 2)
            }
        )


class InvalidEnumValueError(AppException):
    """Valor de enum inválido."""
    
    def __init__(
        self,
        field: str,
        value: str,
        allowed_values: List[str]
    ):
        super().__init__(
            message=f"Valor inválido para {field}: {value}",
            error_code="INVALID_ENUM_VALUE",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details={
                "field": field,
                "provided_value": value,
                "allowed_values": allowed_values
            }
        )


class ValidationGroupError(AppException):
    """Múltiplos erros de validação."""
    
    def __init__(self, errors: List[Dict[str, Any]]):
        super().__init__(
            message=f"Múltiplos erros de validação encontrados ({len(errors)} erros)",
            error_code="VALIDATION_GROUP_ERROR",
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            details={"errors": errors}
        )
```

### 🌐 **Exceções de Serviços Externos**

```python
# src/api/core/exceptions/external.py
"""Exceções para integrações com serviços externos."""

from typing import Optional, Dict, Any
from fastapi import status

from .base import AppException


class ExternalServiceError(AppException):
    """Erro base para serviços externos."""
    
    def __init__(
        self,
        service_name: str,
        message: str,
        error_code: str = "EXTERNAL_SERVICE_ERROR",
        status_code: int = status.HTTP_502_BAD_GATEWAY,
        details: Optional[Dict[str, Any]] = None
    ):
        details = details or {}
        details["service"] = service_name
        
        super().__init__(
            message=message,
            error_code=error_code,
            status_code=status_code,
            details=details
        )


class ExternalAPIError(ExternalServiceError):
    """Erro de API externa."""
    
    def __init__(
        self,
        service_name: str,
        endpoint: str,
        http_status: int,
        response_body: Optional[str] = None
    ):
        details = {
            "endpoint": endpoint,
            "http_status": http_status
        }
        if response_body:
            details["response"] = response_body
        
        super().__init__(
            service_name=service_name,
            message=f"Erro ao comunicar com {service_name}",
            error_code="EXTERNAL_API_ERROR",
            details=details
        )


class ExternalAPITimeoutError(ExternalServiceError):
    """Timeout em API externa."""
    
    def __init__(
        self,
        service_name: str,
        timeout_seconds: float
    ):
        super().__init__(
            service_name=service_name,
            message=f"Timeout ao comunicar com {service_name}",
            error_code="EXTERNAL_API_TIMEOUT",
            status_code=status.HTTP_504_GATEWAY_TIMEOUT,
            details={"timeout_seconds": timeout_seconds}
        )


class PaymentGatewayError(ExternalServiceError):
    """Erro no gateway de pagamento."""
    
    def __init__(
        self,
        gateway_name: str,
        error_message: str,
        transaction_id: Optional[str] = None
    ):
        details = {"error_message": error_message}
        if transaction_id:
            details["transaction_id"] = transaction_id
        
        super().__init__(
            service_name=gateway_name,
            message="Erro ao processar pagamento",
            error_code="PAYMENT_GATEWAY_ERROR",
            status_code=status.HTTP_502_BAD_GATEWAY,
            details=details
        )


class EmailServiceError(ExternalServiceError):
    """Erro no serviço de email."""
    
    def __init__(
        self,
        provider: str,
        recipient: str,
        error_message: str
    ):
        super().__init__(
            service_name=provider,
            message="Falha ao enviar email",
            error_code="EMAIL_SERVICE_ERROR",
            details={
                "recipient": recipient,
                "error_message": error_message
            }
        )


class StorageServiceError(ExternalServiceError):
    """Erro no serviço de storage."""
    
    def __init__(
        self,
        provider: str,
        operation: str,
        file_path: str,
        error_message: str
    ):
        super().__init__(
            service_name=provider,
            message=f"Erro ao {operation} arquivo",
            error_code="STORAGE_SERVICE_ERROR",
            details={
                "operation": operation,
                "file_path": file_path,
                "error_message": error_message
            }
        )


class DatabaseConnectionError(AppException):
    """Erro de conexão com banco de dados."""
    
    def __init__(
        self,
        database_name: str,
        error_message: str
    ):
        super().__init__(
            message="Erro ao conectar com banco de dados",
            error_code="DATABASE_CONNECTION_ERROR",
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            details={
                "database": database_name,
                "error_message": error_message
            }
        )


class CacheServiceError(ExternalServiceError):
    """Erro no serviço de cache."""
    
    def __init__(
        self,
        cache_provider: str,
        operation: str,
        key: str
    ):
        super().__init__(
            service_name=cache_provider,
            message=f"Erro ao {operation} cache",
            error_code="CACHE_SERVICE_ERROR",
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            details={
                "operation": operation,
                "key": key
            }
        )
