# src/api/main.py
"""Configuração principal da aplicação com exception handlers."""

import logging
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from src.api.core.handlers.exception_handlers import register_exception_handlers
from src.api.core.handlers.http_handlers import (
    not_found_handler,
    method_not_allowed_handler
)
from src.api.core.middleware.correlation_middleware import CorrelationMiddleware
from src.api.core.middleware.response_middleware import ResponseFormattingMiddleware
from src.api.v1.router import api_router

# Configurar logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s - %(request_id)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)

logger = logging.getLogger(__name__)

# Criar aplicação
app = FastAPI(
    title="API com Tratamento Robusto de Exceções",
    description="API FastAPI com sistema completo de tratamento de erros",
    version="1.0.0",
    docs_url="/docs",
    redoc_url="/redoc"
)

# Configurar CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Configurar apropriadamente em produção
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Adicionar middlewares customizados (ordem importa)
app.add_middleware(ResponseFormattingMiddleware)
app.add_middleware(CorrelationMiddleware)

# Registrar exception handlers
register_exception_handlers(app)

# Registrar handlers HTTP específicos
app.add_exception_handler(404, not_found_handler)
app.add_exception_handler(405, method_not_allowed_handler)

# Incluir routers
app.include_router(api_router, prefix="/api/v1")


@app.on_event("startup")
async def startup_event():
    """Evento de inicialização."""
    logger.info("🚀 Aplicação iniciada com sistema de exceções configurado")
    logger.info("📝 Documentação disponível em: /docs")


@app.on_event("shutdown")
async def shutdown_event():
    """Evento de encerramento."""
    logger.info("👋 Encerrando aplicação")


@app.get("/health")
async def health_check():
    """Endpoint de health check."""
    return {
        "status": "healthy",
        "version": app.version
    }


