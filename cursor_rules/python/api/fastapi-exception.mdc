# src/api/core/context.py
"""Contexto de requisição e rastreamento."""

import uuid
from contextvars import ContextVar
from typing import Optional

# ContextVars para armazenar informações da requisição
request_id_var: ContextVar[Optional[str]] = ContextVar("request_id", default=None)
user_id_var: ContextVar[Optional[str]] = ContextVar("user_id", default=None)
correlation_id_var: ContextVar[Optional[str]] = ContextVar("correlation_id", default=None)


def generate_request_id() -> str:
    """Gera um novo ID de requisição."""
    return str(uuid.uuid4())


def set_request_id(request_id: str) -> None:
    """Define o ID da requisição no contexto."""
    request_id_var.set(request_id)


def get_request_id() -> Optional[str]:
    """Obtém o ID da requisição do contexto."""
    return request_id_var.get()


def set_user_id(user_id: str) -> None:
    """Define o ID do usuário no contexto."""
    user_id_var.set(user_id)


def get_user_id() -> Optional[str]:
    """Obtém o ID do usuário do contexto."""
    return user_id_var.get()


def set_correlation_id(correlation_id: str) -> None:
    """Define o ID de correlação no contexto."""
    correlation_id_var.set(correlation_id)


def get_correlation_id() -> Optional[str]:
    """Obtém o ID de correlação do contexto."""
    return correlation_id_var.get()


def clear_context() -> None:
    """Limpa todo o contexto."""
    request_id_var.set(None)
    user_id_var.set(None)
    correlation_id_var.set(None)
