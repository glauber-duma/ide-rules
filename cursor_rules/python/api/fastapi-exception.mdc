# src/api/core/responses/error_responses.py
"""Builder para respostas de erro padronizadas."""

from typing import Any, Dict, Optional, List
from datetime import datetime


class ErrorResponseBuilder:
    """Builder para construção de respostas de erro padronizadas."""
    
    @staticmethod
    def build_error_response(
        message: str,
        error_code: str,
        status_code: int,
        request_id: Optional[str] = None,
        path: Optional[str] = None,
        details: Optional[Dict[str, Any]] = None,
        timestamp: Optional[datetime] = None
    ) -> Dict[str, Any]:
        """
        Constrói resposta de erro padronizada.
        
        Args:
            message: Mensagem de erro amigável
            error_code: Código único do erro
            status_code: Status HTTP
            request_id: ID da requisição para rastreamento
            path: Path da requisição
            details: Detalhes adicionais do erro
            timestamp: Timestamp do erro
        
        Returns:
            Dicionário com estrutura padronizada de erro
        """
        error_response = {
            "error": {
                "message": message,
                "code": error_code,
                "status": status_code,
                "timestamp": (timestamp or datetime.utcnow()).isoformat()
            }
        }
        
        if request_id:
            error_response["error"]["request_id"] = request_id
        
        if path:
            error_response["error"]["path"] = path
        
        if details:
            error_response["error"]["details"] = details
        
        return error_response
    
    @staticmethod
    def build_validation_error_response(
        errors: List[Dict[str, Any]],
        request_id: Optional[str] = None,
        path: Optional[str] = None
    ) -> Dict[str, Any]:
        """
        Constrói resposta para erros de validação.
        
        Args:
            errors: Lista de erros de validação
            request_id: ID da requisição
            path: Path da requisição
        
        Returns:
            Dicionário com estrutura de erro de validação
        """
        return ErrorResponseBuilder.build_error_response(
            message=f"Erro de validação ({len(errors)} erro(s) encontrado(s))",
            error_code="VALIDATION_ERROR",
            status_code=422,
            request_id=request_id,
            path=path,
            details={"validation_errors": errors}
        )
    
    @staticmethod
    def build_auth_error_response(
        message: str = "Autenticação necessária",
        request_id: Optional[str] = None,
        path: Optional[str] = None
    ) -> Dict[str, Any]:
        """Constrói resposta para erros de autenticação."""
        return ErrorResponseBuilder.build_error_response(
            message=message,
            error_code="AUTHENTICATION_REQUIRED",
            status_code=401,
            request_id=request_id,
            path=path
        )
    
    @staticmethod
    def build_permission_error_response(
        message: str = "Permissão negada",
        required_permission: Optional[str] = None,
        request_id: Optional[str] = None,
        path: Optional[str] = None
    ) -> Dict[str, Any]:
        """Constrói resposta para erros de permissão."""
        details = {}
        if required_permission:
            details["required_permission"] = required_permission
        
        return ErrorResponseBuilder.build_error_response(
            message=message,
            error_code="PERMISSION_DENIED",
            status_code=403,
            request_id=request_id,
            path=path,
            details=details if details else None
        )
    
    @staticmethod
    def build_not_found_response(
        resource: str,
        identifier: Any,
        request_id: Optional[str] = None,
        path: Optional[str] = None
    ) -> Dict[str, Any]:
        """Constrói resposta para recurso não encontrado."""
        return ErrorResponseBuilder.build_error_response(
            message=f"{resource} não encontrado",
            error_code=f"{resource.upper()}_NOT_FOUND",
            status_code=404,
            request_id=request_id,
            path=path,
            details={
                "resource": resource,
                "identifier": str(identifier)
            }
        )
    
    @staticmethod
    def build_conflict_response(
        resource: str,
        field: str,
        value: Any,
        request_id: Optional[str] = None,
        path: Optional[str] = None
    ) -> Dict[str, Any]:
        """Constrói resposta para conflito de recursos."""
        return ErrorResponseBuilder.build_error_response(
            message=f"{resource} já existe com {field}={value}",
            error_code=f"{resource.upper()}_CONFLICT",
            status_code=409,
            request_id=request_id,
            path=path,
            details={
                "resource": resource,
                "field": field,
                "value": str(value)
            }
        )
```

