# src/api/core/responses/success_responses.py
"""Builder para respostas de sucesso padronizadas."""

from typing import Any, Dict, Optional
from datetime import datetime


class SuccessResponseBuilder:
    """Builder para construção de respostas de sucesso padronizadas."""
    
    @staticmethod
    def build_success_response(
        data: Any,
        message: Optional[str] = None,
        meta: Optional[Dict[str, Any]] = None
    ) -> Dict[str, Any]:
        """
        Constrói resposta de sucesso padronizada.
        
        Args:
            data: Dados da resposta
            message: Mensagem opcional de sucesso
            meta: Metadados adicionais
        
        Returns:
            Dicionário com estrutura padronizada
        """
        response = {"data": data}
        
        if message:
            response["message"] = message
        
        if meta:
            response["meta"] = meta
        
        return response
    
    @staticmethod
    def build_list_response(
        items: list,
        total: int,
        page: int = 1,
        page_size: int = 100,
        meta: Optional[Dict[str, Any]] = None
    ) -> Dict[str, Any]:
        """Constrói resposta de lista com paginação."""
        pagination_meta = {
            "total": total,
            "page": page,
            "page_size": page_size,
            "total_pages": (total + page_size - 1) // page_size,
            "has_next": page * page_size < total,
            "has_previous": page > 1
        }
        
        if meta:
            pagination_meta.update(meta)
        
        return SuccessResponseBuilder.build_success_response(
            data=items,
            meta=pagination_meta
        )
    
    @staticmethod
    def build_created_response(
        data: Any,
        resource_id: Any,
        message: Optional[str] = None
    ) -> Dict[str, Any]:
        """Constrói resposta para recurso criado (201)."""
        return SuccessResponseBuilder.build_success_response(
            data=data,
            message=message or "Recurso criado com sucesso",
            meta={"resource_id": str(resource_id)}
        )
    
    @staticmethod
    def build_no_content_response() -> None:
        """Retorna None para 204 No Content."""
        return None
