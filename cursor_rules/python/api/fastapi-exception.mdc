# src/api/core/middleware/correlation_middleware.py
"""Middleware para correlação de requisições."""

import logging
from typing import Callable
from fastapi import Request, Response
from starlette.middleware.base import BaseHTTPMiddleware

from ..context import (
    generate_request_id,
    set_request_id,
    set_correlation_id,
    get_request_id,
    clear_context
)

logger = logging.getLogger(__name__)


class CorrelationMiddleware(BaseHTTPMiddleware):
    """
    Middleware que gerencia IDs de correlação e rastreamento.
    
    Adiciona X-Request-ID e X-Correlation-ID aos headers.
    """
    
    async def dispatch(
        self,
        request: Request,
        call_next: Callable
    ) -> Response:
        """
        Processa requisição e adiciona IDs de rastreamento.
        """
        # Obter ou gerar request_id
        request_id = request.headers.get("X-Request-ID") or generate_request_id()
        set_request_id(request_id)
        
        # Obter ou gerar correlation_id
        correlation_id = request.headers.get("X-Correlation-ID") or request_id
        set_correlation_id(correlation_id)
        
        # Adicionar ao contexto de log
        logger.info(
            f"Incoming request: {request.method} {request.url.path}",
            extra={
                "request_id": request_id,
                "correlation_id": correlation_id,
                "method": request.method,
                "path": request.url.path,
                "client_ip": request.client.host if request.client else None
            }
        )
        
        try:
            # Processar requisição
            response = await call_next(request)
            
            # Adicionar headers de rastreamento
            response.headers["X-Request-ID"] = request_id
            response.headers["X-Correlation-ID"] = correlation_id
            
            return response
        
        finally:
            # Limpar contexto após requisição
            clear_context()
