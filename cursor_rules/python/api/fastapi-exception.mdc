### ❌ **DON'Ts - Práticas a Evitar**

```python
# ❌ NÃO use exceções genéricas
raise Exception("Algum erro aconteceu")  # Muito genérico


# ❌ NÃO exponha detalhes internos em mensagens de erro
raise Exception(f"Database error: {connection_string}")  # Expõe dados sensíveis


# ❌ NÃO capture exceções sem fazer nada (silent failures)
try:
    result = dangerous_operation()
except Exception:
    pass  # Erro engolido sem log ou tratamento


# ❌ NÃO use bare except
try:
    result = operation()
except:  # Captura TUDO, inclusive KeyboardInterrupt
    handle_error()


# ❌ NÃO use exceções para controle de fluxo normal
def get_user_age(user_id):
    try:
        return users[user_id].age
    except KeyError:
        return 0  # Usando exceção como if


# ❌ NÃO retorne estruturas inconsistentes de erro
# Endpoint 1
return {"error": "Not found"}

# Endpoint 2
return {"message": "Error occurred", "status": "fail"}

# Endpoint 3
return {"detail": {"msg": "Something wrong"}}


# ❌ NÃO ignore o status code HTTP
raise HTTPException(
    status_code=200,  # Status de sucesso para um erro!
    detail="User not found"
)


# ❌ NÃO inclua stack traces em responses de produção
return {
    "error": str(exc),
    "traceback": traceback.format_exc()  # Expõe estrutura interna
}


# ❌ NÃO crie exceções sem contexto útil
raise ValueError("Invalid")  # Inválido o quê?


# ❌ NÃO misture idiomas em mensagens de erro
raise Exception("Usuário not found no database")  # Inconsistente


# ❌ NÃO use strings mágicas para error codes
if error_type == "notfound":  # Typo-prone, sem padronização
    handle_not_found()


# ❌ NÃO log informações sensíveis
logger.error(f"Login failed for password: {password}")  # Expõe senha


# ❌ NÃO crie exceções dentro de loops
for item in items:
    try:
        process(item)
    except Exception:
        raise CustomError()  # Cria nova exceção a cada iteração


# ❌ NÃO ignore exception chaining
try:
    operation()
except Exception:
    raise NewException()  # Perde contexto da exceção original

# ✅ CORRETO
try:
    operation()
except Exception as e:
    raise NewException() from e  # Preserva contexto


# ❌ NÃO use exceções para validação que deveria ser feita antes
async def create_user(email: str):
    try:
        user = await db.create(email=email)
    except IntegrityError:
        raise UserAlreadyExistsError()  # Deveria verificar antes

# ✅ CORRETO
async def create_user(email: str):
    existing = await db.get(email=email)
    if existing:
        raise UserAlreadyExistsError()
    return await db.create(email=email)


# ❌ NÃO re-raise exceções desnecessariamente
try:
    result = operation()
except Exception as e:
    logger.error(str(e))
    raise e  # Desnecessário, pode só fazer raise

# ✅ CORRETO
try:
    result = operation()
except Exception as e:
    logger.error(str(e))
    raise  # Mais limpo


# ❌ NÃO crie múltiplas exceções para o mesmo erro
class UserNotFound(Exception): pass
class UserDoesNotExist(Exception): pass
class NoUserFound(Exception): pass  # Redundante


# ❌ NÃO use assert para validação de entrada de usuário
def create_user(email: str):
    assert "@" in email  # Desabilitado com -O flag
    # Usar validação explícita


# ❌ NÃO ignore o contexto assíncrono
def blocking_operation():  # Função síncrona
    time.sleep(10)  # Bloqueia event loop

# ✅ CORRETO
async def async_operation():
    await asyncio.sleep(10)  # Não bloqueia


# ❌ NÃO crie exception handlers muito genéricos
@app.exception_handler(Exception)
async def handle_all(request, exc):
    return JSONResponse({"error": "Error"})  # Muito genérico


# ❌ NÃO esqueça de limpar recursos em caso de exceção
file = open("data.txt")
process(file)  # Se falhar, arquivo não fecha
file.close()

# ✅ CORRETO - use context manager
with open("data.txt") as file:
    process(file)  # Fecha automaticamente


# ❌ NÃO retorne códigos de erro numéricos sem documentação
return {"error_code": 1042}  # O que significa 1042?


# ❌ NÃO use exceções para comunicação entre camadas
# Service
def get_user(user_id):
    raise UserNotFoundFlag()  # Não é erro, é flag

# ✅ CORRETO - use retorno None ou Optional
def get_user(user_id) -> Optional[User]:
    return None  # Indica não encontrado


# ❌ NÃO crie hierarquias de exceção muito profundas
class BaseError(Exception): pass
class ServiceError(BaseError): pass
class APIError(ServiceError): pass
class HTTPError(APIError): pass
class RequestError(HTTPError): pass
class TimeoutError(RequestError): pass  # Muito profundo


# ❌ NÃO log o mesmo erro múltiplas vezes
try:
    operation()
except Exception as e:
    logger.error(str(e))  # Log 1
    handle_error(e)  # Função que também loga - Log 2
    raise  # Handler global também loga - Log 3


# ❌ NÃO retorne diferentes tipos de response para sucesso/erro
# Sucesso: {"data": {...}}
# Erro: "Error message"  # String ao invés de objeto


# ❌ NÃO use exceções para representar estado de negócio
if order.status == "pending":
    raise OrderPendingException()  # Estado, não erro

# ✅ CORRETO
if order.status == "pending":
    return {"status": "pending", "message": "Order awaiting processing"}
```

**Esta rule deve ser rigorosamente seguida em todos os projetos FastAPI da organização.**
