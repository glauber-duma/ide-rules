```python
# src/api/core/decorators/context_decorator.py
"""Decoradores para gerenciamento de contexto."""

import logging
from typing import Callable
from functools import wraps

from ..context import get_request_id, get_user_id

logger = logging.getLogger(__name__)


def with_context(operation_name: str):
    """
    Decorator que adiciona contexto automaticamente ao log.
    
    Args:
        operation_name: Nome da operação para contexto
    
    Uso:
        @with_context("create_user")
        async def create_user(data: UserCreate):
            ...
    """
    def decorator(func: Callable):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            request_id = get_request_id()
            user_id = get_user_id()
            
            log_context = {
                "operation": operation_name,
                "request_id": request_id,
                "user_id": user_id,
                "function": func.__name__
            }
            
            logger.info(
                f"Starting operation: {operation_name}",
                extra=log_context
            )
            
            try:
                result = await func(*args, **kwargs)
                
                logger.info(
                    f"Operation completed: {operation_name}",
                    extra=log_context
                )
                
                return result
            
            except Exception as e:
                logger.error(
                    f"Operation failed: {operation_name}",
                    extra={
                        **log_context,
                        "error": str(e),
                        "error_type": type(e).__name__
                    },
                    exc_info=True
                )
                raise
        
        return wrapper
    return decorator


def log_exceptions(func: Callable):
    """
    Decorator que loga exceções automaticamente com contexto.
    
    Uso:
        @log_exceptions
        async def risky_operation():
            ...
    """
    @wraps(func)
    async def wrapper(*args, **kwargs):
        try:
            return await func(*args, **kwargs)
        except Exception as e:
            logger.error(
                f"Exception in {func.__name__}",
                extra={
                    "function": func.__name__,
                    "request_id": get_request_id(),
                    "user_id": get_user_id(),
                    "exception_type": type(e).__name__,
                    "exception_message": str(e)
                },
                exc_info=True
            )
            raise
    
    return wrapper
