# ==================== GERENCIADOR DE UPLOAD ====================

class SecureFileUploader:
    """
    Gerenciador de upload seguro de arquivos.
    """
    
    def __init__(self, upload_dir: str):
        """
        Args:
            upload_dir: Diretório base para uploads
        """
        self.upload_dir = Path(upload_dir)
        self.upload_dir.mkdir(parents=True, exist_ok=True)
    
    async def save_image(
        self,
        file: UploadFile,
        subfolder: Optional[str] = None,
    ) -> tuple[str, dict]:
        """
        Salva imagem de forma segura.
        
        Args:
            file: Arquivo de imagem
            subfolder: Subpasta opcional
            
        Returns:
            tuple[str, dict]: (caminho do arquivo, metadados)
        """
        # Validar imagem
        width, height = await ImageValidator.validate_image(file)
        
        # Sanitizar nome
        safe_filename = FileValidator.sanitize_filename(file.filename)
        
        # Calcular hash
        file_hash = await FileValidator.calculate_file_hash(file)
        
        # Gerar nome único usando hash
        ext = Path(safe_filename).suffix
        unique_filename = f"{file_hash}{ext}"
        
        # Determinar caminho
        if subfolder:
            save_dir = self.upload_dir / subfolder
            save_dir.mkdir(parents=True, exist_ok=True)
        else:
            save_dir = self.upload_dir
        
        file_path = save_dir / unique_filename
        
        # Salvar arquivo
        contents = await file.read()
        
        # Remover EXIF data
        contents = ImageValidator.strip_exif_data(contents)
        
        with open(file_path, "wb") as f:
            f.write(contents)
        
        # Metadados
        metadata = {
            "original_filename": file.filename,
            "saved_filename": unique_filename,
            "file_hash": file_hash,
            "size": len(contents),
            "width": width,
            "height": height,
            "mime_type": file.content_type,
        }
        
        return str(file_path), metadata
    
    async def save_document(
        self,
        file: UploadFile,
        subfolder: Optional[str] = None,
    ) -> tuple[str, dict]:
        """
