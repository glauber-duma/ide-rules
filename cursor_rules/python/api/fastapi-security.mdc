# ==================== TESTES DE SEGURANÇA ====================

class TestSecurityVulnerabilities:
    """Testes de vulnerabilidades comuns."""
    
    def test_sql_injection_in_login(self, client: TestClient):
        """Sistema deve prevenir SQL injection no login."""
        sql_injection_payloads = [
            "' OR '1'='1",
            "admin'--",
            "' OR 1=1--",
            "'; DROP TABLE users;--",
        ]
        
        for payload in sql_injection_payloads:
            response = client.post(
                "/api/v1/auth/login",
                json={
                    "email": payload,
                    "password": payload,
                },
            )
            
            # Não deve retornar 500 (erro de servidor)
            # Deve retornar 401 ou 422
            assert response.status_code in [
                status.HTTP_401_UNAUTHORIZED,
                status.HTTP_422_UNPROCESSABLE_ENTITY,
            ]
    
    def test_xss_in_user_input(self, client: TestClient, auth_headers):
        """Sistema deve sanitizar XSS em inputs."""
        xss_payloads = [
            "<script>alert('XSS')</script>",
            "<img src=x onerror=alert('XSS')>",
            "javascript:alert('XSS')",
        ]
        
        for payload in xss_payloads:
            response = client.post(
                "/api/v1/posts",
                headers=auth_headers,
                json={
                    "title": payload,
                    "content": payload,
                },
            )
            
            # Deve aceitar mas sanitizar
            if response.status_code == status.HTTP_201_CREATED:
                data = response.json()
                # Verificar que tags foram escapadas ou removidas
                assert "<script>" not in data["title"]
                assert "onerror=" not in data["title"]
    
    def test_rate_limiting(self, client: TestClient):
        """Sistema deve implementar rate limiting."""
        # Fazer múltiplas requisições rápidas
        responses = []
        for _ in range(100):
            response = client.post(
                "/api/v1/auth/login",
                json={
                    "email": "test@example.com",
                    "password": "password",
                },
            )
            responses.append(response.status_code)
        
        # Deve ter pelo menos um 429 (Too Many Requests)
        assert status.HTTP_429_TOO_MANY_REQUESTS in responses
    
    def test_cors_headers(self, client: TestClient):
        """Sistema deve ter headers CORS apropriados."""
        response = client.options("/api/v1/users")
        
        assert "access-control-allow-origin" in response.headers
        assert "access-control-allow-methods" in response.headers
    
    def test_security_headers(self, client: TestClient):
        """Sistema deve incluir headers de segurança."""
        response = client.get("/")
        
        security_headers = [
            "x-content-type-options",
            "x-frame-options",
            "content-security-policy",
            "strict-transport-security",
        ]
        
        for header in security_headers:
            assert header in response.headers.keys()


