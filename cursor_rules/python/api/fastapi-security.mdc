# FastAPI Security - Diretrizes de Segurança para APIs Python

Esta regra estabelece padrões de segurança para APIs baseados em análise de projetos reais e melhores práticas de segurança.

## 🔒 **Autenticação e Autorização**

### 1.1. JWT Autenticação e Autorização

```python
# src/app/core/configs/security.py
"""
Módulo de segurança para autenticação JWT e criptografia.
Implementa funções para geração e validação de tokens, hashing de senhas
e outras operações de segurança.
"""

from datetime import datetime, timedelta
from typing import Any, Dict, Optional, Union

from fastapi import HTTPException, status
from jose import JWTError, jwt
from passlib.context import CryptContext
from pydantic import ValidationError

from app.core.configs.config import settings


# ==================== CONFIGURAÇÃO DE CRIPTOGRAFIA ====================

# Context para hashing de senhas com bcrypt
pwd_context = CryptContext(
    schemes=["bcrypt"],
    deprecated="auto",
    bcrypt__rounds=12,  # Número de rounds (mais = mais seguro mas mais lento)
)


# ==================== HASHING DE SENHAS ====================

def hash_password(password: str) -> str:
    """
    Cria hash de senha usando bcrypt.
    
    Args:
        password: Senha em texto plano
        
    Returns:
        str: Hash da senha
        
    Example:
        >>> hashed = hash_password("minha_senha_segura")
        >>> print(hashed)
        $2b$12$...
    """
    return pwd_context.hash(password)


def verify_password(plain_password: str, hashed_password: str) -> bool:
    """
    Verifica se a senha corresponde ao hash.
    
    Args:
        plain_password: Senha em texto plano
        hashed_password: Hash armazenado
        
    Returns:
        bool: True se a senha está correta
        
    Example:
        >>> hashed = hash_password("senha123")
        >>> verify_password("senha123", hashed)
        True
        >>> verify_password("senha_errada", hashed)
        False
    """
    try:
        return pwd_context.verify(plain_password, hashed_password)
    except Exception:
        # Em caso de erro na verificação, sempre retornar False
        return False


def needs_rehash(hashed_password: str) -> bool:
    """
    Verifica se o hash da senha precisa ser atualizado.
    Útil quando você muda o número de rounds do bcrypt.
    
    Args:
        hashed_password: Hash armazenado
        
    Returns:
        bool: True se precisa rehash
    """
    return pwd_context.needs_update(hashed_password)


# ==================== GERAÇÃO DE TOKENS JWT ====================

def create_access_token(
    subject: Union[str, Any],
    expires_delta: Optional[timedelta] = None,
    additional_claims: Optional[Dict[str, Any]] = None,
) -> str:
    """
    Cria um token de acesso JWT.
    
    Args:
        subject: Identificador do usuário (geralmente user_id)
        expires_delta: Tempo de expiração customizado
        additional_claims: Claims adicionais para incluir no token
        
    Returns:
        str: Token JWT codificado
        
    Example:
        >>> token = create_access_token(subject="user_123")
        >>> print(token)
        eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
    """
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(
            minutes=settings.ACCESS_TOKEN_EXPIRE_MINUTES
        )
    
    # Claims obrigatórios
    to_encode = {
        "exp": expire,
        "sub": str(subject),
        "iat": datetime.utcnow(),
        "type": "access",
    }
    
    # Adicionar claims extras se fornecidos
    if additional_claims:
        to_encode.update(additional_claims)
    
    # Codificar token
    encoded_jwt = jwt.encode(
        to_encode,
        settings.SECRET_KEY,
        algorithm=settings.ALGORITHM,
    )
    
    return encoded_jwt


def create_refresh_token(
    subject: Union[str, Any],
    expires_delta: Optional[timedelta] = None,
) -> str:
    """
    Cria um token de refresh JWT.
    
    Args:
        subject: Identificador do usuário
        expires_delta: Tempo de expiração customizado
        
    Returns:
        str: Token JWT de refresh
        
    Example:
        >>> refresh_token = create_refresh_token(subject="user_123")
    """
    if expires_delta:
        expire = datetime.utcnow() + expires_delta
    else:
        expire = datetime.utcnow() + timedelta(
            days=settings.REFRESH_TOKEN_EXPIRE_DAYS
        )
    
    to_encode = {
        "exp": expire,
        "sub": str(subject),
        "iat": datetime.utcnow(),
        "type": "refresh",
    }
    
    encoded_jwt = jwt.encode(
        to_encode,
        settings.SECRET_KEY,
        algorithm=settings.ALGORITHM,
    )
    
    return encoded_jwt


def create_email_verification_token(email: str) -> str:
    """
    Cria token para verificação de email.
    
    Args:
        email: Email para verificar
        
    Returns:
        str: Token JWT de verificação
    """
    expire = datetime.utcnow() + timedelta(hours=24)
    
    to_encode = {
        "exp": expire,
        "sub": email,
        "type": "email_verification",
    }
    
    encoded_jwt = jwt.encode(
        to_encode,
        settings.SECRET_KEY,
        algorithm=settings.ALGORITHM,
    )
    
    return encoded_jwt


def create_password_reset_token(email: str) -> str:
    """
    Cria token para reset de senha.
    
    Args:
        email: Email do usuário
        
    Returns:
        str: Token JWT de reset
    """
    expire = datetime.utcnow() + timedelta(hours=1)
    
    to_encode = {
        "exp": expire,
        "sub": email,
        "type": "password_reset",
    }
    
    encoded_jwt = jwt.encode(
        to_encode,
        settings.SECRET_KEY,
        algorithm=settings.ALGORITHM,
    )
    
    return encoded_jwt


# ==================== VALIDAÇÃO DE TOKENS ====================

def decode_token(token: str) -> Dict[str, Any]:
    """
    Decodifica e valida um token JWT.
    
    Args:
        token: Token JWT para decodificar
        
    Returns:
        Dict[str, Any]: Payload do token
        
    Raises:
        HTTPException: Se token inválido ou expirado
        
    Example:
        >>> token = create_access_token(subject="user_123")
        >>> payload = decode_token(token)
        >>> print(payload["sub"])
        user_123
    """
    credentials_exception = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Não foi possível validar as credenciais",
        headers={"WWW-Authenticate": "Bearer"},
    )
    
    try:
        payload = jwt.decode(
            token,
            settings.SECRET_KEY,
            algorithms=[settings.ALGORITHM],
        )
        return payload
        
    except jwt.ExpiredSignatureError:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Token expirado",
            headers={"WWW-Authenticate": "Bearer"},
        )
    except jwt.JWTClaimsError:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Claims do token inválidos",
            headers={"WWW-Authenticate": "Bearer"},
        )
    except JWTError:
        raise credentials_exception


def verify_token_type(payload: Dict[str, Any], expected_type: str) -> None:
    """
    Verifica se o token é do tipo esperado.
    
    Args:
        payload: Payload decodificado do token
        expected_type: Tipo esperado (access, refresh, etc)
        
    Raises:
        HTTPException: Se o tipo não corresponder
    """
    token_type = payload.get("type")
    if token_type != expected_type:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail=f"Token inválido. Esperado tipo '{expected_type}', recebido '{token_type}'",
        )


def extract_user_id_from_token(token: str) -> str:
    """
    Extrai o ID do usuário de um token de acesso.
    
    Args:
        token: Token JWT
        
    Returns:
        str: ID do usuário
        
    Raises:
        HTTPException: Se token inválido
    """
    payload = decode_token(token)
    verify_token_type(payload, "access")
    
    user_id = payload.get("sub")
    if user_id is None:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Token inválido: subject não encontrado",
        )
    
    return user_id


# ==================== PERMISSÕES E ROLES ====================

class Permission:
    """
    Classe para definir permissões do sistema.
    """
    # Permissões de usuário
    USER_READ = "user:read"
    USER_WRITE = "user:write"
    USER_DELETE = "user:delete"
    
    # Permissões de admin
    ADMIN_READ = "admin:read"
    ADMIN_WRITE = "admin:write"
    ADMIN_DELETE = "admin:delete"
    
    # Permissões de conteúdo
    CONTENT_CREATE = "content:create"
    CONTENT_UPDATE = "content:update"
    CONTENT_DELETE = "content:delete"
    CONTENT_PUBLISH = "content:publish"


# Mapeamento de roles para permissões
ROLE_PERMISSIONS: Dict[str, list[str]] = {
    "user": [
        Permission.USER_READ,
        Permission.CONTENT_CREATE,
    ],
    "moderator": [
        Permission.USER_READ,
        Permission.USER_WRITE,
        Permission.CONTENT_CREATE,
        Permission.CONTENT_UPDATE,
        Permission.CONTENT_DELETE,
        Permission.CONTENT_PUBLISH,
    ],
    "admin": [
        Permission.USER_READ,
        Permission.USER_WRITE,
        Permission.USER_DELETE,
        Permission.ADMIN_READ,
        Permission.ADMIN_WRITE,
        Permission.ADMIN_DELETE,
        Permission.CONTENT_CREATE,
        Permission.CONTENT_UPDATE,
        Permission.CONTENT_DELETE,
        Permission.CONTENT_PUBLISH,
    ],
}


def get_permissions_for_role(role: str) -> list[str]:
    """
    Obtém todas as permissões para uma role.
    
    Args:
        role: Nome da role
        
    Returns:
        list[str]: Lista de permissões
    """
    return ROLE_PERMISSIONS.get(role, [])


def has_permission(user_role: str, required_permission: str) -> bool:
    """
    Verifica se uma role tem uma permissão específica.
    
    Args:
        user_role: Role do usuário
        required_permission: Permissão necessária
        
    Returns:
        bool: True se tem a permissão
        
    Example:
        >>> has_permission("admin", Permission.USER_DELETE)
        True
        >>> has_permission("user", Permission.USER_DELETE)
        False
    """
    user_permissions = get_permissions_for_role(user_role)
    return required_permission in user_permissions


# ==================== API KEY MANAGEMENT ====================

import secrets


def generate_api_key(length: int = 32) -> str:
    """
    Gera uma API key segura.
    
    Args:
        length: Comprimento da chave em bytes
        
    Returns:
        str: API key em formato hexadecimal
        
    Example:
        >>> api_key = generate_api_key()
        >>> print(len(api_key))
        64
    """
    return secrets.token_hex(length)


def hash_api_key(api_key: str) -> str:
    """
    Cria hash de API key para armazenamento seguro.
    
    Args:
        api_key: API key em texto plano
        
    Returns:
        str: Hash da API key
    """
    import hashlib
    return hashlib.sha256(api_key.encode()).hexdigest()


def verify_api_key(plain_key: str, hashed_key: str) -> bool:
    """
    Verifica se API key corresponde ao hash.
    
    Args:
        plain_key: API key em texto plano
        hashed_key: Hash armazenado
        
    Returns:
        bool: True se a key está correta
    """
    return hash_api_key(plain_key) == hashed_key


# ==================== RATE LIMITING ====================

from typing import Dict
from datetime import datetime


class TokenBucket:
    """
    Implementação de Token Bucket para rate limiting.
    """
    
    def __init__(self, capacity: int, refill_rate: float):
        """
        Args:
            capacity: Número máximo de tokens
            refill_rate: Tokens adicionados por segundo
        """
        self.capacity = capacity
        self.refill_rate = refill_rate
        self.tokens = capacity
        self.last_refill = datetime.utcnow()
    
    def consume(self, tokens: int = 1) -> bool:
        """
        Tenta consumir tokens do bucket.
        
        Args:
            tokens: Número de tokens a consumir
            
        Returns:
            bool: True se foi possível consumir
        """
        self._refill()
        
        if self.tokens >= tokens:
            self.tokens -= tokens
            return True
        
        return False
    
    def _refill(self) -> None:
        """Reabastece o bucket baseado no tempo decorrido."""
        now = datetime.utcnow()
        elapsed = (now - self.last_refill).total_seconds()
        tokens_to_add = elapsed * self.refill_rate
        
        self.tokens = min(self.capacity, self.tokens + tokens_to_add)
        self.last_refill = now


# ==================== SECURITY UTILITIES ====================

def constant_time_compare(val1: str, val2: str) -> bool:
    """
    Compara duas strings em tempo constante para prevenir timing attacks.
    
    Args:
        val1: Primeira string
        val2: Segunda string
        
    Returns:
        bool: True se são iguais
    """
    import hmac
    return hmac.compare_digest(val1, val2)


def generate_secure_random_string(length: int = 32) -> str:
    """
    Gera string aleatória criptograficamente segura.
    
    Args:
        length: Tamanho da string
        
    Returns:
        str: String aleatória
    """
    return secrets.token_urlsafe(length)


def mask_sensitive_data(data: str, visible_chars: int = 4) -> str:
    """
    Mascara dados sensíveis para logs ou exibição.
    
    Args:
        data: Dados a mascarar
        visible_chars: Número de caracteres visíveis no final
        
    Returns:
        str: Dados mascarados
        
    Example:
        >>> mask_sensitive_data("1234567890123456")
        '************3456'
    """
    if len(data) <= visible_chars:
        return "*" * len(data)
    
    masked_length = len(data) - visible_chars
    return "*" * masked_length + data[-visible_chars:]
