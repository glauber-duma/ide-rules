        password = "correct_password"
        hashed = hash_password(password)
        
        assert verify_password(password, hashed) is True
    
    def test_verify_password_failure(self):
        """Verificação de senha incorreta deve retornar False."""
        password = "correct_password"
        wrong_password = "wrong_password"
        hashed = hash_password(password)
        
        assert verify_password(wrong_password, hashed) is False
    
    def test_verify_password_with_invalid_hash(self):
        """Verificação com hash inválido deve retornar False."""
        password = "test_password"
        invalid_hash = "invalid_hash_string"
        
        assert verify_password(password, invalid_hash) is False


# ==================== TESTES DE JWT ====================

class TestJWTTokens:
    """Testes de geração e validação de JWT."""
    
    def test_create_access_token(self):
        """Token de acesso deve ser criado corretamente."""
        user_id = "user_123"
        token = create_access_token(subject=user_id)
        
        assert token is not None
        assert isinstance(token, str)
        assert len(token) > 0
    
    def test_decode_valid_token(self):
        """Token válido deve ser decodificado corretamente."""
        user_id = "user_123"
        token = create_access_token(subject=user_id)
        
        payload = decode_token(token)
        
        assert payload["sub"] == user_id
        assert payload["type"] == "access"
        assert "exp" in payload
        assert "iat" in payload
    
    def test_decode_expired_token(self):
        """Token expirado deve retornar erro."""
        user_id = "user_123"
        token = create_access_token(
            subject=user_id,
            expires_delta=timedelta(seconds=-1)  # Já expirado
        )
        
        with pytest.raises(Exception) as exc_info:
            decode_token(token)
        
        assert "expirado" in str(exc_info.value.detail).lower()
    
    def test_decode_invalid_token(self):
        """Token inválido deve retornar erro."""
        invalid_token = "invalid.token.here"
        
        with pytest.raises(Exception):
            decode_token(invalid_token)
    
    def test_decode_tampered_token(self):
        """Token modificado deve ser rejeitado."""
        user_id = "user_123"
        token = create_access_token(subject=user_id)
        
        # Modificar token
        parts = token.split(".")
        tampered_token = f"{parts[0]}.{parts[1][:-1]}X.{parts[2]}"
        
        with pytest.raises(Exception):
            decode_token(tampered_token)
    
    def test_refresh_token_creation(self):
        """Token de refresh deve ser criado com tempo de expiração correto."""
        user_id = "user_123"
        token = create_refresh_token(subject=user_id)
        
        payload = jwt.decode(
            token,
            settings.SECRET_KEY,
            algorithms=[settings.ALGORITHM],
        )
        
        assert payload["type"] == "refresh"
        assert payload["sub"] == user_id


