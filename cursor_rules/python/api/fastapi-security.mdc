# src/app/api/middlewares/security.py
"""
Middleware de segurança para adicionar headers de proteção
e implementar políticas de segurança.
"""

from typing import Callable

from fastapi import Request, Response
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.types import ASGIApp


class SecurityHeadersMiddleware(BaseHTTPMiddleware):
    """
    Middleware que adiciona headers de segurança às respostas.
    
    Headers implementados:
    - X-Content-Type-Options: Previne MIME type sniffing
    - X-Frame-Options: Previne clickjacking
    - X-XSS-Protection: Proteção XSS (legacy)
    - Content-Security-Policy: Política de segurança de conteúdo
    - Strict-Transport-Security: Force HTTPS
    - Referrer-Policy: Controla informações de referrer
    - Permissions-Policy: Controla features do browser
    """
    
    def __init__(
        self,
        app: ASGIApp,
        enable_hsts: bool = True,
        hsts_max_age: int = 31536000,  # 1 ano
        hsts_include_subdomains: bool = True,
        hsts_preload: bool = False,
    ):
        """
        Args:
            app: Aplicação ASGI
            enable_hsts: Habilitar HSTS
            hsts_max_age: Tempo de cache HSTS em segundos
            hsts_include_subdomains: Incluir subdomínios no HSTS
            hsts_preload: Habilitar HSTS preload
        """
        super().__init__(app)
        self.enable_hsts = enable_hsts
        self.hsts_max_age = hsts_max_age
        self.hsts_include_subdomains = hsts_include_subdomains
        self.hsts_preload = hsts_preload
    
    async def dispatch(
        self,
        request: Request,
        call_next: Callable,
    ) -> Response:
        """Adiciona headers de segurança à resposta."""
        response = await call_next(request)
        
        # Prevenir MIME type sniffing
        response.headers["X-Content-Type-Options"] = "nosniff"
        
        # Prevenir clickjacking
        response.headers["X-Frame-Options"] = "DENY"
        
        # Proteção XSS (navegadores antigos)
        response.headers["X-XSS-Protection"] = "1; mode=block"
        
        # Content Security Policy
        csp_directives = [
            "default-src 'self'",
            "script-src 'self' 'unsafe-inline' 'unsafe-eval'",
            "style-src 'self' 'unsafe-inline'",
            "img-src 'self' data: https:",
            "font-src 'self' data:",
            "connect-src 'self'",
            "frame-ancestors 'none'",
            "base-uri 'self'",
            "form-action 'self'",
        ]
        response.headers["Content-Security-Policy"] = "; ".join(csp_directives)
        
        # HSTS - Force HTTPS
        if self.enable_hsts:
            hsts_value = f"max-age={self.hsts_max_age}"
            if self.hsts_include_subdomains:
                hsts_value += "; includeSubDomains"
            if self.hsts_preload:
                hsts_value += "; preload"
            response.headers["Strict-Transport-Security"] = hsts_value
        
        # Referrer Policy
        response.headers["Referrer-Policy"] = "strict-origin-when-cross-origin"
        
        # Permissions Policy (Feature Policy)
        permissions_directives = [
            "accelerometer=()",
            "camera=()",
            "geolocation=()",
            "gyroscope=()",
            "magnetometer=()",
            "microphone=()",
            "payment=()",
            "usb=()",
        ]
        response.headers["Permissions-Policy"] = ", ".join(permissions_directives)
        
        # Remover header que expõe tecnologia
        response.headers.pop("Server", None)
        
        return response


class RateLimitMiddleware(BaseHTTPMiddleware):
    """
    Middleware de rate limiting baseado em IP.
    """
    
    def __init__(
        self,
        app: ASGIApp,
        requests_per_minute: int = 60,
        requests_per_hour: int = 1000,
    ):
        """
        Args:
            app: Aplicação ASGI
            requests_per_minute: Requisições permitidas por minuto
            requests_per_hour: Requisições permitidas por hora
        """
        super().__init__(app)
        self.requests_per_minute = requests_per_minute
        self.requests_per_hour = requests_per_hour
        self.ip_requests: dict = {}
    
    async def dispatch(
        self,
        request: Request,
        call_next: Callable,
    ) -> Response:
        """Verifica e aplica rate limiting."""
        from datetime import datetime, timedelta
        
        # Obter IP do cliente
        client_ip = request.client.host
        
        # Inicializar tracking para este IP
        if client_ip not in self.ip_requests:
            self.ip_requests[client_ip] = {
                "minute": [],
                "hour": [],
            }
        
        now = datetime.utcnow()
        
        # Limpar requests antigos
        minute_ago = now - timedelta(minutes=1)
        hour_ago = now - timedelta(hours=1)
        
        self.ip_requests[client_ip]["minute"] = [
            req_time for req_time in self.ip_requests[client_ip]["minute"]
            if req_time > minute_ago
        ]
        
        self.ip_requests[client_ip]["hour"] = [
            req_time for req_time in self.ip_requests[client_ip]["hour"]
            if req_time > hour_ago
        ]
        
        # Verificar limites
        minute_count = len(self.ip_requests[client_ip]["minute"])
        hour_count = len(self.ip_requests[client_ip]["hour"])
        
        if minute_count >= self.requests_per_minute:
            from fastapi.responses import JSONResponse
            return JSONResponse(
                status_code=429,
                content={
                    "error": {
                        "code": 429,
                        "message": "Muitas requisições. Tente novamente em 1 minuto.",
                        "type": "rate_limit_exceeded",
                    }
                },
                headers={
                    "Retry-After": "60",
                    "X-RateLimit-Limit": str(self.requests_per_minute),
                    "X-RateLimit-Remaining": "0",
                    "X-RateLimit-Reset": str(int((now + timedelta(minutes=1)).timestamp())),
                },
            )
        
        if hour_count >= self.requests_per_hour:
            from fastapi.responses import JSONResponse
            return JSONResponse(
                status_code=429,
                content={
                    "error": {
                        "code": 429,
                        "message": "Limite horário excedido. Tente novamente mais tarde.",
                        "type": "rate_limit_exceeded",
                    }
                },
                headers={
                    "Retry-After": "3600",
                    "X-RateLimit-Limit": str(self.requests_per_hour),
                    "X-RateLimit-Remaining": "0",
                },
            )
        
        # Registrar requisição
        self.ip_requests[client_ip]["minute"].append(now)
        self.ip_requests[client_ip]["hour"].append(now)
        
        # Processar request
        response = await call_next(request)
        
        # Adicionar headers de rate limit
        response.headers["X-RateLimit-Limit"] = str(self.requests_per_minute)
        response.headers["X-RateLimit-Remaining"] = str(
            self.requests_per_minute - minute_count - 1
        )
        
        return response


class IPWhitelistMiddleware(BaseHTTPMiddleware):
    """
    Middleware para whitelist de IPs.
    Útil para endpoints administrativos.
    """
    
    def __init__(
        self,
        app: ASGIApp,
        allowed_ips: list[str],
        protected_paths: list[str],
    ):
        """
        Args:
            app: Aplicação ASGI
            allowed_ips: Lista de IPs permitidos
            protected_paths: Lista de paths protegidos
        """
        super().__init__(app)
        self.allowed_ips = set(allowed_ips)
        self.protected_paths = protected_paths
    
    async def dispatch(
        self,
        request: Request,
        call_next: Callable,
    ) -> Response:
        """Verifica whitelist de IP."""
        # Verificar se o path precisa de proteção
        path_protected = any(
            request.url.path.startswith(path)
            for path in self.protected_paths
        )
        
        if path_protected:
            client_ip = request.client.host
            
            if client_ip not in self.allowed_ips:
                from fastapi.responses import JSONResponse
                return JSONResponse(
                    status_code=403,
                    content={
                        "error": {
                            "code": 403,
                            "message": "Acesso negado",
                            "type": "ip_not_allowed",
                        }
                    },
                )
        
        return await call_next(request)


class RequestSizeLimitMiddleware(BaseHTTPMiddleware):
    """
    Middleware para limitar tamanho de requisição.
    Previne ataques de DoS via upload de arquivos grandes.
    """
    
    def __init__(
        self,
        app: ASGIApp,
        max_size: int = 10 * 1024 * 1024,  # 10 MB
    ):
        """
        Args:
            app: Aplicação ASGI
            max_size: Tamanho máximo em bytes
        """
        super().__init__(app)
        self.max_size = max_size
    
    async def dispatch(
        self,
        request: Request,
        call_next: Callable,
    ) -> Response:
        """Verifica tamanho da requisição."""
        content_length = request.headers.get("content-length")
        
        if content_length and int(content_length) > self.max_size:
            from fastapi.responses import JSONResponse
            return JSONResponse(
                status_code=413,
                content={
                    "error": {
                        "code": 413,
                        "message": f"Requisição muito grande. Máximo: {self.max_size / (1024*1024):.2f} MB",
                        "type": "payload_too_large",
                    }
                },
            )
        
        return await call_next(request)
```

