# src/app/core/configs/file_security.py
"""
Validação e segurança para upload de arquivos.
Implementa verificações de tipo, tamanho e conteúdo.
"""

import hashlib
import io
import magic
import os
from pathlib import Path
from typing import BinaryIO, List, Optional

from fastapi import HTTPException, UploadFile, status
from PIL import Image


# ==================== CONFIGURAÇÕES ====================

class FileSecurityConfig:
    """Configurações de segurança para arquivos."""
    
    # Tamanho máximo de arquivo (em bytes)
    MAX_FILE_SIZE = 10 * 1024 * 1024  # 10 MB
    MAX_IMAGE_SIZE = 5 * 1024 * 1024   # 5 MB
    MAX_DOCUMENT_SIZE = 20 * 1024 * 1024  # 20 MB
    
    # Extensões permitidas por categoria
    ALLOWED_IMAGE_EXTENSIONS = {".jpg", ".jpeg", ".png", ".gif", ".webp"}
    ALLOWED_DOCUMENT_EXTENSIONS = {".pdf", ".doc", ".docx", ".txt"}
    ALLOWED_VIDEO_EXTENSIONS = {".mp4", ".avi", ".mov", ".webm"}
    
    # MIME types permitidos
    ALLOWED_IMAGE_MIMES = {
        "image/jpeg",
        "image/png",
        "image/gif",
        "image/webp",
    }
    
    ALLOWED_DOCUMENT_MIMES = {
        "application/pdf",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "text/plain",
    }
    
    # Dimensões máximas para imagens
    MAX_IMAGE_WIDTH = 4096
    MAX_IMAGE_HEIGHT = 4096


# ==================== VALIDADORES DE ARQUIVO ====================

class FileValidator:
    """
    Validador principal para arquivos enviados.
    """
    
    @staticmethod
    async def validate_file_size(
        file: UploadFile,
        max_size: int = FileSecurityConfig.MAX_FILE_SIZE,
    ) -> None:
        """
        Valida o tamanho do arquivo.
        
        Args:
            file: Arquivo para validar
            max_size: Tamanho máximo em bytes
            
        Raises:
            HTTPException: Se arquivo muito grande
        """
        # Ler arquivo em chunks para não carregar tudo na memória
        size = 0
        chunk_size = 1024 * 1024  # 1 MB chunks
        
        while chunk := await file.read(chunk_size):
            size += len(chunk)
            if size > max_size:
                await file.close()
                raise HTTPException(
                    status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,
                    detail=f"Arquivo muito grande. Máximo permitido: {max_size / (1024*1024):.2f} MB",
                )
        
        # Voltar ao início do arquivo
        await file.seek(0)
    
    @staticmethod
    def validate_extension(
        filename: str,
        allowed_extensions: set[str],
    ) -> None:
        """
        Valida a extensão do arquivo.
        
        Args:
            filename: Nome do arquivo
            allowed_extensions: Conjunto de extensões permitidas
            
        Raises:
            HTTPException: Se extensão não permitida
        """
        ext = Path(filename).suffix.lower()
        
        if ext not in allowed_extensions:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"Extensão não permitida. Permitidas: {', '.join(allowed_extensions)}",
            )
    
    @staticmethod
    async def validate_mime_type(
        file: UploadFile,
        allowed_mimes: set[str],
    ) -> str:
        """
        Valida o MIME type real do arquivo (não confia no header).
        
        Args:
            file: Arquivo para validar
            allowed_mimes: Conjunto de MIME types permitidos
            
        Returns:
            str: MIME type detectado
            
        Raises:
            HTTPException: Se MIME type não permitido
        """
        # Ler primeiros bytes para detectar tipo
        header = await file.read(2048)
        await file.seek(0)
        
        # Usar python-magic para detecção real de tipo
        mime = magic.from_buffer(header, mime=True)
        
        if mime not in allowed_mimes:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"Tipo de arquivo não permitido: {mime}",
            )
        
        return mime
    
    @staticmethod
    def sanitize_filename(filename: str) -> str:
        """
        Sanitiza nome do arquivo removendo caracteres perigosos.
        
        Args:
            filename: Nome do arquivo
            
        Returns:
            str: Nome sanitizado
        """
        import re
        import unicodedata
        
        # Normalizar unicode
        filename = unicodedata.normalize("NFKD", filename)
        filename = filename.encode("ascii", "ignore").decode("ascii")
        
        # Remover caracteres especiais exceto ponto, underscore e hífen
        filename = re.sub(r"[^a-zA-Z0-9._-]", "_", filename)
        
        # Limitar tamanho
        name, ext = os.path.splitext(filename)
        if len(name) > 100:
            name = name[:100]
        
        return f"{name}{ext}"
    
    @staticmethod
    async def calculate_file_hash(
        file: UploadFile,
        algorithm: str = "sha256",
    ) -> str:
        """
        Calcula hash do arquivo para detecção de duplicatas.
        
        Args:
            file: Arquivo
            algorithm: Algoritmo de hash (md5, sha256, etc)
            
        Returns:
            str: Hash do arquivo
        """
        hasher = hashlib.new(algorithm)
        
        # Ler em chunks
        while chunk := await file.read(8192):
            hasher.update(chunk)
        
        await file.seek(0)
        
        return hasher.hexdigest()


# ==================== VALIDADOR DE IMAGENS ====================

class ImageValidator:
    """
    Validador específico para imagens.
    """
    
    @staticmethod
    async def validate_image(
        file: UploadFile,
        max_width: int = FileSecurityConfig.MAX_IMAGE_WIDTH,
        max_height: int = FileSecurityConfig.MAX_IMAGE_HEIGHT,
    ) -> tuple[int, int]:
        """
        Valida imagem completa.
        
        Args:
            file: Arquivo de imagem
            max_width: Largura máxima
            max_height: Altura máxima
            
        Returns:
            tuple[int, int]: Dimensões (largura, altura)
            
        Raises:
            HTTPException: Se imagem inválida
        """
        # Validar tamanho
        await FileValidator.validate_file_size(
            file,
            max_size=FileSecurityConfig.MAX_IMAGE_SIZE,
        )
        
        # Validar extensão
        FileValidator.validate_extension(
            file.filename,
            FileSecurityConfig.ALLOWED_IMAGE_EXTENSIONS,
        )
        
        # Validar MIME type
        await FileValidator.validate_mime_type(
            file,
            FileSecurityConfig.ALLOWED_IMAGE_MIMES,
        )
        
        # Validar dimensões e integridade da imagem
        try:
            contents = await file.read()
            image = Image.open(io.BytesIO(contents))
            
            width, height = image.size
            
            if width > max_width or height > max_height:
                raise HTTPException(
                    status_code=status.HTTP_400_BAD_REQUEST,
                    detail=f"Dimensões da imagem excedem o máximo permitido: {max_width}x{max_height}",
                )
            
            # Verificar se é uma imagem válida tentando carregar
            image.verify()
            
            await file.seek(0)
            
            return width, height
            
        except Exception as e:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail=f"Arquivo de imagem inválido: {str(e)}",
            )
    
    @staticmethod
    def strip_exif_data(image_bytes: bytes) -> bytes:
        """
        Remove dados EXIF da imagem (pode conter localização, etc).
        
        Args:
            image_bytes: Bytes da imagem
            
        Returns:
            bytes: Imagem sem EXIF
        """
        image = Image.open(io.BytesIO(image_bytes))
        
        # Remover EXIF data
        data = list(image.getdata())
        image_without_exif = Image.new(image.mode, image.size)
        image_without_exif.putdata(data)
        
        # Converter de volta para bytes
        output = io.BytesIO()
        image_without_exif.save(output, format=image.format)
        
        return output.getvalue()


# ==================== VALIDADOR DE DOCUMENTOS ====================

class DocumentValidator:
    """
