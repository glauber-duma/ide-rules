```

### 🚀 Router Principal

```python
# src/api/v1/router.py
"""Router principal da API v1."""

from fastapi import APIRouter

from src.api.v1.endpoints import auth, users, products

# Criar router principal da v1
api_router = APIRouter(prefix="/v1")

# Incluir routers de cada recurso
api_router.include_router(
    auth.router,
    prefix="/auth",
    tags=["authentication"]
)

api_router.include_router(
    users.router,
    prefix="/users",
    tags=["users"]
)

api_router.include_router(
    products.router,
    prefix="/products",
    tags=["products"]
)
```

## 3. Padrões de Endpoints CRUD

### 👤 **Exemplo completo: User endpoints**

```python
# src/api/v1/endpoints/users.py
"""Endpoints de gerenciamento de usuários."""

from typing import List, Optional
from uuid import UUID

from fastapi import APIRouter, Depends, HTTPException, Query, status
from fastapi.responses import JSONResponse
from sqlalchemy.orm import Session

from src.api import deps
from src.api.v1.schemas.users import (
    UserCreate,
    UserUpdate,
    UserResponse,
    UserListResponse,
    UserDetailResponse
)
from src.api.v1.schemas.common import ErrorResponse, MessageResponse
from src.services.user_service import UserService
from src.core.security import get_current_active_user
from src.models.user import User

router = APIRouter()


@router.get(
    "/",
    response_model=UserListResponse,
    status_code=status.HTTP_200_OK,
    summary="Listar todos os usuários",
    description="Retorna lista paginada de usuários com filtros opcionais",
    responses={
        200: {"description": "Lista de usuários retornada com sucesso"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
        403: {"model": ErrorResponse, "description": "Sem permissão"},
    }
)
async def list_users(
    skip: int = Query(0, ge=0, description="Número de registros a pular"),
    limit: int = Query(100, ge=1, le=1000, description="Número máximo de registros"),
    search: Optional[str] = Query(None, min_length=2, description="Busca por nome ou email"),
    is_active: Optional[bool] = Query(None, description="Filtrar por status ativo"),
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> UserListResponse:
    """
    Lista usuários com paginação e filtros.
    
    - **skip**: Offset para paginação
    - **limit**: Limite de registros retornados
    - **search**: Busca textual em nome e email
    - **is_active**: Filtrar apenas usuários ativos/inativos
    """
    service = UserService(db)
    
    users, total = await service.get_users(
        skip=skip,
        limit=limit,
        search=search,
        is_active=is_active
    )
    
    return UserListResponse(
        data=users,
        total=total,
        skip=skip,
        limit=limit
    )


@router.get(
    "/{user_id}",
    response_model=UserDetailResponse,
    status_code=status.HTTP_200_OK,
    summary="Obter usuário por ID",
    description="Retorna detalhes completos de um usuário específico",
    responses={
        200: {"description": "Usuário encontrado"},
        404: {"model": ErrorResponse, "description": "Usuário não encontrado"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
    }
)
async def get_user(
    user_id: UUID,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> UserDetailResponse:
    """
    Retorna detalhes completos de um usuário pelo ID.
    
    - **user_id**: ID único do usuário (UUID)
    """
    service = UserService(db)
    
    user = await service.get_user_by_id(user_id)
    
    if not user:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Usuário com ID {user_id} não encontrado"
        )
    
    return UserDetailResponse(data=user)


@router.post(
    "/",
    response_model=UserResponse,
    status_code=status.HTTP_201_CREATED,
    summary="Criar novo usuário",
    description="Cria um novo usuário no sistema",
    responses={
        201: {"description": "Usuário criado com sucesso"},
        400: {"model": ErrorResponse, "description": "Dados inválidos"},
        409: {"model": ErrorResponse, "description": "Email já cadastrado"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
    }
)
async def create_user(
    user_data: UserCreate,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> UserResponse:
    """
    Cria um novo usuário.
    
    - **email**: Email único do usuário (validado)
    - **name**: Nome completo do usuário
    - **password**: Senha (mínimo 8 caracteres)
    """
    service = UserService(db)
    
    # Verificar se email já existe
    existing_user = await service.get_user_by_email(user_data.email)
    if existing_user:
        raise HTTPException(
            status_code=status.HTTP_409_CONFLICT,
            detail="Email já cadastrado no sistema"
        )
    
    user = await service.create_user(user_data)
    
    return UserResponse(
        data=user,
        message="Usuário criado com sucesso"
    )


@router.put(
    "/{user_id}",
    response_model=UserResponse,
    status_code=status.HTTP_200_OK,
    summary="Atualizar usuário completo",
    description="Atualiza todos os campos de um usuário (substituição completa)",
    responses={
        200: {"description": "Usuário atualizado com sucesso"},
        404: {"model": ErrorResponse, "description": "Usuário não encontrado"},
        400: {"model": ErrorResponse, "description": "Dados inválidos"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
    }
)
async def update_user(
    user_id: UUID,
    user_data: UserUpdate,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> UserResponse:
    """
    Atualiza completamente um usuário (PUT - substituição total).
    
    - **user_id**: ID do usuário a ser atualizado
    - Todos os campos do UserUpdate devem ser fornecidos
    """
    service = UserService(db)
    
    user = await service.update_user(user_id, user_data)
    
    if not user:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Usuário com ID {user_id} não encontrado"
        )
    
    return UserResponse(
        data=user,
        message="Usuário atualizado com sucesso"
    )


@router.patch(
    "/{user_id}",
    response_model=UserResponse,
    status_code=status.HTTP_200_OK,
    summary="Atualizar usuário parcialmente",
    description="Atualiza campos específicos de um usuário",
    responses={
        200: {"description": "Usuário atualizado com sucesso"},
        404: {"model": ErrorResponse, "description": "Usuário não encontrado"},
        400: {"model": ErrorResponse, "description": "Dados inválidos"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
    }
)
async def partial_update_user(
    user_id: UUID,
    user_data: UserUpdate,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> UserResponse:
    """
    Atualiza parcialmente um usuário (PATCH - atualização parcial).
    
    - **user_id**: ID do usuário a ser atualizado
    - Apenas campos fornecidos serão atualizados
    """
    service = UserService(db)
    
    # exclude_unset=True permite atualização parcial
    user = await service.patch_user(
        user_id, 
        user_data.model_dump(exclude_unset=True)
    )
    
    if not user:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Usuário com ID {user_id} não encontrado"
        )
    
    return UserResponse(
        data=user,
        message="Usuário atualizado com sucesso"
    )


@router.delete(
    "/{user_id}",
    status_code=status.HTTP_204_NO_CONTENT,
    summary="Deletar usuário",
    description="Remove permanentemente um usuário do sistema",
    responses={
        204: {"description": "Usuário deletado com sucesso"},
        404: {"model": ErrorResponse, "description": "Usuário não encontrado"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
        409: {"model": ErrorResponse, "description": "Usuário possui dependências"},
    }
)
async def delete_user(
    user_id: UUID,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> None:
    """
    Deleta permanentemente um usuário.
    
    - **user_id**: ID do usuário a ser deletado
    
    **ATENÇÃO**: Esta operação é irreversível!
    """
    service = UserService(db)
    
    success = await service.delete_user(user_id)
    
    if not success:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Usuário com ID {user_id} não encontrado"
        )
    
    # 204 não retorna body
    return None


@router.post(
    "/{user_id}/activate",
    response_model=MessageResponse,
    status_code=status.HTTP_200_OK,
    summary="Ativar usuário",
    description="Ativa um usuário previamente desativado",
    responses={
        200: {"description": "Usuário ativado com sucesso"},
        404: {"model": ErrorResponse, "description": "Usuário não encontrado"},
        401: {"model": ErrorResponse, "description": "Não autenticado"},
    }
)
async def activate_user(
    user_id: UUID,
    db: Session = Depends(deps.get_db),
    current_user: User = Depends(get_current_active_user)
) -> MessageResponse:
    """
    Ativa um usuário desativado.
    
    - **user_id**: ID do usuário a ser ativado
    """
    service = UserService(db)
    
    success = await service.activate_user(user_id)
    
    if not success:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Usuário com ID {user_id} não encontrado"
        )
    
    return MessageResponse(message="Usuário ativado com sucesso")
```

## 4. Schemas Pydantic

### 📄 **Schemas de usuários**

```python
# src/api/v1/schemas/users.py
"""Schemas Pydantic para usuários."""

from datetime import datetime
from typing import Optional, List
from uuid import UUID

from pydantic import BaseModel, EmailStr, Field, ConfigDict


# Schema base com campos comuns
class UserBase(BaseModel):
    """Schema base para usuário."""
    
    email: EmailStr = Field(
        ...,
        description="Email único do usuário",
        examples=["usuario@example.com"]
    )
    name: str = Field(
        ...,
        min_length=2,
        max_length=100,
        description="Nome completo do usuário",
        examples=["João Silva"]
    )
    is_active: bool = Field(
        default=True,
        description="Indica se o usuário está ativo"
    )


# Schema para criação (entrada)
class UserCreate(UserBase):
    """Schema para criação de usuário."""
    
    password: str = Field(
        ...,
        min_length=8,
        max_length=100,
        description="Senha do usuário (mínimo 8 caracteres)",
        examples=["SenhaForte123!"]
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "email": "novo.usuario@example.com",
                "name": "Novo Usuário",
                "password": "SenhaSegura123!",
                "is_active": True
            }
        }
    )


# Schema para atualização (entrada)
class UserUpdate(BaseModel):
    """Schema para atualização de usuário."""
    
    email: Optional[EmailStr] = Field(
        None,
        description="Novo email do usuário"
    )
    name: Optional[str] = Field(
        None,
        min_length=2,
        max_length=100,
        description="Novo nome do usuário"
    )
    is_active: Optional[bool] = Field(
        None,
        description="Novo status ativo/inativo"
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "name": "Nome Atualizado",
                "is_active": False
            }
        }
    )


# Schema de leitura (saída) - sem campos sensíveis
class UserRead(UserBase):
    """Schema de leitura básico de usuário."""
    
    id: UUID = Field(..., description="ID único do usuário")
    created_at: datetime = Field(..., description="Data de criação")
    updated_at: datetime = Field(..., description="Data da última atualização")
    
    model_config = ConfigDict(
        from_attributes=True,  # Permite conversão de ORM para Pydantic
        json_schema_extra={
            "example": {
                "id": "123e4567-e89b-12d3-a456-426614174000",
                "email": "usuario@example.com",
                "name": "João Silva",
                "is_active": True,
                "created_at": "2026-01-22T10:30:00",
                "updated_at": "2026-01-22T10:30:00"
            }
        }
    )


# Schema detalhado (saída) - com relações e campos adicionais
class UserDetail(UserRead):
    """Schema detalhado de usuário com informações completas."""
    
    last_login: Optional[datetime] = Field(
        None,
        description="Data do último login"
    )
    login_count: int = Field(
        default=0,
        description="Número total de logins"
    )
    # Adicionar outras relações conforme necessário


# Schemas de resposta wrapeados
class UserResponse(BaseModel):
    """Response wrapper para um único usuário."""
    
    data: UserRead
    message: str = Field(default="Operação realizada com sucesso")


class UserDetailResponse(BaseModel):
    """Response wrapper para detalhes de usuário."""
    
    data: UserDetail


class UserListResponse(BaseModel):
    """Response wrapper para lista de usuários com paginação."""
    
    data: List[UserRead]
    total: int = Field(..., description="Total de registros disponíveis")
    skip: int = Field(..., description="Offset aplicado")
    limit: int = Field(..., description="Limite aplicado")
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "data": [
                    {
                        "id": "123e4567-e89b-12d3-a456-426614174000",
                        "email": "usuario1@example.com",
                        "name": "Usuário 1",
                        "is_active": True,
                        "created_at": "2026-01-22T10:30:00",
                        "updated_at": "2026-01-22T10:30:00"
                    }
                ],
                "total": 150,
                "skip": 0,
                "limit": 100
            }
        }
    )
```

### 📄 **Schemas comuns**

```python
# src/api/v1/schemas/common.py
"""Schemas comuns reutilizáveis."""

from typing import Optional, Generic, TypeVar, List, Any
from datetime import datetime

from pydantic import BaseModel, Field, ConfigDict


# Schema genérico para mensagens
class MessageResponse(BaseModel):
    """Response padrão com mensagem."""
    
    message: str = Field(
        ...,
        description="Mensagem descritiva da operação",
        examples=["Operação realizada com sucesso"]
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "message": "Operação realizada com sucesso"
            }
        }
    )


# Schema para erros
class ErrorResponse(BaseModel):
    """Response padrão para erros."""
    
    detail: str = Field(
        ...,
        description="Descrição detalhada do erro",
        examples=["Recurso não encontrado"]
    )
    error_code: Optional[str] = Field(
        None,
        description="Código interno do erro",
        examples=["USER_NOT_FOUND"]
    )
    timestamp: datetime = Field(
        default_factory=datetime.utcnow,
        description="Timestamp do erro"
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "detail": "Recurso não encontrado",
                "error_code": "RESOURCE_NOT_FOUND",
                "timestamp": "2026-01-22T10:30:00"
            }
        }
    )


# Schema para erros de validação
class ValidationErrorResponse(BaseModel):
    """Response para erros de validação."""
    
    detail: List[dict[str, Any]] = Field(
        ...,
        description="Lista de erros de validação"
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "detail": [
                    {
                        "loc": ["body", "email"],
                        "msg": "value is not a valid email address",
                        "type": "value_error.email"
                    }
                ]
            }
        }
    )


# Schema genérico para listas paginadas
DataT = TypeVar('DataT')

class PaginatedResponse(BaseModel, Generic[DataT]):
    """Response genérico para listas paginadas."""
    
    data: List[DataT]
    total: int = Field(..., ge=0, description="Total de registros")
    skip: int = Field(..., ge=0, description="Offset de paginação")
    limit: int = Field(..., ge=1, description="Limite de registros")
    has_next: bool = Field(..., description="Indica se há próxima página")
    has_previous: bool = Field(..., description="Indica se há página anterior")
    
    @property
    def page(self) -> int:
        """Calcula número da página atual."""
        return (self.skip // self.limit) + 1 if self.limit else 1
    
    @property
    def total_pages(self) -> int:
        """Calcula total de páginas."""
        return (self.total + self.limit - 1) // self.limit if self.limit else 1


# Schema para health check
class HealthCheckResponse(BaseModel):
    """Response de health check."""
    
    status: str = Field(..., examples=["healthy"])
    version: str = Field(..., examples=["1.0.0"])
    timestamp: datetime = Field(default_factory=datetime.utcnow)
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "status": "healthy",
                "version": "1.0.0",
                "timestamp": "2026-01-22T10:30:00"
            }
        }
    )


# Schema para operações em lote
class BulkOperationResponse(BaseModel):
    """Response para operações em lote."""
    
    total: int = Field(..., description="Total de operações solicitadas")
    successful: int = Field(..., description="Operações bem-sucedidas")
    failed: int = Field(..., description="Operações falhadas")
    errors: Optional[List[dict]] = Field(
        None,
        description="Lista de erros para operações falhadas"
    )
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "total": 100,
                "successful": 95,
                "failed": 5,
                "errors": [
                    {"id": "123", "error": "Email já existe"}
                ]
            }
        }
    )
```

## 5. Versionamento de API

### ♻️ **Estratégias de Versionamento**

```python
# src/api/main.py
"""Configuração principal da aplicação com versionamento."""

from fastapi import FastAPI, Request, status
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse

from src.api.v1.router import api_router as v1_router
from src.api.v2.router import api_router as v2_router
from src.api.core.exception_handlers import (
    register_exception_handlers,
    validation_exception_handler
)
from src.api.core.config import settings

# Criar aplicação FastAPI
app = FastAPI(
    title=settings.PROJECT_NAME,
    description="API REST com FastAPI seguindo melhores práticas",
    version="1.0.0",
    openapi_url="/api/openapi.json",
    docs_url="/api/docs",
    redoc_url="/api/redoc",
    openapi_tags=[
        {
            "name": "authentication",
            "description": "Operações de autenticação e autorização"
        },
        {
            "name": "users",
            "description": "Operações de gerenciamento de usuários"
        },
        {
            "name": "products",
            "description": "Operações de gerenciamento de produtos"
        }
    ]
)

# Configurar CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=settings.ALLOWED_ORIGINS,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Registrar handlers de exceção
register_exception_handlers(app)

# Incluir routers versionados
app.include_router(v1_router, prefix="/api")
app.include_router(v2_router, prefix="/api")


# Health check endpoint
@app.get(
    "/health",
    status_code=status.HTTP_200_OK,
    tags=["health"],
    summary="Health check",
    description="Verifica saúde da aplicação"
)
async def health_check():
    """Endpoint de health check."""
    return {
        "status": "healthy",
        "version": app.version
    }


# Root endpoint
@app.get(
    "/",
    status_code=status.HTTP_200_OK,
    include_in_schema=False
)
async def root():
    """Endpoint raiz - redireciona para documentação."""
    return {
        "message": "API FastAPI - Acesse /api/docs para documentação",
        "docs": "/api/docs",
        "redoc": "/api/redoc",
        "openapi": "/api/openapi.json"
    }


# Startup event
