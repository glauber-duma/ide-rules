```python
# src/api/core/versioning.py
"""Sistema de versionamento por header."""

from typing import Callable
from fastapi import Request, HTTPException, status
from functools import wraps


def get_api_version(request: Request) -> str:
    """
    Extrai versão da API do header.
    
    Suporta:
    - Header: API-Version: 1
    - Header: Accept: application/vnd.api+json; version=1
    - Default: v1
    """
    # Tentar header API-Version
    version = request.headers.get("API-Version")
    
    if not version:
        # Tentar extrair do Accept header
        accept = request.headers.get("Accept", "")
        if "version=" in accept:
            try:
                version = accept.split("version=")[1].split(";")[0].strip()
            except IndexError:
                version = None
    
    # Default para v1
    return f"v{version}" if version else "v1"


def require_api_version(min_version: int):
    """
    Decorator para exigir versão mínima da API.
    
    Uso:
        @require_api_version(2)
        async def my_endpoint():
            ...
    """
    def decorator(func: Callable):
        @wraps(func)
        async def wrapper(*args, request: Request, **kwargs):
            version_str = get_api_version(request)
            
            try:
                current_version = int(version_str.replace("v", ""))
            except ValueError:
                raise HTTPException(
                    status_code=status.HTTP_400_BAD_REQUEST,
                    detail="Versão da API inválida"
                )
            
            if current_version < min_version:
                raise HTTPException(
                    status_code=status.HTTP_400_BAD_REQUEST,
                    detail=f"Esta operação requer API versão {min_version} ou superior"
                )
            
            return await func(*args, request=request, **kwargs)
        
        return wrapper
    return decorator


def deprecated_endpoint(
    deprecated_in: str,
    removed_in: str,
    alternative: str = None
):
    """
    Decorator para marcar endpoint como deprecated.
    
    Args:
        deprecated_in: Versão em que foi marcado como deprecated
        removed_in: Versão em que será removido
        alternative: Endpoint alternativo sugerido
    
    Uso:
        @deprecated_endpoint(
            deprecated_in="v1",
            removed_in="v3",
            alternative="/api/v2/users"
        )
    """
    def decorator(func: Callable):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            # Adicionar header de warning
            response = await func(*args, **kwargs)
            
            warning_msg = (
                f'299 - "Deprecated in {deprecated_in}, '
                f'will be removed in {removed_in}'
            )
            
            if alternative:
                warning_msg += f'. Use {alternative} instead'
            
            warning_msg += '"'
            
            if hasattr(response, 'headers'):
                response.headers['Warning'] = warning_msg
                response.headers['Sunset'] = removed_in
            
            return response
        
        return wrapper
    return decorator


# Middleware de versionamento
async def version_middleware(request: Request, call_next):
    """
    Middleware que adiciona informação de versão aos headers de resposta.
    """
    version = get_api_version(request)
    
    response = await call_next(request)
    response.headers["API-Version"] = version
    
    return response
```

