│   │       ├── users.py             # Schemas de usuários
│   │       └── products.py          # Schemas de produtos
│   │
│   └── v2/                          # Nova versão da API
│       └── ...
│
├── models/                          # Modelos de domínio/ORM
│   ├── __init__.py
│   └── user.py
│
├── services/                        # Lógica de negócio
