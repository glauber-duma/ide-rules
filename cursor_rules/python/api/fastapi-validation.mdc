### ❌ **DONT`s - Práticas a Evitar**

```Python
# ❌ Não use um schema para tudo
class User(BaseModel):
    id: int
    email: str
    password: str  # Expõe senha em leitura!
    created_at: datetime

# ✅ Separe create, read, update
class UserCreate(BaseModel):
    email: str
    password: str

class UserRead(BaseModel):
    id: int
    email: str
    created_at: datetime  # Sem password


# ❌ Não ignore validação de entrada
@app.post("/items")
async def create_item(data: dict):  # dict não valida!
    return data

# ✅ Use schema Pydantic
@app.post("/items")
async def create_item(data: ItemCreate):  # Validado automaticamente
    return data


# ❌ Não use valores hardcoded em múltiplos lugares
class UserCreate(BaseModel):
    password: str = Field(..., min_length=8, max_length=100)

class PasswordReset(BaseModel):
    password: str = Field(..., min_length=8, max_length=100)  # Duplicado!

# ✅ Centralize em constantes ou validadores
PASSWORD_MIN_LENGTH = 8
PASSWORD_MAX_LENGTH = 100

class UserCreate(BaseModel):
    password: str = Field(..., min_length=PASSWORD_MIN_LENGTH, max_length=PASSWORD_MAX_LENGTH)


# ❌ Não exponha campos sensíveis
class UserRead(BaseModel):
    id: int
    email: str
    password: str  # NUNCA!
    hashed_password: str  # NUNCA!
    secret_key: str  # NUNCA!

# ✅ Exclua campos sensíveis
class UserRead(BaseModel):
    id: int
    email: str
    # Sem campos sensíveis


# ❌ Não ignore erros de validação
try:
    user = UserCreate(**data)
except ValidationError:
    pass  # Silencioso!

# ✅ Trate e retorne erros apropriadamente
from fastapi import HTTPException

try:
    user = UserCreate(**data)
except ValidationError as e:
    raise HTTPException(
        status_code=422,
        detail=e.errors()
    )


