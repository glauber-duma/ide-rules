class TestPasswordValidator:
    """Testes para validador de senha."""
    
    def test_password_validator_valid(self):
        """Testa senha válida."""
        validator = PasswordValidator()
        result = validator("Str0ng!Password")
        assert result == "Str0ng!Password"
    
    def test_password_validator_too_short(self):
        """Testa senha muito curta."""
        validator = PasswordValidator(min_length=10)
        with pytest.raises(ValueError) as exc_info:
            validator("Short1!")
        assert "pelo menos 10 caracteres" in str(exc_info.value)
    
    def test_password_validator_no_uppercase(self):
        """Testa senha sem maiúscula."""
        validator = PasswordValidator()
        with pytest.raises(ValueError) as exc_info:
            validator("alllower1!")
        assert "maiúscula" in str(exc_info.value)
    
    def test_password_validator_custom_config(self):
        """Testa validador com configuração customizada."""
        validator = PasswordValidator(
            min_length=6,
            require_special=False
        )
        result = validator("Simple1")
        assert result == "Simple1"


