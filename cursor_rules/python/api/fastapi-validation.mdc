# src/api/schemas/async_validators.py
"""
Validadores assíncronos: usar dependências do FastAPI para checagens que requerem I/O.
Pydantic não executa validadores async automaticamente no v1; preferir dependências.
"""
from fastapi import Depends, HTTPException
