# Validadores de domínio específico
def validate_cpf(cpf: str) -> str:
    """Valida CPF brasileiro."""
    cpf_clean = re.sub(r"[^0-9]", "", cpf)
    
    if len(cpf_clean) != 11:
        raise ValueError("CPF deve ter 11 dígitos")
    
    if cpf_clean == cpf_clean[0] * 11:
        raise ValueError("CPF inválido")
    
    # Validação dos dígitos verificadores (simplificado)
    return cpf_clean


def validate_phone_br(phone: str) -> str:
    """Valida telefone brasileiro."""
    phone_clean = re.sub(r"[^0-9]", "", phone)
    
    if len(phone_clean) not in (10, 11):
        raise ValueError("Telefone deve ter 10 ou 11 dígitos (com DDD)")
    
    return phone_clean


def validate_url_safe(value: str) -> str:
    """Valida string segura para URL (slug)."""
    if not re.match(r"^[a-z0-9-]+$", value):
        raise ValueError("Apenas letras minúsculas, números e hífens são permitidos")
    
    if value.startswith("-") or value.endswith("-"):
        raise ValueError("Não pode iniciar ou terminar com hífen")
    
    if "--" in value:
        raise ValueError("Não pode conter hífens consecutivos")
    
