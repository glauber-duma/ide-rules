# src/api/schemas/validators/password_validator.py
"""
Validadores de senhas robusto
"""
import re
from pydantic import validator


def password_rules(password: str):
    if len(password) < 8:
        raise ValueError("Senha deve ter pelo menos 8 caracteres")
    if not re.search(r"[0-9]", password):
        raise ValueError("Senha deve conter números")
    if not re.search(r"[A-Z]", password):
        raise ValueError("Senha deve conter letras maiúsculas")
    return password


