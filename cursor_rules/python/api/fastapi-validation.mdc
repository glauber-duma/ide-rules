# src/api/schemas/serialization.py
"""
Serialização consciente de contexto
"""
from pydantic import BaseModel
from typing import Any, Dict


class ContextSerializer(BaseModel):
    def dict_with_context(self, *, exclude_none=True, context: Dict[str, Any] | None = None):
        data = self.dict(exclude_none=exclude_none)
        # exemplo: esconder campos sensíveis para clientes
        if context and context.get("public"):
            data.pop("internal_notes", None)
        return data

