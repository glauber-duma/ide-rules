from typing import Any, Dict, Set, Optional, Literal
from pydantic import BaseModel, ConfigDict, model_serializer


class ContextAwareSchema(BaseModel):
    """Schema base com serialização consciente de contexto."""
    
    model_config = ConfigDict(from_attributes=True)
    
    def model_dump_context(
        self,
        context: Literal["public", "private", "admin"] = "public",
        **kwargs
    ) -> Dict[str, Any]:
        """Serializa modelo com base no contexto.
        
        Args:
            context: Contexto da serialização
            **kwargs: Argumentos adicionais para model_dump
            
        Returns:
            Dicionário com dados serializados
        """
        exclude_fields = self._get_excluded_fields(context)
        return self.model_dump(exclude=exclude_fields, **kwargs)
    
    def _get_excluded_fields(self, context: str) -> Set[str]:
        """Retorna campos a excluir baseado no contexto."""
        # Override em subclasses
        return set()


class UserContextSchema(ContextAwareSchema):
    """Exemplo de schema com serialização contextual."""
    
    id: int
    email: str
    full_name: str
    is_active: bool
    role: str
    internal_notes: Optional[str] = None
    hashed_password: Optional[str] = None
    salary: Optional[float] = None
    
    def _get_excluded_fields(self, context: str) -> Set[str]:
        """Define campos excluídos por contexto."""
        if context == "public":
            return {"internal_notes", "hashed_password", "salary", "role"}
        elif context == "private":
            return {"hashed_password", "salary"}
        elif context == "admin":
            return {"hashed_password"}
        return set()


