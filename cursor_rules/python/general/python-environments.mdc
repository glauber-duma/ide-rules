# Python - Configuração de Ambientes

## 1. Objetivo

Estabelecer padrões para configuração e gerenciamento de ambientes Python, garantindo:
- **Isolamento completo** entre projetos e dependências
- **Reprodutibilidade** entre ambientes de desenvolvimento, teste e produção
- **Compatibilidade** de versões de Python e bibliotecas
- **Facilidade de Setup** para novos desenvolvedores
- **Portabilidade** entre diferentes máquinas e sistemas operacionais

---

## 2. Estratégias de Gerenciamento

### ⚖️ **Comparação de Ferramentas**

```python
"""
Comparação de ferramentas de gerenciamento de ambientes
"""

# ==== VENV (padrão built-in) ====
# Prós: nativo, simples, universal, leve
# Contras: apenas Python, sem gestão de versão do Python
# Uso: projetos simples, desenvolvimento básico
# Comando: python -m venv .venv

# ==== VIRTUALENV ====
# Prós: mais features que venv, suporta Python 2/3, mais rápido
# Contras: dependência externa
# Uso: projetos que precisam de features extras
# Comando: virtualenv .venv

# ==== PYENV + PYENV-VIRTUALENV ====
# Prós: gerencia múltiplas versões do Python, troca fácil
# Contras: complexidade adicional, apenas Unix-like
# Uso: desenvolvimento com múltiplas versões Python
# Comando: pyenv install 3.11.7 && pyenv virtualenv 3.11.7 myenv

# ==== CONDA/MINICONDA ====
# Prós: gerencia Python + libs nativas (C/C++), cross-platform
# Contras: pesado, pode conflitar com pip
# Uso: data science, dependências não-Python
# Comando: conda create -n myenv python=3.11

# ==== POETRY ====
# Prós: gerencia dependências + ambiente, lock file, publicação
# Contras: curva de aprendizado, opinativo
# Uso: projetos modernos, bibliotecas Python
# Comando: poetry install

# ==== DOCKER ====
# Prós: isolamento total, reprodutível, inclui SO
# Contras: overhead, complexidade
# Uso: produção, CI/CD, ambientes complexos
# Comando: docker-compose up
```

## 3. Configuração com venv (Recomendado Básico)

### 📂 **Estrutura de Projeto**

```bash
# estrutura de projeto com venv
project/
├── .venv/                  # ambiente virtual (não commitar)
├── src/
│   ├── __init__.py
│   ├── main.py
│   └── config/
│       └── settings.py
├── tests/
│   ├── __init__.py
│   ├── conftest.py
│   └── test_main.py
├── docs/
│   └── README.md
├── scripts/
│   ├── setup.sh
│   ├── setup.ps1
│   └── activate.sh
├── requirements/
│   ├── base.txt
│   ├── development.txt
│   └── production.txt
├── .python-version         # versão do Python (pyenv)
├── .env                    # variáveis locais (não commitar)
├── .env.example            # template de variáveis
├── .gitignore
├── Makefile
└── README.md
```

### ⚙️ **Scripts de setup automatizado**

```bash
#!/bin/bash
# scripts/setup.sh - Script para configurar ambiente com venv

set -e  # Para em caso de erro

echo "🐍 FastAPI Project Setup"
echo "======================="

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Verifica versão do Python
REQUIRED_PYTHON="3.11"
PYTHON_VERSION=$(python3 --version 2>&1 | awk '{print $2}' | cut -d'.' -f1,2)

echo -e "${YELLOW}Verificando versão do Python...${NC}"
if [ "$PYTHON_VERSION" != "$REQUIRED_PYTHON" ]; then
    echo -e "${RED}✗ Python $REQUIRED_PYTHON é necessário (encontrado: $PYTHON_VERSION)${NC}"
    exit 1
fi
echo -e "${GREEN}✓ Python $REQUIRED_PYTHON detectado${NC}"

# Cria ambiente virtual se não existir
if [ ! -d ".venv" ]; then
    echo -e "${YELLOW}Criando ambiente virtual...${NC}"
    python3 -m venv .venv
    echo -e "${GREEN}✓ Ambiente virtual criado${NC}"
else
    echo -e "${GREEN}✓ Ambiente virtual já existe${NC}"
fi

# Ativa ambiente virtual
echo -e "${YELLOW}Ativando ambiente virtual...${NC}"
source .venv/bin/activate

# Atualiza pip
echo -e "${YELLOW}Atualizando pip...${NC}"
pip install --upgrade pip setuptools wheel

# Instala dependências
if [ -f "requirements/development.txt" ]; then
    echo -e "${YELLOW}Instalando dependências de desenvolvimento...${NC}"
    pip install -r requirements/development.txt
elif [ -f "requirements.txt" ]; then
    echo -e "${YELLOW}Instalando dependências...${NC}"
    pip install -r requirements.txt
else
    echo -e "${RED}✗ Arquivo requirements não encontrado${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Dependências instaladas${NC}"

# Cria .env se não existir
if [ ! -f ".env" ]; then
    if [ -f ".env.example" ]; then
        echo -e "${YELLOW}Criando arquivo .env...${NC}"
        cp .env.example .env
        echo -e "${GREEN}✓ Arquivo .env criado${NC}"
        echo -e "${YELLOW}⚠️  Configure as variáveis em .env${NC}"
    fi
fi

# Instala pre-commit hooks se disponível
if command -v pre-commit &> /dev/null; then
    echo -e "${YELLOW}Instalando pre-commit hooks...${NC}"
    pre-commit install
    echo -e "${GREEN}✓ Pre-commit hooks instalados${NC}"
fi

echo ""
echo -e "${GREEN}✓ Setup concluído com sucesso!${NC}"
echo ""
echo "Para ativar o ambiente virtual:"
echo "  source .venv/bin/activate"
echo ""
echo "Para executar a aplicação:"
echo "  uvicorn src.main:app --reload"
```

```powershell
# scripts/setup.ps1 - Script para configurar ambiente com venv (Windows)

$ErrorActionPreference = "Stop"

Write-Host "🐍 FastAPI Project Setup" -ForegroundColor Cyan
Write-Host "=======================" -ForegroundColor Cyan

# Verifica versão do Python
$RequiredPython = "3.11"
$PythonVersion = (python --version 2>&1 | Select-String -Pattern "\d+\.\d+").Matches.Value

Write-Host "Verificando versão do Python..." -ForegroundColor Yellow
if ($PythonVersion -ne $RequiredPython) {
    Write-Host "✗ Python $RequiredPython é necessário (encontrado: $PythonVersion)" -ForegroundColor Red
    exit 1
}
Write-Host "✓ Python $RequiredPython detectado" -ForegroundColor Green

# Cria ambiente virtual se não existir
if (-not (Test-Path ".venv")) {
    Write-Host "Criando ambiente virtual..." -ForegroundColor Yellow
    python -m venv .venv
    Write-Host "✓ Ambiente virtual criado" -ForegroundColor Green
} else {
    Write-Host "✓ Ambiente virtual já existe" -ForegroundColor Green
}

# Ativa ambiente virtual
Write-Host "Ativando ambiente virtual..." -ForegroundColor Yellow
.\.venv\Scripts\Activate.ps1

# Atualiza pip
Write-Host "Atualizando pip..." -ForegroundColor Yellow
python -m pip install --upgrade pip setuptools wheel

# Instala dependências
if (Test-Path "requirements/development.txt") {
    Write-Host "Instalando dependências de desenvolvimento..." -ForegroundColor Yellow
    pip install -r requirements/development.txt
} elseif (Test-Path "requirements.txt") {
    Write-Host "Instalando dependências..." -ForegroundColor Yellow
    pip install -r requirements.txt
} else {
    Write-Host "✗ Arquivo requirements não encontrado" -ForegroundColor Red
    exit 1
}

Write-Host "✓ Dependências instaladas" -ForegroundColor Green

# Cria .env se não existir
if (-not (Test-Path ".env")) {
    if (Test-Path ".env.example") {
        Write-Host "Criando arquivo .env..." -ForegroundColor Yellow
        Copy-Item .env.example .env
        Write-Host "✓ Arquivo .env criado" -ForegroundColor Green
        Write-Host "⚠️  Configure as variáveis em .env" -ForegroundColor Yellow
    }
}

# Instala pre-commit hooks se disponível
if (Get-Command pre-commit -ErrorAction SilentlyContinue) {
    Write-Host "Instalando pre-commit hooks..." -ForegroundColor Yellow
    pre-commit install
    Write-Host "✓ Pre-commit hooks instalados" -ForegroundColor Green
}

Write-Host ""
Write-Host "✓ Setup concluído com sucesso!" -ForegroundColor Green
Write-Host ""
Write-Host "Para ativar o ambiente virtual:"
Write-Host "  .\.venv\Scripts\Activate.ps1"
Write-Host ""
Write-Host "Para executar a aplicação:"
Write-Host "  uvicorn src.main:app --reload"
```

### 📋 **Makefile para gerenciamento de ambiente**

```makefile
# Makefile para gerenciamento de ambiente FastAPI

.PHONY: help install install-dev clean test lint format run docker-build docker-up

# Variáveis
PYTHON := python3
VENV := .venv
BIN := $(VENV)/bin
PYTHON_BIN := $(BIN)/python
PIP := $(BIN)/pip

# Comandos

help: ## Mostra esta ajuda
	@echo "FastAPI Project - Comandos disponíveis:"
	@echo ""
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

install: ## Instala dependências de produção
	$(PYTHON) -m venv $(VENV)
	$(PIP) install --upgrade pip setuptools wheel
	$(PIP) install -r requirements/base.txt

install-dev: ## Instala dependências de desenvolvimento
	$(PYTHON) -m venv $(VENV)
	$(PIP) install --upgrade pip setuptools wheel
	$(PIP) install -r requirements/development.txt
	$(BIN)/pre-commit install

clean: ## Remove ambiente virtual e cache
	rm -rf $(VENV)
	find . -type d -name "__pycache__" -exec rm -rf {} +
	find . -type d -name "*.egg-info" -exec rm -rf {} +
	find . -type f -name "*.pyc" -delete
	find . -type f -name "*.pyo" -delete
	rm -rf .pytest_cache
	rm -rf .coverage
	rm -rf htmlcov
	rm -rf dist
	rm -rf build

test: ## Executa testes
	$(BIN)/pytest tests/ -v --cov=src --cov-report=html --cov-report=term

test-fast: ## Executa testes em paralelo
	$(BIN)/pytest tests/ -n auto

lint: ## Executa linters (ruff, mypy)
	$(BIN)/ruff check src/ tests/
	$(BIN)/mypy src/

format: ## Formata código (black, isort)
	$(BIN)/black src/ tests/
	$(BIN)/isort src/ tests/

format-check: ## Verifica formatação sem modificar
	$(BIN)/black --check src/ tests/
	$(BIN)/isort --check-only src/ tests/

run: ## Executa aplicação em modo desenvolvimento
	$(BIN)/uvicorn src.main:app --reload --host 0.0.0.0 --port 8000

run-prod: ## Executa aplicação em modo produção
	$(BIN)/gunicorn src.main:app -w 4 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8000

docker-build: ## Constrói imagem Docker
	docker build -t fastapi-app:latest .

docker-up: ## Sobe containers com docker-compose
	docker-compose up -d

docker-down: ## Para containers
	docker-compose down

docker-logs: ## Mostra logs dos containers
	docker-compose logs -f

migrate: ## Executa migrações do banco
	$(BIN)/alembic upgrade head

migrate-create: ## Cria nova migração
	@read -p "Migration name: " name; \
	$(BIN)/alembic revision --autogenerate -m "$$name"

shell: ## Abre shell Python com contexto da aplicação
	$(BIN)/python

deps-update: ## Atualiza dependências
	$(PIP) install --upgrade pip
	$(PIP) list --outdated

security: ## Executa auditoria de segurança
	$(BIN)/pip-audit
	$(BIN)/bandit -r src/

activate: ## Mostra comando para ativar ambiente
	@echo "Execute: source $(BIN)/activate"
```

