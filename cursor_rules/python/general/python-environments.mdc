```python
# scripts/dev.py
"""Script de desenvolvimento com hot-reload."""
import subprocess
import sys
from pathlib import Path


def check_environment() -> bool:
    """Verifica se ambiente está configurado."""
    venv_path = Path(".venv")
    env_file = Path(".env")
    
    if not venv_path.exists():
        print("❌ Ambiente virtual não encontrado")
        print("   Execute: python -m venv .venv")
        return False
    
    if not env_file.exists():
        print("⚠️  Arquivo .env não encontrado")
        print("   Copiando .env.example...")
        Path(".env.example").read_text()
        env_file.write_text(Path(".env.example").read_text())
    
    return True


def run_dev_server() -> None:
    """Executa servidor de desenvolvimento."""
    if not check_environment():
        sys.exit(1)
    
    print("🚀 Iniciando servidor de desenvolvimento...")
    subprocess.run([
        "uvicorn",
        "src.main:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8000",
        "--log-level", "debug"
    ])


if __name__ == "__main__":
    run_dev_server()
```

