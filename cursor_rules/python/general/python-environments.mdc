### 📋 **Scripts Conda**

```bash
#!/bin/bash
# scripts/setup_conda.sh - Script para configurar ambiente com Conda

set -e

echo "🐍 FastAPI Conda Setup"
echo "====================="

ENV_NAME="fastapi-project"

# Verifica se conda está instalado
if ! command -v conda &> /dev/null; then
    echo "❌ Conda não encontrado. Instale Miniconda ou Anaconda primeiro."
    echo "Download: https://docs.conda.io/en/latest/miniconda.html"
    exit 1
fi

# Remove ambiente existente (opcional)
if conda env list | grep -q "^${ENV_NAME} "; then
    echo "⚠️  Ambiente ${ENV_NAME} já existe. Removendo..."
    conda env remove -n ${ENV_NAME} -y
fi

# Cria ambiente do arquivo
echo "📦 Criando ambiente Conda..."
conda env create -f environment.yml

echo ""
echo "✅ Setup concluído!"
echo ""
echo "Para ativar o ambiente:"
echo "  conda activate ${ENV_NAME}"
echo ""
echo "Para desativar:"
echo "  conda deactivate"
echo ""
echo "Para atualizar o ambiente:"
echo "  conda env update -f environment.yml --prune"
```

## 5. Configuração com Poetry

### 📋 **Poetry Environment Setup**

```bash
#!/bin/bash
# scripts/setup_poetry.sh - Script para configurar ambiente com Poetry

set -e

echo "🐍 FastAPI Poetry Setup"
echo "======================"

# Verifica se Poetry está instalado
if ! command -v poetry &> /dev/null; then
    echo "⚠️  Poetry não encontrado. Instalando..."
    curl -sSL https://install.python-poetry.org | python3 -
    echo "✅ Poetry instalado"
fi

# Configura Poetry para criar venv no projeto
poetry config virtualenvs.in-project true

# Verifica versão do Python
REQUIRED_PYTHON="3.11"
if [ -f ".python-version" ]; then
    REQUIRED_PYTHON=$(cat .python-version)
fi

echo "📌 Versão Python requerida: ${REQUIRED_PYTHON}"

# Instala dependências
echo "📦 Instalando dependências..."
poetry install

# Ativa ambiente
echo "✅ Setup concluído!"
echo ""
echo "Para ativar o ambiente:"
echo "  poetry shell"
echo ""
echo "Para executar comandos sem ativar:"
echo "  poetry run <comando>"
echo ""
echo "Para adicionar dependências:"
echo "  poetry add <pacote>"
```

