## 7. Variáveis de Ambiente

### 🔧 **Gestão de Configuração**

```python
# src/config/settings.py
"""
Configuração centralizada usando pydantic-settings.
"""
from functools import lru_cache
from typing import Literal

from pydantic import Field, PostgresDsn, RedisDsn, field_validator
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """
    Configurações da aplicação.
    
    Variáveis de ambiente são carregadas automaticamente do .env
    e sobrescritas por variáveis de ambiente do sistema.
    """
    
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=False,
        extra="ignore"
    )
    
    # ===== Ambiente =====
    environment: Literal["development", "staging", "production"] = Field(
        default="development",
        description="Ambiente de execução"
    )
    
    debug: bool = Field(
        default=False,
        description="Modo debug"
    )
    
    # ===== Aplicação =====
    app_name: str = Field(
        default="FastAPI Application",
        description="Nome da aplicação"
    )
    
    app_version: str = Field(
        default="0.1.0",
        description="Versão da aplicação"
    )
    
    api_prefix: str = Field(
        default="/api/v1",
        description="Prefixo das rotas da API"
    )
    
    # ===== Servidor =====
    host: str = Field(
        default="0.0.0.0",
        description="Host do servidor"
    )
    
    port: int = Field(
        default=8000,
        description="Porta do servidor",
        ge=1,
        le=65535
    )
    
    workers: int = Field(
        default=4,
        description="Número de workers",
        ge=1
    )
    
    # ===== Database =====
    database_url: PostgresDsn = Field(
        description="URL de conexão do PostgreSQL"
    )
    
    database_pool_size: int = Field(
        default=10,
        description="Tamanho do pool de conexões",
        ge=1
    )
    
    database_max_overflow: int = Field(
        default=20,
        description="Máximo de conexões extras",
        ge=0
    )
    
    # ===== Redis =====
    redis_url: RedisDsn = Field(
        description="URL de conexão do Redis"
    )
    
    redis_ttl: int = Field(
        default=3600,
        description="TTL padrão do cache (segundos)",
        ge=0
    )
    
    # ===== Security =====
    secret_key: str = Field(
        description="Chave secreta para JWT",
        min_length=32
    )
    
    access_token_expire_minutes: int = Field(
        default=30,
        description="Expiração do token de acesso (minutos)",
        ge=1
    )
    
    refresh_token_expire_days: int = Field(
        default=7,
        description="Expiração do token de refresh (dias)",
        ge=1
    )
    
    algorithm: str = Field(
        default="HS256",
        description="Algoritmo de criptografia JWT"
    )
    
    # ===== CORS =====
    cors_origins: list[str] = Field(
        default=["http://localhost:3000"],
        description="Origens permitidas para CORS"
    )
    
    cors_allow_credentials: bool = Field(
        default=True,
        description="Permitir credenciais no CORS"
    )
    
    # ===== Logging =====
    log_level: Literal["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"] = Field(
        default="INFO",
        description="Nível de log"
    )
    
    log_format: Literal["json", "console"] = Field(
        default="console",
        description="Formato do log"
    )
    
    # ===== Monitoring =====
    enable_metrics: bool = Field(
        default=True,
        description="Habilitar métricas Prometheus"
    )
    
    enable_tracing: bool = Field(
        default=False,
        description="Habilitar tracing distribuído"
    )
    
    @field_validator("environment")
    @classmethod
    def validate_environment(cls, v: str) -> str:
        """Valida o ambiente."""
        if v not in ["development", "staging", "production"]:
            raise ValueError("Ambiente inválido")
        return v
    
    @property
    def is_development(self) -> bool:
        """Verifica se é ambiente de desenvolvimento."""
        return self.environment == "development"
    
    @property
    def is_production(self) -> bool:
        """Verifica se é ambiente de produção."""
        return self.environment == "production"


@lru_cache
def get_settings() -> Settings:
    """
    Retorna instância singleton das configurações.
    
    Returns:
        Settings: Configurações da aplicação
    """
    return Settings()


# Instância global
settings = get_settings()
```

