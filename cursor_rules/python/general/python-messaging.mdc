## 3. Event System

### 📡 **Base Event Class**

```python
# src/messaging/events/base.py
"""
Classe base para eventos.
"""
from abc import ABC
from datetime import datetime, timezone
from typing import Any, Dict, Optional
from uuid import UUID, uuid4

from pydantic import BaseModel, Field, ConfigDict


class BaseEvent(BaseModel, ABC):
    """
    Classe base para todos os eventos do sistema.
    
    Attributes:
        event_id: Identificador único do evento
        event_type: Tipo do evento (nome da classe)
        event_version: Versão do schema do evento
        timestamp: Timestamp de criação do evento (UTC)
        correlation_id: ID para correlação entre eventos relacionados
        causation_id: ID do evento que causou este evento
        user_id: ID do usuário que gerou o evento
        metadata: Metadados adicionais do evento
    """
    
    model_config = ConfigDict(
        json_schema_extra={
            "example": {
                "event_id": "123e4567-e89b-12d3-a456-426614174000",
                "event_type": "UserCreated",
                "event_version": "1.0.0",
                "timestamp": "2026-01-27T10:00:00Z",
                "correlation_id": "123e4567-e89b-12d3-a456-426614174001",
                "causation_id": None,
                "user_id": "user-123",
                "metadata": {"source": "api"}
            }
        }
    )
    
    event_id: UUID = Field(
        default_factory=uuid4,
        description="Identificador único do evento"
    )
    
    event_type: str = Field(
        description="Tipo do evento",
        frozen=True
    )
    
    event_version: str = Field(
        default="1.0.0",
        description="Versão do schema do evento",
        pattern=r"^\d+\.\d+\.\d+$"
    )
    
    timestamp: datetime = Field(
        default_factory=lambda: datetime.now(timezone.utc),
        description="Timestamp de criação do evento (UTC)"
    )
    
    correlation_id: Optional[UUID] = Field(
        default=None,
        description="ID para correlação entre eventos relacionados"
    )
    
    causation_id: Optional[UUID] = Field(
        default=None,
        description="ID do evento que causou este evento"
    )
    
    user_id: Optional[str] = Field(
        default=None,
        description="ID do usuário que gerou o evento"
    )
    
    metadata: Dict[str, Any] = Field(
        default_factory=dict,
        description="Metadados adicionais do evento"
    )
    
    def __init__(self, **data):
        """Inicializa o evento com o tipo correto."""
        if "event_type" not in data:
            data["event_type"] = self.__class__.__name__
        super().__init__(**data)
    
    @property
    def routing_key(self) -> str:
        """
        Gera a routing key para o evento.
        
        Returns:
            Routing key no formato: domain.entity.action.version
        """
        parts = self._parse_event_type()
        return f"{parts['domain']}.{parts['entity']}.{parts['action']}.{self.event_version}"
    
    def _parse_event_type(self) -> Dict[str, str]:
        """
        Parse do event_type para extrair componentes.
        
        Returns:
            Dicionário com domain, entity e action
        """
        # Exemplo: UserCreated -> user.created
        import re
        
        # Converte CamelCase para snake_case
        snake_case = re.sub(r'(?<!^)(?=[A-Z])', '_', self.event_type).lower()
        parts = snake_case.split('_')
        
        if len(parts) >= 2:
            entity = parts[0]
            action = '_'.join(parts[1:])
        else:
            entity = "system"
            action = snake_case
        
        return {
            "domain": self.metadata.get("domain", "default"),
            "entity": entity,
            "action": action
        }
    
    def with_correlation(self, correlation_id: UUID) -> "BaseEvent":
        """
        Cria uma cópia do evento com correlation_id.
        
        Args:
            correlation_id: ID de correlação
            
        Returns:
            Nova instância do evento com correlation_id
        """
        return self.model_copy(update={"correlation_id": correlation_id})
    
    def with_causation(self, causation_id: UUID) -> "BaseEvent":
        """
        Cria uma cópia do evento com causation_id.
        
        Args:
            causation_id: ID de causação
            
        Returns:
            Nova instância do evento com causation_id
        """
        return self.model_copy(update={"causation_id": causation_id})
    
    def to_dict(self) -> Dict[str, Any]:
        """
        Converte o evento para dicionário.
        
        Returns:
            Dicionário com os dados do evento
        """
        return self.model_dump(mode="json")
    
    def to_json(self) -> str:
        """
        Converte o evento para JSON.
        
        Returns:
            String JSON com os dados do evento
        """
        return self.model_dump_json()


class DomainEvent(BaseEvent):
    """Evento de domínio do negócio."""
    
    aggregate_id: str = Field(
        description="ID do agregado que gerou o evento"
    )
    
    aggregate_type: str = Field(
        description="Tipo do agregado"
    )
    
    aggregate_version: int = Field(
        default=1,
        description="Versão do agregado",
        ge=1
    )


class IntegrationEvent(BaseEvent):
    """Evento de integração entre serviços."""
    
    source_service: str = Field(
        description="Serviço de origem do evento"
    )
    
    target_services: list[str] = Field(
        default_factory=list,
        description="Serviços destino do evento"
    )


class SystemEvent(BaseEvent):
    """Evento de sistema."""
    
    severity: str = Field(
        default="info",
        description="Severidade do evento (debug, info, warning, error, critical)"
    )
    
    component: str = Field(
        description="Componente que gerou o evento"
    )
```

