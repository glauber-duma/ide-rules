"""
Message serialization.
"""
import json
import logging
from typing import Any, Dict, Type

from .events.base import BaseEvent

logger = logging.getLogger(__name__)


class EventSerializer:
    """Serializador de eventos."""
    
    def __init__(self):
        """Inicializa o serializador."""
        self._event_registry: Dict[str, Type[BaseEvent]] = {}
    
    def register_event_type(
        self,
        event_type: Type[BaseEvent]
    ) -> None:
        """
        Registra um tipo de evento.
        
        Args:
            event_type: Classe do evento
        """
        event_name = event_type.__name__
        self._event_registry[event_name] = event_type
        logger.debug(f"Tipo de evento registrado: {event_name}")
    
    def serialize(self, event: BaseEvent) -> bytes:
        """
        Serializa um evento para bytes.
        
        Args:
            event: Evento a ser serializado
            
        Returns:
            Evento serializado em bytes
        """
        try:
            data = event.model_dump(mode="json")
            json_str = json.dumps(data, ensure_ascii=False)
            return json_str.encode('utf-8')
            
        except Exception as e:
            logger.error(f"Erro ao serializar evento: {e}")
            raise
    
    def deserialize(self, data: bytes) -> BaseEvent:
        """
        Deserializa bytes para um evento.
        
        Args:
            data: Dados serializados
            
        Returns:
            Evento deserializado
        """
        try:
            json_str = data.decode('utf-8')
            event_dict = json.loads(json_str)
            
            # Obtém o tipo do evento
            event_type_name = event_dict.get('event_type')
            if not event_type_name:
                raise ValueError("event_type não encontrado nos dados")
            
            # Busca a classe do evento
            event_class = self._event_registry.get(event_type_name)
            if not event_class:
                # Fallback para BaseEvent
                logger.warning(
                    f"Tipo de evento não registrado: {event_type_name}, "
                    "usando BaseEvent"
                )
                event_class = BaseEvent
            
            # Cria a instância do evento
            return event_class(**event_dict)
            
        except Exception as e:
            logger.error(f"Erro ao deserializar evento: {e}")
            raise
