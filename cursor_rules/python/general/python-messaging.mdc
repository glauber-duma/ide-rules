# ✅ CORRETO: Configuração de DLQ no consumer
class ConsumerWithDLQ:
    """Consumer com suporte a DLQ."""
    
    async def process_message(self, message):
        """Processa mensagem com fallback para DLQ."""
        max_retries = 3
        retry_count = self._get_retry_count(message)
        
        try:
            # Tenta processar
            await self._process(message)
            
        except RecoverableError as e:
            # Erro recuperável - faz retry
            if retry_count < max_retries:
                await self._schedule_retry(message, retry_count + 1)
            else:
                # Máximo de retries atingido - envia para DLQ
                await self._send_to_dlq(message, error=str(e))
            
        except UnrecoverableError as e:
            # Erro não recuperável - envia direto para DLQ
            await self._send_to_dlq(message, error=str(e))
    
    async def _send_to_dlq(self, message, error: str) -> None:
        """Envia mensagem para DLQ com contexto de erro."""
        dlq_message = {
            "original_topic": message.topic,
            "original_message": message.value,
            "error": error,
            "retry_count": self._get_retry_count(message),
            "failed_at": datetime.utcnow().isoformat(),
            "headers": dict(message.headers)
        }
        
        await self._producer.publish(
            event=dlq_message,
            topic=f"{message.topic}.dlq"
        )
