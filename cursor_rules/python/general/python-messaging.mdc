"""
Kafka admin operations.
"""
import logging
from typing import Dict, List, Optional

from aiokafka.admin import AIOKafkaAdminClient, NewTopic
from aiokafka.errors import KafkaError, TopicAlreadyExistsError

from ....core.messaging.config import messaging_settings

logger = logging.getLogger(__name__)


class KafkaAdmin:
    """Operações administrativas do Kafka."""
    
    def __init__(self, bootstrap_servers: Optional[str] = None):
        """
        Inicializa o admin client.
        
        Args:
            bootstrap_servers: Servidores Kafka
        """
        self._bootstrap_servers = (
            bootstrap_servers or messaging_settings.kafka_bootstrap_servers
        )
        self._admin: Optional[AIOKafkaAdminClient] = None
    
    async def connect(self) -> None:
        """Conecta ao Kafka."""
        try:
            self._admin = AIOKafkaAdminClient(
                bootstrap_servers=self._bootstrap_servers,
                security_protocol=messaging_settings.kafka_security_protocol,
                sasl_mechanism=messaging_settings.kafka_sasl_mechanism,
                sasl_plain_username=messaging_settings.kafka_sasl_username,
                sasl_plain_password=messaging_settings.kafka_sasl_password
            )
            await self._admin.start()
            logger.info("Kafka admin conectado")
            
        except KafkaError as e:
            logger.error(f"Erro ao conectar Kafka admin: {e}")
            raise
    
    async def disconnect(self) -> None:
        """Desconecta do Kafka."""
        if self._admin:
            await self._admin.close()
            logger.info("Kafka admin desconectado")
    
    async def create_topic(
        self,
        topic: str,
        partitions: int = 1,
        replication_factor: int = 1,
        config: Optional[Dict[str, str]] = None
    ) -> None:
        """
        Cria um tópico.
        
        Args:
            topic: Nome do tópico
            partitions: Número de partições
            replication_factor: Fator de replicação
            config: Configurações adicionais do tópico
        """
        if not self._admin:
            raise RuntimeError("Admin não está conectado")
        
        try:
            new_topic = NewTopic(
                name=topic,
                num_partitions=partitions,
                replication_factor=replication_factor,
                topic_configs=config or {}
            )
            
            await self._admin.create_topics([new_topic])
            logger.info(
                f"Tópico criado: {topic} "
                f"(partitions={partitions}, replication={replication_factor})"
            )
            
        except TopicAlreadyExistsError:
            logger.warning(f"Tópico já existe: {topic}")
        except KafkaError as e:
            logger.error(f"Erro ao criar tópico {topic}: {e}")
            raise
    
    async def delete_topic(self, topic: str) -> None:
        """
        Deleta um tópico.
        
        Args:
            topic: Nome do tópico
        """
        if not self._admin:
            raise RuntimeError("Admin não está conectado")
        
        try:
            await self._admin.delete_topics([topic])
            logger.info(f"Tópico deletado: {topic}")
            
        except KafkaError as e:
            logger.error(f"Erro ao deletar tópico {topic}: {e}")
            raise
    
    async def list_topics(self) -> List[str]:
        """
        Lista todos os tópicos.
        
        Returns:
            Lista de nomes de tópicos
        """
        if not self._admin:
            raise RuntimeError("Admin não está conectado")
        
        try:
            metadata = await self._admin.list_topics()
            return list(metadata.keys())
            
        except KafkaError as e:
            logger.error(f"Erro ao listar tópicos: {e}")
            raise
    
    async def describe_topic(self, topic: str) -> Dict:
        """
        Descreve um tópico.
        
        Args:
            topic: Nome do tópico
            
        Returns:
            Informações do tópico
        """
        if not self._admin:
            raise RuntimeError("Admin não está conectado")
        
        try:
            metadata = await self._admin.list_topics()
            if topic not in metadata:
                raise ValueError(f"Tópico não encontrado: {topic}")
            
            topic_metadata = metadata[topic]
            return {
                "topic": topic,
                "partitions": len(topic_metadata),
                "partition_info": [
                    {
                        "partition": p.partition,
                        "leader": p.leader,
                        "replicas": p.replicas,
                        "isr": p.isr
                    }
                    for p in topic_metadata
                ]
            }
            
        except KafkaError as e:
            logger.error(f"Erro ao descrever tópico {topic}: {e}")
            raise
