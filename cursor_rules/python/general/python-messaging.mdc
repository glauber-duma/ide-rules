# src/messaging/retry.py
"""
Retry mechanisms.
"""
import asyncio
import logging
import random
from typing import Any, Awaitable, Callable, Optional

from ..core.messaging.config import messaging_settings

logger = logging.getLogger(__name__)


class RetryManager:
    """Gerenciador de retry para processamento de mensagens."""
    
    def __init__(
        self,
        max_attempts: Optional[int] = None,
        initial_delay: Optional[float] = None,
        max_delay: Optional[float] = None,
        exponential_base: Optional[float] = None,
        jitter: Optional[bool] = None
    ):
        """
        Inicializa o retry manager.
        
        Args:
            max_attempts: Número máximo de tentativas
            initial_delay: Delay inicial (segundos)
            max_delay: Delay máximo (segundos)
            exponential_base: Base para cálculo exponencial
            jitter: Se deve adicionar jitter
        """
        self.max_attempts = max_attempts or messaging_settings.retry_max_attempts
        self.initial_delay = initial_delay or messaging_settings.retry_initial_delay
        self.max_delay = max_delay or messaging_settings.retry_max_delay
        self.exponential_base = (
            exponential_base or messaging_settings.retry_exponential_base
        )
        self.jitter = jitter if jitter is not None else messaging_settings.retry_jitter
    
    async def execute_with_retry(
        self,
        func: Callable[..., Awaitable[Any]],
        *args,
        **kwargs
    ) -> Any:
        """
        Executa uma função com retry automático.
        
        Args:
            func: Função assíncrona a ser executada
            *args: Argumentos posicionais
            **kwargs: Argumentos nomeados
            
        Returns:
            Resultado da função
            
        Raises:
            Exception: Se todas as tentativas falharem
        """
        last_exception: Optional[Exception] = None
        
        for attempt in range(1, self.max_attempts + 1):
            try:
                return await func(*args, **kwargs)
                
            except Exception as e:
                last_exception = e
                
                if attempt == self.max_attempts:
                    logger.error(
                        f"Todas as {self.max_attempts} tentativas falharam: {e}"
                    )
                    raise
                
                delay = self._calculate_delay(attempt)
                
                logger.warning(
                    f"Tentativa {attempt}/{self.max_attempts} falhou: {e}. "
                    f"Retrying em {delay:.2f}s..."
                )
                
                await asyncio.sleep(delay)
        
        # Não deveria chegar aqui, mas por segurança
        if last_exception:
            raise last_exception
    
    def _calculate_delay(self, attempt: int) -> float:
        """
        Calcula o delay para uma tentativa.
        
        Args:
            attempt: Número da tentativa
            
        Returns:
            Delay em segundos
        """
        # Exponential backoff
        delay = min(
            self.initial_delay * (self.exponential_base ** (attempt - 1)),
            self.max_delay
        )
        
        # Adiciona jitter se habilitado
        if self.jitter:
            delay = delay * (0.5 + random.random())
        
        return delay


class CircuitBreaker:
    """
    Circuit breaker para proteção contra falhas.
    
    Estados:
    - CLOSED: Normal, requisições passam
    - OPEN: Detectou falhas, bloqueia requisições
    - HALF_OPEN: Testando recuperação
    """
    
    def __init__(
        self,
        failure_threshold: Optional[int] = None,
        timeout: Optional[float] = None,
        recovery_timeout: Optional[float] = None
    ):
        """
        Inicializa o circuit breaker.
        
        Args:
            failure_threshold: Número de falhas para abrir
            timeout: Timeout para bloquear (segundos)
            recovery_timeout: Timeout para tentar recuperação (segundos)
        """
        self.failure_threshold = (
            failure_threshold or 
            messaging_settings.circuit_breaker_failure_threshold
        )
        self.timeout = timeout or messaging_settings.circuit_breaker_timeout
        self.recovery_timeout = (
            recovery_timeout or 
            messaging_settings.circuit_breaker_recovery_timeout
        )
        
        self._failure_count = 0
        self._last_failure_time: Optional[float] = None
        self._state = "CLOSED"
    
    async def call(
        self,
        func: Callable[..., Awaitable[Any]],
        *args,
        **kwargs
    ) -> Any:
        """
        Executa uma função através do circuit breaker.
        
        Args:
            func: Função a ser executada
            *args: Argumentos posicionais
            **kwargs: Argumentos nomeados
            
        Returns:
            Resultado da função
            
        Raises:
            Exception: Se o circuit breaker estiver aberto ou a função falhar
        """
        if self._state == "OPEN":
            if self._should_attempt_reset():
                self._state = "HALF_OPEN"
                logger.info("Circuit breaker: OPEN -> HALF_OPEN")
            else:
                raise Exception("Circuit breaker está OPEN")
        
        try:
            result = await func(*args, **kwargs)
            self._on_success()
            return result
            
        except Exception as e:
            self._on_failure()
            raise
    
    def _on_success(self) -> None:
        """Callback de sucesso."""
        self._failure_count = 0
        
        if self._state == "HALF_OPEN":
            self._state = "CLOSED"
            logger.info("Circuit breaker: HALF_OPEN -> CLOSED")
    
    def _on_failure(self) -> None:
        """Callback de falha."""
        self._failure_count += 1
        self._last_failure_time = asyncio.get_event_loop().time()
        
        if self._failure_count >= self.failure_threshold:
            self._state = "OPEN"
            logger.warning(
                f"Circuit breaker aberto após {self._failure_count} falhas"
            )
    
    def _should_attempt_reset(self) -> bool:
        """Verifica se deve tentar resetar o circuit breaker."""
        if not self._last_failure_time:
            return False
        
        elapsed = asyncio.get_event_loop().time() - self._last_failure_time
        return elapsed >= self.recovery_timeout
