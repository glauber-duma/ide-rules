"""
Handler registry.
"""
import logging
from collections import defaultdict
from typing import Dict, List, Type

from ...messaging.events.base import BaseEvent
from ...messaging.handlers.base import EventHandler

logger = logging.getLogger(__name__)


class HandlerRegistry:
    """
    Registro de handlers de eventos.
    
    Mantém mapeamento entre tipos de eventos e seus handlers.
    """
    
    def __init__(self):
        """Inicializa o registro."""
        self._handlers: Dict[Type[BaseEvent], List[EventHandler]] = defaultdict(list)
    
    def register(self, handler: EventHandler) -> None:
        """
        Registra um handler.
        
        Args:
            handler: Handler a ser registrado
        """
        event_type = handler.event_type
        
        if handler in self._handlers[event_type]:
            logger.warning(f"Handler já registrado: {handler}")
            return
        
        self._handlers[event_type].append(handler)
        logger.info(
            f"Handler registrado: {handler} para evento {event_type.__name__}"
        )
    
    def unregister(self, handler: EventHandler) -> None:
        """
        Remove o registro de um handler.
        
        Args:
            handler: Handler a ser removido
        """
        event_type = handler.event_type
        
        if handler in self._handlers[event_type]:
            self._handlers[event_type].remove(handler)
            logger.info(f"Handler removido: {handler}")
    
    def get_handlers(self, event_type: Type[BaseEvent]) -> List[EventHandler]:
        """
        Retorna os handlers para um tipo de evento.
        
        Args:
            event_type: Tipo do evento
            
        Returns:
            Lista de handlers
        """
        return self._handlers.get(event_type, [])
    
    def clear(self) -> None:
        """Remove todos os handlers."""
        self._handlers.clear()
        logger.info("Registry limpo")
