```python
# ✅ CORRETO: Circuit breaker protegendo chamadas externas
from messaging.retry import CircuitBreaker

class NotificationService:
    """Serviço de notificação com circuit breaker."""
    
    def __init__(self):
        self._circuit_breaker = CircuitBreaker(
            failure_threshold=5,
            timeout=60.0,
            recovery_timeout=30.0
        )
    
    async def send_notification(self, event: BaseEvent) -> None:
        """Envia notificação com proteção de circuit breaker."""
        try:
            await self._circuit_breaker.call(
                self._do_send_notification,
                event
            )
            
        except Exception as e:
            logger.error(
                f"Falha ao enviar notificação: {e}",
                extra={
                    "event_id": str(event.event_id),
                    "circuit_state": self._circuit_breaker._state
                }
            )
            
            # Estratégia de fallback
            await self._fallback_notification(event)
    
    async def _do_send_notification(self, event: BaseEvent) -> None:
        """Implementação real do envio."""
        # Chamada ao serviço externo
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "https://notification-service/send",
                json=event.to_dict(),
                timeout=10.0
            )
            response.raise_for_status()
    
    async def _fallback_notification(self, event: BaseEvent) -> None:
        """Estratégia de fallback quando circuit breaker está aberto."""
        # Exemplo: salva em fila secundária para processamento posterior
        await self._backup_queue.enqueue(event)
        logger.info(f"Notificação enviada para fila de backup: {event.event_id}")
```

### ❌ **DON'Ts - Práticas a Evitar**

#### ❌ Não inclua dados sensíveis em eventos

```python
# ❌ ERRADO: Dados sensíveis expostos
class UserCreated(DomainEvent):
    email: str
    password: str  # ❌ NUNCA inclua senha!
    credit_card: str  # ❌ NUNCA inclua dados de cartão!
    ssn: str  # ❌ NUNCA inclua dados pessoais sensíveis!

# ✅ CORRETO: Apenas referências e dados não sensíveis
class UserCreated(DomainEvent):
    user_id: str
    email: str  # OK se necessário
    username: str
    account_status: str
    # Dados sensíveis ficam apenas no banco de dados
```

#### ❌ Não faça operações síncronas em handlers

```python
# ❌ ERRADO: Operações síncronas bloqueantes
class OrderHandler(EventHandler):
    async def handle(self, event: OrderCreated) -> None:
        # ❌ ERRADO: Operação síncrona bloqueando o event loop
        time.sleep(5)  # Bloqueante!
        
        # ❌ ERRADO: I/O síncrono
        with open('orders.txt', 'a') as f:  # Bloqueante!
            f.write(f"{event.order_id}\n")
        
        # ❌ ERRADO: HTTP síncrono
        import requests
        requests.post("http://api/notify", json=event.to_dict())  # Bloqueante!

# ✅ CORRETO: Operações assíncronas
class OrderHandler(EventHandler):
    async def handle(self, event: OrderCreated) -> None:
        # ✅ CORRETO: Operação assíncrona
        await asyncio.sleep(5)
        
        # ✅ CORRETO: I/O assíncrono
        async with aiofiles.open('orders.txt', 'a') as f:
            await f.write(f"{event.order_id}\n")
        
        # ✅ CORRETO: HTTP assíncrono
        async with httpx.AsyncClient() as client:
            await client.post("http://api/notify", json=event.to_dict())
```

#### ❌ Não ignore falhas silenciosamente

```python
# ❌ ERRADO: Ignorando erros silenciosamente
class BadHandler(EventHandler):
    async def handle(self, event: BaseEvent) -> None:
        try:
            await self._process(event)
        except Exception:
            pass  # ❌ NUNCA ignore erros silenciosamente!

# ✅ CORRETO: Tratamento adequado de erros
class GoodHandler(EventHandler):
    async def handle(self, event: BaseEvent) -> None:
        try:
            await self._process(event)
            
        except ValidationError as e:
            logger.error(
                "Erro de validação ao processar evento",
                extra={
                    "event_id": str(event.event_id),
                    "error": str(e)
                },
                exc_info=True
            )
            # Envia para DLQ - não vale a pena retry
            raise UnrecoverableError(f"Validação falhou: {e}")
            
        except DatabaseError as e:
            logger.warning(
                "Erro temporário de banco de dados",
                extra={"event_id": str(event.event_id)}
            )
            # Erro recuperável - permite retry
            raise RecoverableError(f"DB error: {e}")
            
        except Exception as e:
            logger.exception(
                "Erro inesperado ao processar evento",
                extra={
                    "event_id": str(event.event_id),
                    "event_type": event.event_type
                }
            )
            raise
```

#### ❌ Não crie dependências circulares entre eventos

```python
# ❌ ERRADO: Dependência circular
class UserCreatedHandler(EventHandler):
    async def handle(self, event: UserCreated) -> None:
        # Cria um pedido
        order_event = OrderCreated(...)
        await dispatcher.publish(order_event)  # ❌ Cria Order

class OrderCreatedHandler(EventHandler):
    async def handle(self, event: OrderCreated) -> None:
        # Atualiza o usuário
        user_event = UserUpdated(...)
        await dispatcher.publish(user_event)  # ❌ Atualiza User

# UserCreated -> OrderCreated -> UserUpdated -> OrderUpdated... ❌ Ciclo infinito!

# ✅ CORRETO: Fluxo unidirecional e orquestração
class UserCreatedHandler(EventHandler):
    async def handle(self, event: UserCreated) -> None:
        # Apenas cria recursos necessários, sem dependências circulares
        await self._create_user_profile(event)
        await self._send_welcome_email(event)

class OrderOrchestrator:
    """Orquestrador centralizado para evitar ciclos."""
    
    async def create_order_for_new_user(self, user_id: str) -> None:
        # Orquestra o fluxo completo sem criar ciclos
        order = await self._create_order(user_id)
        await self._process_payment(order)
        await self._notify_user(user_id, order)
```

#### ❌ Não use eventos para operações síncronas críticas

```python
# ❌ ERRADO: Usando eventos para operação síncrona crítica
async def create_order(data: OrderCreate) -> Order:
    # Cria o pedido
    order = await order_repo.create(data)
    
    # ❌ ERRADO: Publica evento e espera processamento para retornar
    event = OrderCreated(order_id=order.id, ...)
    await dispatcher.publish(event)
    
    # ❌ Aguarda processamento assíncrono (pode demorar!)
    await wait_for_order_processing(order.id)
    
    return order  # Cliente fica esperando processos assíncronos

# ✅ CORRETO: Separa operações síncronas das assíncronas
async def create_order(data: OrderCreate) -> Order:
    # Operações síncronas críticas
    order = await order_repo.create(data)
    payment = await payment_service.authorize(order)  # Síncrono
    
    if not payment.authorized:
        raise PaymentError("Pagamento não autorizado")
    
    # Retorna imediatamente para o cliente
    response = Order(
        id=order.id,
        status="pending",
        payment_status=payment.status
    )
    
    # Publica evento para processamento assíncrono posterior
    event = OrderCreated(order_id=order.id, ...)
    await dispatcher.publish(event)  # Fire and forget
    
    return response  # Retorna rápido
```

#### ❌ Não esqueça de versionar eventos

```python
# ❌ ERRADO: Evento sem versão
class ProductUpdated(DomainEvent):
    product_id: str
    name: str
    price: float
    # Sem versionamento!

# Mais tarde adiciona campos...
class ProductUpdated(DomainEvent):  # ❌ Quebra compatibilidade!
    product_id: str
    name: str
    price: float
    stock: int  # Campo novo quebra consumers antigos!

# ✅ CORRETO: Versionamento adequado
class ProductUpdatedV1(DomainEvent):
    """Versão 1 do evento de atualização de produto."""
    
    event_version: str = Field(default="1.0.0")
    
    product_id: str
    name: str
    price: float

class ProductUpdatedV2(DomainEvent):
    """
    Versão 2 do evento de atualização de produto.
    
    Changelog:
    - v2.0.0: Adicionado campo stock
    """
    
    event_version: str = Field(default="2.0.0")
    
    product_id: str
    name: str
    price: float
    stock: int  # Novo campo

# Handler que suporta ambas as versões
class ProductHandler(EventHandler):
    async def handle(self, event: DomainEvent) -> None:
        if event.event_version.startswith("1."):
            await self._handle_v1(event)
        elif event.event_version.startswith("2."):
            await self._handle_v2(event)
        else:
            raise ValueError(f"Versão não suportada: {event.event_version}")
```

