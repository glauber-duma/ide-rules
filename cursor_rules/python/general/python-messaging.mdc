# src/messaging/brokers/kafka/consumer.py
"""
Kafka consumer implementation.
"""
import asyncio
import logging
from typing import Callable, Awaitable, List, Optional

from aiokafka import AIOKafkaConsumer
from aiokafka.errors import KafkaError

from ...interface import MessageConsumer
from ...events.base import BaseEvent
from ...serialization import EventSerializer
from ...monitoring import MetricsCollector
from ...retry import RetryManager
from ....core.messaging.config import messaging_settings

logger = logging.getLogger(__name__)


class KafkaConsumer(MessageConsumer):
    """Implementação de consumer para Kafka."""
    
    def __init__(
        self,
        group_id: str,
        bootstrap_servers: Optional[str] = None,
        client_id: str = "fastapi-consumer",
        serializer: Optional[EventSerializer] = None,
        metrics_collector: Optional[MetricsCollector] = None,
        retry_manager: Optional[RetryManager] = None
    ):
        """
        Inicializa o Kafka consumer.
        
        Args:
            group_id: ID do consumer group
            bootstrap_servers: Servidores Kafka
            client_id: ID do cliente
            serializer: Serializador de eventos
            metrics_collector: Coletor de métricas
            retry_manager: Gerenciador de retries
        """
        self._group_id = group_id
        self._bootstrap_servers = (
            bootstrap_servers or messaging_settings.kafka_bootstrap_servers
        )
        self._client_id = client_id
        self._serializer = serializer or EventSerializer()
        self._metrics = metrics_collector or MetricsCollector()
        self._retry_manager = retry_manager or RetryManager()
        self._consumer: Optional[AIOKafkaConsumer] = None
        self._is_connected = False
        self._is_consuming = False
        self._handler: Optional[Callable[[BaseEvent], Awaitable[None]]] = None
        self._consume_task: Optional[asyncio.Task] = None
    
    async def connect(self) -> None:
        """Conecta ao Kafka."""
        if self._is_connected:
            logger.warning("Consumer já está conectado")
            return
        
        try:
            self._consumer = AIOKafkaConsumer(
                bootstrap_servers=self._bootstrap_servers,
                group_id=self._group_id,
                client_id=self._client_id,
                auto_offset_reset=messaging_settings.kafka_auto_offset_reset,
                enable_auto_commit=False,  # Commit manual para garantir processamento
                session_timeout_ms=30000,
                heartbeat_interval_ms=10000,
                max_poll_records=100,
                security_protocol=messaging_settings.kafka_security_protocol,
                sasl_mechanism=messaging_settings.kafka_sasl_mechanism,
                sasl_plain_username=messaging_settings.kafka_sasl_username,
                sasl_plain_password=messaging_settings.kafka_sasl_password
            )
            
            await self._consumer.start()
            self._is_connected = True
            logger.info(
                f"Kafka consumer conectado: {self._bootstrap_servers} "
                f"(group: {self._group_id})"
            )
            
        except KafkaError as e:
            logger.error(f"Erro ao conectar Kafka consumer: {e}")
            raise
    
    async def disconnect(self) -> None:
        """Desconecta do Kafka."""
        if self._is_consuming:
            await self.stop_consuming()
        
        if not self._is_connected or not self._consumer:
            return
        
        try:
            await self._consumer.stop()
            self._is_connected = False
            logger.info("Kafka consumer desconectado")
            
        except KafkaError as e:
            logger.error(f"Erro ao desconectar Kafka consumer: {e}")
            raise
    
    async def subscribe(
        self,
        topics: List[str],
        handler: Callable[[BaseEvent], Awaitable[None]]
    ) -> None:
        """
        Se inscreve em tópicos.
        
        Args:
            topics: Lista de tópicos
            handler: Função handler para processar mensagens
        """
        if not self._is_connected or not self._consumer:
            raise RuntimeError("Consumer não está conectado")
        
        self._handler = handler
        self._consumer.subscribe(topics=topics)
        
        logger.info(f"Inscrito nos tópicos: {topics}")
    
    async def start_consuming(self) -> None:
        """Inicia o consumo de mensagens."""
        if not self._is_connected or not self._consumer:
            raise RuntimeError("Consumer não está conectado")
        
        if not self._handler:
            raise RuntimeError("Handler não foi configurado")
        
        if self._is_consuming:
            logger.warning("Consumer já está consumindo")
            return
        
        self._is_consuming = True
        self._consume_task = asyncio.create_task(self._consume_loop())
        logger.info("Consumo iniciado")
    
    async def stop_consuming(self) -> None:
        """Para o consumo de mensagens."""
        if not self._is_consuming:
            return
        
        self._is_consuming = False
        
        if self._consume_task:
            self._consume_task.cancel()
            try:
                await self._consume_task
            except asyncio.CancelledError:
                pass
        
        logger.info("Consumo parado")
    
    async def commit(self) -> None:
        """Comita o offset atual."""
        if self._consumer:
            await self._consumer.commit()
    
    async def rollback(self) -> None:
        """Faz rollback do offset."""
        if self._consumer:
            await self._consumer.seek_to_committed()
    
    async def _consume_loop(self) -> None:
        """Loop principal de consumo."""
        logger.info("Iniciando loop de consumo")
        
        try:
            async for message in self._consumer:
                if not self._is_consuming:
                    break
                
                try:
                    await self._process_message(message)
                    await self.commit()
                    
                except Exception as e:
                    logger.error(
                        f"Erro ao processar mensagem: {e}",
                        extra={
                            "topic": message.topic,
                            "partition": message.partition,
                            "offset": message.offset
                        }
                    )
                    # Não faz commit em caso de erro
                    
        except asyncio.CancelledError:
            logger.info("Loop de consumo cancelado")
        except Exception as e:
            logger.error(f"Erro no loop de consumo: {e}")
            raise
    
    async def _process_message(self, message) -> None:
        """Processa uma mensagem individual."""
        start_time = asyncio.get_event_loop().time()
        
        try:
            # Deserializa o evento
            event = self._serializer.deserialize(message.value)
            
            # Extrai headers
            headers = {
                key: value.decode('utf-8') if isinstance(value, bytes) else value
                for key, value in (message.headers or [])
            }
            
            logger.debug(
                f"Processando evento: {event.event_type}",
                extra={
                    "event_id": str(event.event_id),
                    "topic": message.topic,
                    "partition": message.partition,
                    "offset": message.offset
                }
            )
            
            # Processa com retry
            await self._retry_manager.execute_with_retry(
                func=self._handler,
                event=event
            )
            
            # Coleta métricas
            processing_time = asyncio.get_event_loop().time() - start_time
            self._metrics.record_message_processed(
                topic=message.topic,
                event_type=event.event_type,
                processing_time=processing_time
            )
            
        except Exception as e:
            self._metrics.increment_processing_errors(
                topic=message.topic
            )
            
            # Envia para DLQ se habilitado
            if messaging_settings.enable_dlq:
                await self._send_to_dlq(message, error=str(e))
            
            raise
    
    async def _send_to_dlq(self, message, error: str) -> None:
        """Envia mensagem para Dead Letter Queue."""
        dlq_topic = f"{message.topic}{messaging_settings.dlq_topic_suffix}"
        
        try:
            # Importação local para evitar circular dependency
            from .producer import KafkaProducer
            
            producer = KafkaProducer()
            await producer.connect()
            
            # Adiciona informações de erro aos headers
            headers = list(message.headers or [])
            headers.extend([
                ("error", error.encode('utf-8')),
                ("original_topic", message.topic.encode('utf-8')),
                ("original_partition", str(message.partition).encode('utf-8')),
                ("original_offset", str(message.offset).encode('utf-8'))
            ])
            
            # Republica no DLQ
            await producer._producer.send(
                topic=dlq_topic,
                value=message.value,
                key=message.key,
                headers=headers
            )
            
            await producer.disconnect()
            
            logger.warning(
                f"Mensagem enviada para DLQ: {dlq_topic}",
                extra={
                    "original_topic": message.topic,
                    "error": error
                }
            )
            
        except Exception as e:
            logger.error(f"Erro ao enviar mensagem para DLQ: {e}")
