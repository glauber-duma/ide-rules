## 4. Message Interface

### 🔌 **Messaging Interface**

```python
# src/messaging/interface.py
"""
Interface abstrata para messaging.
"""
from abc import ABC, abstractmethod
from typing import Any, Callable, Awaitable, Dict, List, Optional

from .events.base import BaseEvent


class MessageProducer(ABC):
    """Interface abstrata para producers de mensagens."""
    
    @abstractmethod
    async def connect(self) -> None:
        """Conecta ao broker."""
        pass
    
    @abstractmethod
    async def disconnect(self) -> None:
        """Desconecta do broker."""
        pass
    
    @abstractmethod
    async def publish(
        self,
        event: BaseEvent,
        topic: str,
        key: Optional[str] = None,
        headers: Optional[Dict[str, Any]] = None
    ) -> None:
        """
        Publica um evento.
        
        Args:
            event: Evento a ser publicado
            topic: Tópico de destino
            key: Chave da mensagem (para particionamento)
            headers: Headers adicionais
        """
        pass
    
    @abstractmethod
    async def publish_batch(
        self,
        events: List[BaseEvent],
        topic: str
    ) -> None:
        """
        Publica múltiplos eventos em batch.
        
        Args:
            events: Lista de eventos
            topic: Tópico de destino
        """
        pass


class MessageConsumer(ABC):
    """Interface abstrata para consumers de mensagens."""
    
    @abstractmethod
    async def connect(self) -> None:
        """Conecta ao broker."""
        pass
    
    @abstractmethod
    async def disconnect(self) -> None:
        """Desconecta do broker."""
        pass
    
    @abstractmethod
    async def subscribe(
        self,
        topics: List[str],
        handler: Callable[[BaseEvent], Awaitable[None]]
    ) -> None:
        """
        Se inscreve em tópicos.
        
        Args:
            topics: Lista de tópicos
            handler: Função handler para processar mensagens
        """
        pass
    
    @abstractmethod
    async def start_consuming(self) -> None:
        """Inicia o consumo de mensagens."""
        pass
    
    @abstractmethod
    async def stop_consuming(self) -> None:
        """Para o consumo de mensagens."""
        pass
    
    @abstractmethod
    async def commit(self) -> None:
        """Comita o offset atual."""
        pass
    
    @abstractmethod
    async def rollback(self) -> None:
        """Faz rollback do offset."""
        pass


class MessageBroker(ABC):
    """Interface abstrata para broker de mensagens."""
    
    @abstractmethod
    def get_producer(self) -> MessageProducer:
        """Retorna uma instância de producer."""
        pass
    
    @abstractmethod
    def get_consumer(self, group_id: str) -> MessageConsumer:
        """Retorna uma instância de consumer."""
        pass
    
    @abstractmethod
    async def create_topic(
        self,
        topic: str,
        partitions: int = 1,
        replication_factor: int = 1
    ) -> None:
        """Cria um tópico."""
        pass
    
    @abstractmethod
    async def delete_topic(self, topic: str) -> None:
        """Deleta um tópico."""
        pass
    
    @abstractmethod
    async def list_topics(self) -> List[str]:
        """Lista todos os tópicos."""
        pass
    
    @abstractmethod
    async def health_check(self) -> bool:
        """Verifica a saúde do broker."""
        pass
```

## 5. Kafka Implementation

### 🔵 **Kafka Producer**

```python
# src/messaging/brokers/kafka/producer.py
"""
Kafka producer implementation.
"""
import logging
from typing import Any, Dict, List, Optional

from aiokafka import AIOKafkaProducer
from aiokafka.errors import KafkaError

from ...interface import MessageProducer
from ...events.base import BaseEvent
from ...serialization import EventSerializer
from ...monitoring import MetricsCollector
from ....core.messaging.config import messaging_settings

logger = logging.getLogger(__name__)


class KafkaProducer(MessageProducer):
    """Implementação de producer para Kafka."""
    
    def __init__(
        self,
        bootstrap_servers: Optional[str] = None,
        client_id: str = "fastapi-producer",
        serializer: Optional[EventSerializer] = None,
        metrics_collector: Optional[MetricsCollector] = None
    ):
        """
        Inicializa o Kafka producer.
        
        Args:
            bootstrap_servers: Servidores Kafka
            client_id: ID do cliente
            serializer: Serializador de eventos
            metrics_collector: Coletor de métricas
        """
        self._bootstrap_servers = (
            bootstrap_servers or messaging_settings.kafka_bootstrap_servers
        )
        self._client_id = client_id
        self._serializer = serializer or EventSerializer()
        self._metrics = metrics_collector or MetricsCollector()
        self._producer: Optional[AIOKafkaProducer] = None
        self._is_connected = False
    
    async def connect(self) -> None:
        """Conecta ao Kafka."""
        if self._is_connected:
            logger.warning("Producer já está conectado")
            return
        
        try:
            self._producer = AIOKafkaProducer(
                bootstrap_servers=self._bootstrap_servers,
                client_id=self._client_id,
                compression_type=messaging_settings.kafka_compression_type,
                enable_idempotence=messaging_settings.kafka_enable_idempotence,
                max_in_flight_requests_per_connection=(
                    messaging_settings.kafka_max_in_flight_requests
                ),
                acks='all',  # Aguarda confirmação de todas as réplicas
                retries=3,
                request_timeout_ms=30000,
                security_protocol=messaging_settings.kafka_security_protocol,
                sasl_mechanism=messaging_settings.kafka_sasl_mechanism,
                sasl_plain_username=messaging_settings.kafka_sasl_username,
                sasl_plain_password=messaging_settings.kafka_sasl_password
            )
            
            await self._producer.start()
            self._is_connected = True
            logger.info(f"Kafka producer conectado: {self._bootstrap_servers}")
            
        except KafkaError as e:
            logger.error(f"Erro ao conectar Kafka producer: {e}")
            raise
    
    async def disconnect(self) -> None:
        """Desconecta do Kafka."""
        if not self._is_connected or not self._producer:
            return
        
        try:
            await self._producer.stop()
            self._is_connected = False
            logger.info("Kafka producer desconectado")
            
        except KafkaError as e:
            logger.error(f"Erro ao desconectar Kafka producer: {e}")
            raise
    
    async def publish(
        self,
        event: BaseEvent,
        topic: str,
        key: Optional[str] = None,
        headers: Optional[Dict[str, Any]] = None
    ) -> None:
        """
        Publica um evento no Kafka.
        
        Args:
            event: Evento a ser publicado
            topic: Tópico de destino
            key: Chave da mensagem (para particionamento)
            headers: Headers adicionais
        """
        if not self._is_connected or not self._producer:
            raise RuntimeError("Producer não está conectado")
        
        try:
            # Serializa o evento
            value = self._serializer.serialize(event)
            key_bytes = key.encode('utf-8') if key else None
            
            # Prepara headers
            message_headers = self._prepare_headers(event, headers)
            
            # Publica no Kafka
            await self._producer.send(
                topic=topic,
                value=value,
                key=key_bytes,
                headers=message_headers
            )
            
            # Coleta métricas
            self._metrics.increment_published_messages(
                topic=topic,
                event_type=event.event_type
            )
            
            logger.debug(
                f"Evento publicado: {event.event_type} -> {topic}",
                extra={
                    "event_id": str(event.event_id),
                    "topic": topic,
                    "correlation_id": str(event.correlation_id)
                }
            )
            
        except KafkaError as e:
            self._metrics.increment_publish_errors(
                topic=topic,
                event_type=event.event_type
            )
            logger.error(
                f"Erro ao publicar evento: {e}",
                extra={
                    "event_id": str(event.event_id),
                    "topic": topic
                }
            )
            raise
    
    async def publish_batch(
        self,
        events: List[BaseEvent],
        topic: str
    ) -> None:
        """
        Publica múltiplos eventos em batch.
        
        Args:
            events: Lista de eventos
            topic: Tópico de destino
        """
        if not self._is_connected or not self._producer:
            raise RuntimeError("Producer não está conectado")
        
        try:
            batch = self._producer.create_batch()
            
            for event in events:
                value = self._serializer.serialize(event)
                headers = self._prepare_headers(event)
                
                metadata = batch.append(
                    key=None,
                    value=value,
                    timestamp=None,
                    headers=headers
                )
                
                if metadata is None:
                    # Batch cheio, envia e cria novo
                    await self._producer.send_batch(batch, topic)
                    batch = self._producer.create_batch()
                    
                    # Tenta adicionar novamente
                    metadata = batch.append(
                        key=None,
                        value=value,
                        timestamp=None,
                        headers=headers
                    )
            
            # Envia o último batch
            if batch:
                await self._producer.send_batch(batch, topic)
            
            self._metrics.increment_published_messages(
                topic=topic,
                count=len(events)
            )
            
            logger.info(f"Batch de {len(events)} eventos publicado -> {topic}")
            
        except KafkaError as e:
            self._metrics.increment_publish_errors(topic=topic)
            logger.error(f"Erro ao publicar batch: {e}")
            raise
    
    def _prepare_headers(
        self,
        event: BaseEvent,
        additional_headers: Optional[Dict[str, Any]] = None
    ) -> List[tuple[str, bytes]]:
        """Prepara headers da mensagem."""
        headers = [
            ("event_type", event.event_type.encode('utf-8')),
            ("event_version", event.event_version.encode('utf-8')),
            ("event_id", str(event.event_id).encode('utf-8')),
            ("timestamp", event.timestamp.isoformat().encode('utf-8'))
        ]
        
        if event.correlation_id:
            headers.append(
                ("correlation_id", str(event.correlation_id).encode('utf-8'))
            )
        
        if event.causation_id:
            headers.append(
                ("causation_id", str(event.causation_id).encode('utf-8'))
            )
        
        if additional_headers:
            for key, value in additional_headers.items():
                if isinstance(value, str):
                    headers.append((key, value.encode('utf-8')))
                elif isinstance(value, bytes):
                    headers.append((key, value))
        
        return headers
