## 7. Event Dispatcher

### 📩 **Event Publishing and Routing**

```python
# src/core/events/dispatcher.py
"""
Event dispatcher central.
"""
import logging
from typing import Dict, List, Optional, Type

from ...messaging.interface import MessageProducer
from ...messaging.events.base import BaseEvent
from ...messaging.handlers.base import EventHandler
from .registry import HandlerRegistry

logger = logging.getLogger(__name__)


class EventDispatcher:
    """
    Dispatcher central para publicação e roteamento de eventos.
    
    Responsável por:
    - Publicar eventos no broker
    - Rotear eventos para handlers apropriados
    - Gerenciar registro de handlers
    """
    
    def __init__(
        self,
        producer: MessageProducer,
        registry: Optional[HandlerRegistry] = None
    ):
        """
        Inicializa o dispatcher.
        
        Args:
            producer: Producer de mensagens
            registry: Registro de handlers
        """
        self._producer = producer
        self._registry = registry or HandlerRegistry()
        self._topic_mapping: Dict[Type[BaseEvent], str] = {}
    
    def register_handler(self, handler: EventHandler) -> None:
        """
        Registra um handler para um tipo de evento.
        
        Args:
            handler: Handler a ser registrado
        """
        self._registry.register(handler)
        logger.info(f"Handler registrado: {handler}")
    
    def register_handlers(self, handlers: List[EventHandler]) -> None:
        """
        Registra múltiplos handlers.
        
        Args:
            handlers: Lista de handlers
        """
        for handler in handlers:
            self.register_handler(handler)
    
    def map_event_to_topic(
        self,
        event_type: Type[BaseEvent],
        topic: str
    ) -> None:
        """
        Mapeia um tipo de evento para um tópico.
        
        Args:
            event_type: Tipo do evento
            topic: Nome do tópico
        """
        self._topic_mapping[event_type] = topic
        logger.info(f"Mapeamento criado: {event_type.__name__} -> {topic}")
    
    async def publish(
        self,
        event: BaseEvent,
        topic: Optional[str] = None
    ) -> None:
        """
        Publica um evento.
        
        Args:
            event: Evento a ser publicado
            topic: Tópico de destino (opcional, usa mapeamento se não fornecido)
        """
        # Determina o tópico
        if topic is None:
            topic = self._get_topic_for_event(event)
        
        # Usa o aggregate_id como key para particionamento consistente
        key = None
        if hasattr(event, 'aggregate_id'):
            key = event.aggregate_id
        
        try:
            await self._producer.publish(
                event=event,
                topic=topic,
                key=key
            )
            
            logger.info(
                f"Evento publicado: {event.event_type} -> {topic}",
                extra={
                    "event_id": str(event.event_id),
                    "correlation_id": str(event.correlation_id),
                    "topic": topic
                }
            )
            
        except Exception as e:
            logger.error(
                f"Erro ao publicar evento: {e}",
                extra={
                    "event_id": str(event.event_id),
                    "event_type": event.event_type,
                    "topic": topic
                }
            )
            raise
    
    async def dispatch(self, event: BaseEvent) -> None:
        """
        Despacha um evento para os handlers apropriados.
        
        Args:
            event: Evento a ser despachado
        """
        handlers = self._registry.get_handlers(type(event))
        
        if not handlers:
            logger.warning(
                f"Nenhum handler encontrado para evento: {event.event_type}",
                extra={"event_id": str(event.event_id)}
            )
            return
        
        logger.debug(
            f"Despachando evento para {len(handlers)} handler(s): {event.event_type}",
            extra={"event_id": str(event.event_id)}
        )
        
        for handler in handlers:
            try:
                await handler.handle(event)
                
            except Exception as e:
                logger.error(
                    f"Erro no handler {handler}: {e}",
                    extra={
                        "event_id": str(event.event_id),
                        "handler": str(handler)
                    }
                )
                # Continua processando outros handlers
    
    def _get_topic_for_event(self, event: BaseEvent) -> str:
        """
        Determina o tópico para um evento.
        
        Args:
            event: Evento
            
        Returns:
            Nome do tópico
        """
        event_type = type(event)
        
        # Verifica mapeamento explícito
        if event_type in self._topic_mapping:
            return self._topic_mapping[event_type]
        
        # Usa routing key baseada em convenção
        return event.routing_key.replace('.', '-')


