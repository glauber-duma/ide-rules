# src/messaging/handlers/base.py
"""
Base handler para eventos.
"""
import logging
from abc import ABC, abstractmethod
from typing import Type

from ..events.base import BaseEvent

logger = logging.getLogger(__name__)


class EventHandler(ABC):
    """
    Classe base para handlers de eventos.
    
    Cada handler deve processar um tipo específico de evento
    e implementar lógica de negócio correspondente.
    """
    
    @property
    @abstractmethod
    def event_type(self) -> Type[BaseEvent]:
        """Tipo de evento que este handler processa."""
        pass
    
    @abstractmethod
    async def handle(self, event: BaseEvent) -> None:
        """
        Processa o evento.
        
        Args:
            event: Evento a ser processado
            
        Raises:
            Exception: Se houver erro no processamento
        """
        pass
    
    async def on_success(self, event: BaseEvent) -> None:
        """
        Callback executado após processamento bem-sucedido.
        
        Args:
            event: Evento processado
        """
        logger.info(
            f"Evento processado com sucesso: {event.event_type}",
            extra={"event_id": str(event.event_id)}
        )
    
    async def on_error(self, event: BaseEvent, error: Exception) -> None:
        """
        Callback executado após erro no processamento.
        
        Args:
            event: Evento que falhou
            error: Exceção que ocorreu
        """
        logger.error(
            f"Erro ao processar evento: {error}",
            extra={
                "event_id": str(event.event_id),
                "event_type": event.event_type,
                "error": str(error)
            },
            exc_info=True
        )
    
    def __repr__(self) -> str:
        return f"{self.__class__.__name__}(event_type={self.event_type.__name__})"


class IdempotentEventHandler(EventHandler):
    """
    Handler que garante processamento idempotente.
    
    Mantém registro de eventos já processados para evitar duplicação.
    """
    
    def __init__(self):
        self._processed_events: set[str] = set()
    
    async def handle(self, event: BaseEvent) -> None:
        """Processa o evento de forma idempotente."""
        event_id = str(event.event_id)
        
        if event_id in self._processed_events:
            logger.warning(
                f"Evento já processado (ignorando): {event.event_type}",
                extra={"event_id": event_id}
            )
            return
        
        try:
            await self.process(event)
            self._processed_events.add(event_id)
            await self.on_success(event)
            
        except Exception as e:
            await self.on_error(event, e)
            raise
    
    @abstractmethod
    async def process(self, event: BaseEvent) -> None:
        """
        Implementação da lógica de processamento.
        
        Args:
            event: Evento a ser processado
        """
        pass
