## 3. SQLAlchemy com PostgreSQL

### ⚙️ **Setup Assíncrono**

```Python
# src/database/connection.py
"""
Gerenciamento de conexões assíncronas com SQLAlchemy
"""
from typing import AsyncGenerator
from sqlalchemy.ext.asyncio import (
    AsyncSession,
    AsyncEngine,
    create_async_engine,
    async_sessionmaker
)
from sqlalchemy.orm import DeclarativeBase
from sqlalchemy.pool import NullPool, QueuePool
from src.core.config import db_config


class Base(DeclarativeBase):
    """Base class para todos os models SQLAlchemy."""
    pass


class DatabaseManager:
    """Gerenciador centralizado de conexões com banco de dados."""
    
    def __init__(self):
        self._engine: AsyncEngine | None = None
        self._session_factory: async_sessionmaker | None = None
    
    def init(self, database_url: str | None = None, echo: bool = False) -> None:
        """Inicializa engine e session factory.
        
        Args:
            database_url: URL de conexão (padrão: config)
            echo: Habilita logging de queries SQL
        """
        url = database_url or db_config.postgres_url
        
        self._engine = create_async_engine(
            url,
            echo=echo or db_config.DB_ECHO,
            pool_size=db_config.DB_POOL_SIZE,
            max_overflow=db_config.DB_MAX_OVERFLOW,
            pool_recycle=db_config.DB_POOL_RECYCLE,
            poolclass=QueuePool,
            # Configurações adicionais
            pool_pre_ping=True,  # Verifica conexão antes de usar
            connect_args={
                "server_settings": {"jit": "off"}  # Performance para Postgres
            }
        )
        
        self._session_factory = async_sessionmaker(
            self._engine,
            class_=AsyncSession,
            expire_on_commit=False,
            autocommit=False,
            autoflush=False
        )
    
    async def close(self) -> None:
        """Fecha todas as conexões do pool."""
        if self._engine:
            await self._engine.dispose()
    
    async def get_session(self) -> AsyncGenerator[AsyncSession, None]:
        """Fornece sessão de banco de dados.
        
        Yields:
            AsyncSession: Sessão de banco de dados
        """
        if not self._session_factory:
            raise RuntimeError("DatabaseManager não foi inicializado. Chame init() primeiro.")
        
        async with self._session_factory() as session:
            try:
                yield session
            except Exception:
                await session.rollback()
                raise
            finally:
                await session.close()
    
    @property
    def engine(self) -> AsyncEngine:
        """Retorna engine de banco de dados."""
        if not self._engine:
            raise RuntimeError("DatabaseManager não foi inicializado.")
        return self._engine


# Instância global
db_manager = DatabaseManager()


async def init_database():
    """Inicializa banco de dados na startup da aplicação."""
    db_manager.init()
    
    # Cria todas as tabelas (apenas em desenvolvimento)
    # Em produção, use migrations (Alembic)
    # async with db_manager.engine.begin() as conn:
    #     await conn.run_sync(Base.metadata.create_all)


async def close_database():
    """Fecha conexões na shutdown da aplicação."""
    await db_manager.close()

```

### 📄 **Base Models**

```Python
# src/models/base.py
"""
Models base e mixins para SQLAlchemy
"""
from datetime import datetime
from typing import Any
from sqlalchemy import Column, Integer, DateTime, Boolean, String, func
from sqlalchemy.orm import declared_attr
from src.database.connection import Base


class TimestampMixin:
    """Mixin para timestamps automáticos."""
    
    created_at = Column(
        DateTime(timezone=True),
        nullable=False,
        server_default=func.now(),
        comment="Data de criação"
    )
    
    updated_at = Column(
        DateTime(timezone=True),
        nullable=False,
        server_default=func.now(),
        onupdate=func.now(),
        comment="Data de atualização"
    )


class SoftDeleteMixin:
    """Mixin para soft delete."""
    
    deleted_at = Column(
        DateTime(timezone=True),
        nullable=True,
        comment="Data de exclusão (soft delete)"
    )
    
    is_deleted = Column(
        Boolean,
        nullable=False,
        default=False,
        server_default="false",
        comment="Flag de exclusão"
    )
    
    def soft_delete(self):
        """Marca registro como deletado."""
        self.is_deleted = True
        self.deleted_at = datetime.utcnow()
    
    def restore(self):
        """Restaura registro deletado."""
        self.is_deleted = False
        self.deleted_at = None


class AuditMixin:
    """Mixin para auditoria."""
    
    created_by = Column(String(100), nullable=True, comment="Usuário que criou")
    updated_by = Column(String(100), nullable=True, comment="Usuário que atualizou")


class BaseModel(Base, TimestampMixin):
    """Model base com ID e timestamps."""
    
    __abstract__ = True
    
    id = Column(
        Integer,
        primary_key=True,
        autoincrement=True,
        comment="Identificador único"
    )
    
    @declared_attr
    def __tablename__(cls) -> str:
        """Gera nome da tabela automaticamente."""
        return cls.__name__.lower()
    
    def to_dict(self) -> dict[str, Any]:
        """Converte model para dicionário."""
        return {
            column.name: getattr(self, column.name)
            for column in self.__table__.columns
        }
    
    def __repr__(self) -> str:
        """Representação string do model."""
        return f"<{self.__class__.__name__}(id={self.id})>"


