## 6. MongoDB com Motor

### 🍃 **Setup Assíncrono do MongoDB**

```Python
# src/database/mongodb.py
"""
Configuração do MongoDB com Motor (driver assíncrono)
"""
from typing import Optional
from motor.motor_asyncio import AsyncIOMotorClient, AsyncIOMotorDatabase
from pymongo.errors import ConnectionFailure
from src.core.config import db_config
import logging

logger = logging.getLogger(__name__)


class MongoDBManager:
    """Gerenciador de conexões MongoDB."""
    
    def __init__(self):
        self._client: Optional[AsyncIOMotorClient] = None
        self._db: Optional[AsyncIOMotorDatabase] = None
    
    def init(self, mongo_url: str | None = None, db_name: str | None = None):
        """Inicializa cliente MongoDB.
        
        Args:
            mongo_url: URL de conexão MongoDB
            db_name: Nome do banco de dados
        """
        url = mongo_url or db_config.MONGO_URL
        database_name = db_name or db_config.MONGO_DB_NAME
        
        self._client = AsyncIOMotorClient(
            url,
            maxPoolSize=db_config.MONGO_MAX_POOL_SIZE,
            minPoolSize=db_config.MONGO_MIN_POOL_SIZE,
            serverSelectionTimeoutMS=5000,
            connectTimeoutMS=10000,
        )
        
        self._db = self._client[database_name]
        logger.info(f"MongoDB conectado: {database_name}")
    
    @property
    def database(self) -> AsyncIOMotorDatabase:
        """Retorna database MongoDB."""
        if not self._db:
            raise RuntimeError("MongoDB não foi inicializado. Chame init() primeiro.")
        return self._db
    
    @property
    def client(self) -> AsyncIOMotorClient:
        """Retorna cliente MongoDB."""
        if not self._client:
            raise RuntimeError("MongoDB não foi inicializado.")
        return self._client
    
    async def ping(self) -> bool:
        """Verifica conectividade com MongoDB.
        
        Returns:
            bool: True se conectado
        """
        try:
            await self._client.admin.command('ping')
            return True
        except ConnectionFailure:
            return False
    
    async def close(self):
        """Fecha conexão MongoDB."""
        if self._client:
            self._client.close()
            logger.info("MongoDB desconectado")


# Instância global
mongo_manager = MongoDBManager()


async def init_mongodb():
    """Inicializa MongoDB na startup."""
    mongo_manager.init()
    
    # Verifica conectividade
    is_connected = await mongo_manager.ping()
    if not is_connected:
        logger.error("Falha ao conectar com MongoDB")


async def close_mongodb():
    """Fecha MongoDB na shutdown."""
    await mongo_manager.close()


# Repository base para MongoDB
class MongoRepository:
    """Repository base para coleções MongoDB."""
    
    def __init__(self, collection_name: str):
        self.collection_name = collection_name
    
    @property
    def collection(self):
        """Retorna coleção MongoDB."""
        return mongo_manager.database[self.collection_name]
    
    async def create(self, document: dict) -> str:
        """Insere documento.
        
        Args:
            document: Documento a inserir
            
        Returns:
            str: ID do documento inserido
        """
        result = await self.collection.insert_one(document)
        return str(result.inserted_id)
    
    async def find_one(self, filter: dict) -> Optional[dict]:
        """Busca um documento.
        
        Args:
            filter: Filtro de busca
            
        Returns:
            Optional[dict]: Documento encontrado ou None
        """
        return await self.collection.find_one(filter)
    
    async def find_many(self, filter: dict, skip: int = 0, limit: int = 100) -> list[dict]:
        """Busca múltiplos documentos.
        
        Args:
            filter: Filtro de busca
            skip: Documentos a pular
            limit: Limite de documentos
            
        Returns:
            list[dict]: Lista de documentos
        """
        cursor = self.collection.find(filter).skip(skip).limit(limit)
        return await cursor.to_list(length=limit)
    
    async def update_one(self, filter: dict, update: dict) -> bool:
        """Atualiza um documento.
        
        Args:
            filter: Filtro de busca
            update: Operações de update
            
        Returns:
            bool: True se atualizado
        """
        result = await self.collection.update_one(filter, {"$set": update})
        return result.modified_count > 0
    
    async def delete_one(self, filter: dict) -> bool:
        """Remove um documento.
        
        Args:
            filter: Filtro de busca
            
        Returns:
            bool: True se removido
        """
        result = await self.collection.delete_one(filter)
        return result.deleted_count > 0
    
    async def count(self, filter: dict) -> int:
        """Conta documentos.
        
        Args:
            filter: Filtro de busca
            
        Returns:
            int: Número de documentos
        """
        return await self.collection.count_documents(filter)

