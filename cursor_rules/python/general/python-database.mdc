## 7. FastAPI Dependencies

### 📎 **Database Dependencies**

```Python
# src/core/database/deps.py
"""
Dependencies do FastAPI para injeção de dependência de database
"""
from typing import AsyncGenerator
from fastapi import Depends
from sqlalchemy.ext.asyncio import AsyncSession
from src.database.connection import db_manager
from src.repositories.unit_of_work import UnitOfWork
from src.repositories.user_repository import UserRepository


async def get_db_session() -> AsyncGenerator[AsyncSession, None]:
    """Dependency para obter sessão de banco de dados.
    
    Yields:
        AsyncSession: Sessão de banco de dados
        
    Example:
        @app.get("/users/{user_id}")
        async def get_user(
            user_id: int,
            db: AsyncSession = Depends(get_db_session)
        ):
            ...
    """
    async for session in db_manager.get_session():
        yield session


async def get_uow() -> AsyncGenerator[UnitOfWork, None]:
    """Dependency para obter Unit of Work.
    
    Yields:
        UnitOfWork: Instância do Unit of Work
        
    Example:
        @app.post("/users")
        async def create_user(
            data: UserCreate,
            uow: UnitOfWork = Depends(get_uow)
        ):
            async with uow:
                user = await uow.users.create(**data.dict())
                await uow.commit()
                return user
    """
    async with UnitOfWork() as uow:
        yield uow


def get_user_repository(
    session: AsyncSession = Depends(get_db_session)
) -> UserRepository:
    """Dependency para obter UserRepository.
    
    Args:
        session: Sessão de banco de dados
        
    Returns:
        UserRepository: Instância do repository
        
    Example:
        @app.get("/users/{user_id}")
        async def get_user(
            user_id: int,
            repo: UserRepository = Depends(get_user_repository)
        ):
            return await repo.get(user_id)
    """
    return UserRepository(session)


# Exemplo de dependency composta
async def get_current_user_from_db(
    user_id: int,
    repo: UserRepository = Depends(get_user_repository)
):
    """Dependency que busca usuário atual do database.
    
    Args:
        user_id: ID do usuário (extraído do token JWT)
        repo: Repository de usuários
        
    Returns:
        User: Usuário autenticado
        
    Raises:
        HTTPException: Se usuário não encontrado
    """
    from fastapi import HTTPException, status
    
    user = await repo.get(user_id)
    if not user:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Usuário não encontrado"
        )
    
    if not user.is_active:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Usuário inativo"
        )
    
    return user

```

## 8. Boas práticas

### ✅ **DO`s - Práticas Recomendadas**

```Python
# ✅ Use async/await para operações de banco de dados
async def get_user(user_id: int, session: AsyncSession):
    """Sempre use async/await para operações de I/O."""
    stmt = select(User).where(User.id == user_id)
    result = await session.execute(stmt)
    return result.scalar_one_or_none()


# ✅ Implemente soft delete quando apropriado
class User(BaseModel, SoftDeleteMixin):
    pass

async def delete_user(user_id: int, session: AsyncSession):
    """Soft delete preserva dados para auditoria."""
    user = await session.get(User, user_id)
    user.soft_delete()
    await session.commit()


# ✅ Use repository pattern para abstração
class UserService:
    def __init__(self, user_repo: UserRepository):
        self.repo = user_repo
    
    async def create_user(self, email: str, name: str):
        # Lógica de negócio separada do acesso a dados
        return await self.repo.create(email=email, full_name=name)


# ✅ Gerencie transações com Unit of Work
async def transfer_funds(from_account: int, to_account: int, amount: float):
    """Unit of Work garante atomicidade."""
    async with UnitOfWork() as uow:
        # Múltiplas operações na mesma transação
        await uow.accounts.debit(from_account, amount)
        await uow.accounts.credit(to_account, amount)
        await uow.commit()


# ✅ Use indexação adequada
class User(BaseModel):
    __tablename__ = "users"
    
    email = Column(String(255), unique=True, nullable=False, index=True)
    username = Column(String(100), unique=True, index=True)
    
    __table_args__ = (
        # Índice composto para queries frequentes
        Index('idx_user_active_created', 'is_active', 'created_at'),
    )


# ✅ Valide entrada antes de salvar no database
from pydantic import BaseModel, EmailStr

class UserCreate(BaseModel):
    email: EmailStr
    full_name: str

async def create_user(data: UserCreate, repo: UserRepository):
    # Pydantic já validou os dados
    user = await repo.create(**data.dict())
    return user


# ✅ Use eager loading para evitar N+1
from sqlalchemy.orm import selectinload

async def get_users_with_posts(session: AsyncSession):
    """Carrega posts junto com users em uma query."""
    stmt = select(User).options(selectinload(User.posts))
    result = await session.execute(stmt)
    return result.scalars().all()


# ✅ Use transações explícitas quando necessário
async def complex_operation(session: AsyncSession):
    async with session.begin():
        # Operações serão commitadas automaticamente
        user = User(email="test@example.com")
        session.add(user)
        # Mais operações...
    # Commit automático aqui


# ✅ Implemente paginação em queries grandes
async def get_paginated_users(
    session: AsyncSession,
    page: int = 1,
    page_size: int = 20
):
    skip = (page - 1) * page_size
    stmt = select(User).offset(skip).limit(page_size)
    result = await session.execute(stmt)
    return result.scalars().all()

```

### ❌ **DONT`s - Práticas a Evitar**

```Python
# ❌ Não use operações síncronas
def bad_get_user(user_id: int, session):
    # Bloqueia thread!
    user = session.query(User).filter(User.id == user_id).first()
    return user

# ✅ Use async/await
async def good_get_user(user_id: int, session: AsyncSession):
    stmt = select(User).where(User.id == user_id)
    result = await session.execute(stmt)
    return result.scalar_one_or_none()


# ❌ Não deixe conexões abertas
async def bad_database_usage():
    session = await db_manager.get_session().__anext__()
    user = await session.get(User, 1)
    # Sessão nunca fechada!
    return user

# ✅ Use context manager
async def good_database_usage():
    async for session in db_manager.get_session():
        user = await session.get(User, 1)
        return user


# ❌ Não ignore transações
async def bad_multiple_operations(session: AsyncSession):
    user = User(email="test@example.com")
    session.add(user)
    # Faltou commit! Mudanças podem ser perdidas
    
    profile = Profile(user_id=user.id)
    session.add(profile)
    # Sem transação, operações podem ficar inconsistentes

# ✅ Use transações adequadamente
async def good_multiple_operations(session: AsyncSession):
    async with session.begin():
        user = User(email="test@example.com")
        session.add(user)
        
        profile = Profile(user_id=user.id)
        session.add(profile)
    # Commit automático ou rollback em caso de erro


# ❌ Não faça queries N+1
async def bad_get_users_with_posts(session: AsyncSession):
    users = await session.execute(select(User))
    result = []
    for user in users.scalars():
        # Query adicional para cada usuário! N+1 problem
        posts = await session.execute(
            select(Post).where(Post.user_id == user.id)
        )
        user.posts = posts.scalars().all()
        result.append(user)
    return result

# ✅ Use eager loading
from sqlalchemy.orm import selectinload

async def good_get_users_with_posts(session: AsyncSession):
    stmt = select(User).options(selectinload(User.posts))
    result = await session.execute(stmt)
    return result.scalars().all()


# ❌ Não use SQL hardcoded desnecessariamente
async def bad_get_active_users(session: AsyncSession):
    # SQL string dificulta manutenção e é inseguro
    result = await session.execute(
        "SELECT * FROM users WHERE is_active = true"
    )
    return result.fetchall()

# ✅ Use SQLAlchemy ORM
async def good_get_active_users(session: AsyncSession):
    stmt = select(User).where(User.is_active == True)
    result = await session.execute(stmt)
    return result.scalars().all()


# ❌ Não exponha models de database diretamente
from fastapi import APIRouter

router = APIRouter()

@router.get("/users/{user_id}")
async def bad_get_user(user_id: int, session: AsyncSession = Depends(get_db_session)):
    # Retorna model diretamente - expõe campos internos!
    user = await session.get(User, user_id)
    return user  # NUNCA! Pode expor hashed_password, etc.

# ✅ Use schemas Pydantic para response
from pydantic import BaseModel

class UserResponse(BaseModel):
    id: int
    email: str
    full_name: str
    
    class Config:
        from_attributes = True

@router.get("/users/{user_id}", response_model=UserResponse)
async def good_get_user(user_id: int, session: AsyncSession = Depends(get_db_session)):
    user = await session.get(User, user_id)
    return user  # OK - FastAPI usa response_model para filtrar


# ❌ Não crie índices desnecessários
class BadIndexedModel(BaseModel):
    id = Column(Integer, primary_key=True)
    # Índices em todos os campos - overhead desnecessário!
    field1 = Column(String, index=True)
    field2 = Column(String, index=True)
    field3 = Column(String, index=True)
    rarely_queried = Column(String, index=True)  # Desperdício!

# ✅ Indexe apenas campos frequentemente consultados
class GoodIndexedModel(BaseModel):
    id = Column(Integer, primary_key=True)
    email = Column(String, unique=True, index=True)  # Consulta frequente
    username = Column(String, unique=True, index=True)  # Consulta frequente
    bio = Column(Text)  # Sem índice - raramente consultado

```

---

Esta regra estabelece padrões sólidos para integração com banco de dados em aplicações Python/FastAPI, garantindo código limpo, performático e manutenível.
