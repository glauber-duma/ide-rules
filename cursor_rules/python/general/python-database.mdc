## 5. Unit Of Work

### ♻️ **Transaction Management**

```Python
# src/repositories/unit_of_work.py
"""
Unit of Work para gerenciamento transacional
"""
from typing import Optional
from sqlalchemy.ext.asyncio import AsyncSession
from src.database.connection import db_manager
from src.repositories.user_repository import UserRepository


class UnitOfWork:
    """Unit of Work para gerenciar transações e repositories."""
    
    def __init__(self, session: Optional[AsyncSession] = None):
        """
        Args:
            session: Sessão SQLAlchemy (opcional, cria nova se não fornecida)
        """
        self._session = session
        self._own_session = session is None
        
        # Repositories (lazy initialization)
        self._user_repo: Optional[UserRepository] = None
    
    async def __aenter__(self):
        """Inicia contexto do Unit of Work."""
        if self._own_session:
            # Cria nova sessão se não foi fornecida
            session_gen = db_manager.get_session()
            self._session = await session_gen.__anext__()
        
        return self
    
    async def __aexit__(self, exc_type, exc_val, exc_tb):
        """Finaliza contexto do Unit of Work."""
        if exc_type:
            # Rollback em caso de exceção
            await self.rollback()
        
        if self._own_session and self._session:
            # Fecha sessão se foi criada aqui
            await self._session.close()
    
    @property
    def session(self) -> AsyncSession:
        """Retorna sessão ativa."""
        if not self._session:
            raise RuntimeError("UnitOfWork não foi inicializado em um contexto async")
        return self._session
    
    @property
    def users(self) -> UserRepository:
        """Repository de usuários (lazy loading)."""
        if not self._user_repo:
            self._user_repo = UserRepository(self.session)
        return self._user_repo
    
    # Adicione outros repositories aqui
    # @property
    # def products(self) -> ProductRepository:
    #     ...
    
    async def commit(self) -> None:
        """Comita transação."""
        await self.session.commit()
    
    async def rollback(self) -> None:
        """Reverte transação."""
        await self.session.rollback()
    
    async def flush(self) -> None:
        """Faz flush sem commit."""
        await self.session.flush()


# Exemplo de uso
"""
async def create_user_with_profile(email: str, name: str):
    async with UnitOfWork() as uow:
        try:
            # Cria usuário
            user = await uow.users.create(email=email, full_name=name)
            
            # Outras operações no mesmo contexto transacional
            # profile = await uow.profiles.create(user_id=user.id, ...)
            
            # Comita tudo junto
            await uow.commit()
            return user
        except Exception as e:
            # Rollback automático no __aexit__
            raise
"""

