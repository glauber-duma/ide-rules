### 3.3. Generic Types e Advanced Annotations

```python
# ✅ Correto - Generics e types avançados

from typing import (
    Any,
    Callable,
    Generic,
    Optional,
    Protocol,
    TypeVar,
    Union,
    overload,
)
from collections.abc import Awaitable, Iterator


# Type variables para generics
T = TypeVar("T")
K = TypeVar("K")
V = TypeVar("V")


# Classe genérica
class Repository(Generic[T]):
    """Repositório genérico para qualquer tipo."""
    
    def __init__(self) -> None:
        self._items: dict[str, T] = {}
    
    def add(self, key: str, item: T) -> None:
        """Adiciona item ao repositório."""
        self._items[key] = item
    
    def get(self, key: str) -> Optional[T]:
        """Busca item por chave."""
        return self._items.get(key)
    
    def list_all(self) -> list[T]:
        """Lista todos os itens."""
        return list(self._items.values())


# Uso do repositório genérico
user_repo: Repository[User] = Repository()
product_repo: Repository[Product] = Repository()


# Protocol para duck typing
class Drawable(Protocol):
    """Protocol para objetos desenháveis."""
    
    def draw(self) -> None:
        """Desenha o objeto."""
        ...


def render(obj: Drawable) -> None:
    """Renderiza qualquer objeto desenhável."""
    obj.draw()


# Overload para diferentes assinaturas
@overload
def process(data: str) -> str: ...

@overload
def process(data: int) -> int: ...

@overload
def process(data: list[Any]) -> list[Any]: ...

def process(data: str | int | list[Any]) -> str | int | list[Any]:
    """Processa diferentes tipos de dados."""
    if isinstance(data, str):
        return data.upper()
    elif isinstance(data, int):
        return data * 2
    else:
        return [process(item) for item in data]


# Callable com tipos específicos
def retry(
    func: Callable[..., T],
    max_attempts: int = 3,
) -> Callable[..., T]:
    """Decorator para retry de função."""
    def wrapper(*args: Any, **kwargs: Any) -> T:
        for attempt in range(max_attempts):
            try:
                return func(*args, **kwargs)
            except Exception:
                if attempt == max_attempts - 1:
                    raise
        raise RuntimeError("Unreachable")
    return wrapper


# Async types
async def fetch_users() -> list[User]:
    """Busca usuários assincronamente."""
    pass


def get_users_async() -> Awaitable[list[User]]:
    """Retorna awaitable de usuários."""
    return fetch_users()


# Iterator types
def fibonacci(n: int) -> Iterator[int]:
    """Gera sequência de Fibonacci."""
    a, b = 0, 1
    for _ in range(n):
        yield a
        a, b = b, a + b


