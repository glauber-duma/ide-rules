## 🏗️ **Estrutura de Classes e Funções**

### 4.1. Class Organization

```python
# ✅ Correto - Organização clara de classe

from abc import ABC, abstractmethod
from datetime import datetime
from typing import ClassVar, Optional


class BaseService(ABC):
    """
    Classe base abstrata para serviços.
    
    Atributos de classe devem vir primeiro, seguidos de métodos
    na ordem: __init__, __str__/__repr__, métodos públicos,
    métodos protegidos, métodos privados, properties, métodos estáticos.
    """
    
    # 1. Constantes de classe
    VERSION: ClassVar[str] = "1.0.0"
    MAX_RETRIES: ClassVar[int] = 3
    
    # 2. Variáveis de classe
    _instances: ClassVar[int] = 0
    
    # 3. __init__
    def __init__(self, name: str, config: dict[str, Any]) -> None:
        """
        Inicializa o serviço.
        
        Args:
            name: Nome do serviço
            config: Configurações do serviço
        """
        self.name = name
        self.config = config
        self.created_at = datetime.utcnow()
        self._is_initialized = False
        self._cache: dict[str, Any] = {}
        BaseService._instances += 1
    
    # 4. __str__ e __repr__
    def __repr__(self) -> str:
        """Representação do objeto para debugging."""
        return f"{self.__class__.__name__}(name={self.name!r})"
    
    def __str__(self) -> str:
        """Representação legível do objeto."""
        return f"{self.name} Service"
    
    # 5. Métodos públicos abstratos
    @abstractmethod
    def initialize(self) -> None:
        """Inicializa recursos do serviço."""
        pass
    
    @abstractmethod
    def process(self, data: Any) -> Any:
        """Processa dados."""
        pass
    
    # 6. Métodos públicos concretos
    def reset(self) -> None:
        """Reseta estado do serviço."""
        self._cache.clear()
        self._is_initialized = False
    
    def get_stats(self) -> dict[str, Any]:
        """Retorna estatísticas do serviço."""
        return {
            "name": self.name,
            "created_at": self.created_at.isoformat(),
            "is_initialized": self._is_initialized,
            "cache_size": len(self._cache),
        }
    
    # 7. Métodos protegidos (para uso por subclasses)
    def _validate_config(self) -> bool:
        """Valida configuração do serviço."""
        return bool(self.config)
    
    def _get_from_cache(self, key: str) -> Optional[Any]:
        """Busca valor do cache."""
        return self._cache.get(key)
    
    def _set_in_cache(self, key: str, value: Any) -> None:
        """Armazena valor no cache."""
        self._cache[key] = value
    
    # 8. Métodos privados
    def __internal_cleanup(self) -> None:
        """Limpeza interna (name mangling)."""
        pass
    
    # 9. Properties
    @property
    def is_initialized(self) -> bool:
        """Indica se o serviço está inicializado."""
        return self._is_initialized
    
    @property
    def instance_count(self) -> int:
        """Número de instâncias criadas."""
        return BaseService._instances
    
    # 10. Class methods
    @classmethod
    def from_config_file(cls, filepath: str) -> "BaseService":
        """Cria instância a partir de arquivo de configuração."""
        import json
        with open(filepath) as f:
            config = json.load(f)
        return cls(name=config["name"], config=config)
    
    # 11. Static methods
    @staticmethod
    def validate_name(name: str) -> bool:
        """Valida nome do serviço."""
        return len(name) > 0 and name.isidentifier()
    
    # 12. Context manager methods (se aplicável)
    def __enter__(self) -> "BaseService":
        """Entrada de context manager."""
        self.initialize()
        return self
    
    def __exit__(self, exc_type, exc_val, exc_tb) -> None:
        """Saída de context manager."""
        self.reset()


# Exemplo de subclasse
class UserService(BaseService):
    """Serviço de gerenciamento de usuários."""
    
    def initialize(self) -> None:
        """Inicializa serviço de usuários."""
