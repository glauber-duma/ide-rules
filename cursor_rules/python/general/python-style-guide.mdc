### 4.2. Function Organization and Documentation

```python
# ✅ Correto - Função bem documentada e estruturada

from typing import Optional


def calculate_discount(
    original_price: float,
    discount_percentage: float,
    min_price: Optional[float] = None,
    max_discount: Optional[float] = None,
) -> float:
    """
    Calcula preço com desconto aplicado.
    
    Aplica desconto percentual ao preço original, respeitando limites
    mínimos e máximos quando especificados.
    
    Args:
        original_price: Preço original do produto (deve ser > 0)
        discount_percentage: Percentual de desconto (0-100)
        min_price: Preço mínimo permitido após desconto (opcional)
        max_discount: Desconto máximo em valor absoluto (opcional)
    
    Returns:
        Preço final após aplicação do desconto
    
    Raises:
        ValueError: Se preço original <= 0 ou desconto fora de 0-100
    
    Examples:
        >>> calculate_discount(100.0, 10.0)
        90.0
        >>> calculate_discount(100.0, 50.0, min_price=60.0)
        60.0
        >>> calculate_discount(100.0, 80.0, max_discount=50.0)
        50.0
    """
    # 1. Validação de entrada
    if original_price <= 0:
        raise ValueError("Preço original deve ser maior que zero")
    
    if not 0 <= discount_percentage <= 100:
        raise ValueError("Desconto deve estar entre 0 e 100")
    
    # 2. Cálculo principal
    discount_amount = original_price * (discount_percentage / 100)
    
    # 3. Aplicar limite máximo de desconto
    if max_discount is not None:
        discount_amount = min(discount_amount, max_discount)
    
    # 4. Calcular preço final
    final_price = original_price - discount_amount
    
    # 5. Aplicar preço mínimo
    if min_price is not None:
        final_price = max(final_price, min_price)
    
    # 6. Retornar resultado
    return round(final_price, 2)


