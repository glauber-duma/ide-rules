### 2.4. Private and Protected Members

```python
# ✅ Correto - Convenções de privacidade

class User:
    """Classe de usuário com membros privados e protegidos."""
    
    def __init__(self, username: str, password: str):
        # Público - sem underscore
        self.username = username
        self.created_at = datetime.utcnow()
        
        # Protegido - um underscore (convenção, ainda acessível)
        self._email = None
        self._last_login = None
        
        # Privado - dois underscores (name mangling)
        self.__password_hash = self._hash_password(password)
    
    # Método público
    def login(self, password: str) -> bool:
        """Método público para login."""
        return self._verify_password(password)
    
    # Método protegido
    def _verify_password(self, password: str) -> bool:
        """Método protegido para verificação interna."""
        return self.__password_hash == self._hash_password(password)
    
    # Método privado
    def __hash_password(self, password: str) -> str:
        """Método privado - não deve ser acessado externamente."""
        import hashlib
        return hashlib.sha256(password.encode()).hexdigest()
    
    # Property para acesso controlado
    @property
    def email(self) -> Optional[str]:
        """Acesso público ao email protegido."""
        return self._email
    
    @email.setter
    def email(self, value: str) -> None:
        """Setter com validação."""
        if "@" not in value:
            raise ValueError("Email inválido")
        self._email = value.lower()


class Repository:
    """Repositório com membros protegidos."""
    
    def __init__(self, connection):
        self._connection = connection  # Protegido
        self._cache = {}  # Protegido
    
    def get(self, key: str) -> Any:
        """Método público."""
        if key in self._cache:
            return self._cache[key]
        return self._fetch_from_db(key)
    
    def _fetch_from_db(self, key: str) -> Any:
        """Método protegido - uso interno."""
        pass


# ❌ Incorreto - Não seguir convenções de privacidade

class BadUser:
    def __init__(self, password: str):
        # Senha armazenada como pública!
        self.password = password  # ❌ Nunca expor senha!
        
        # Underscores inconsistentes
        self._public_method_name = "value"  # ❌ Se é público, não use _
        self.__also_public = "value"  # ❌ Confuso


    def publicMethod(self):  # ❌ Naming inconsistente
        pass
```

