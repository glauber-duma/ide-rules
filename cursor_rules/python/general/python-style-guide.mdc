    "C901",  # too complex
]

[tool.ruff.per-file-ignores]
"__init__.py" = ["F401"]  # imported but unused

[tool.bandit]
exclude_dirs = ["tests", "venv"]
skips = ["B101"]  # assert_used

[build-system]
requires = ["setuptools>=65.0", "wheel"]
