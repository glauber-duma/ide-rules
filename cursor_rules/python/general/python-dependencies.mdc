#### ✅ Execute auditoria de segurança regularmente

```python
# scripts/security_audit.py
"""Script de auditoria de segurança automatizada."""
import subprocess
import sys
from datetime import datetime


def run_pip_audit() -> bool:
    """Executa pip-audit e retorna se encontrou vulnerabilidades."""
    result = subprocess.run(
        ["pip-audit", "--format", "json"],
        capture_output=True,
        check=False
    )
    return result.returncode != 0


def run_safety() -> bool:
    """Executa safety check."""
    result = subprocess.run(
        ["safety", "check", "--json"],
        capture_output=True,
        check=False
    )
    return result.returncode != 0


def main() -> None:
    """Executa auditoria completa."""
    print(f"🔒 Security Audit - {datetime.now()}")
    
    has_vulns = False
    
    print("\n📦 Running pip-audit...")
    if run_pip_audit():
        print("❌ Vulnerabilities found by pip-audit")
        has_vulns = True
    else:
        print("✅ No vulnerabilities found by pip-audit")
    
    print("\n🛡️  Running safety check...")
    if run_safety():
        print("❌ Vulnerabilities found by safety")
        has_vulns = True
    else:
        print("✅ No vulnerabilities found by safety")
    
    if has_vulns:
        print("\n⚠️  Please review and update vulnerable dependencies!")
        sys.exit(1)
    else:
        print("\n✅ All security checks passed!")


if __name__ == "__main__":
    main()
```

#### ✅ Monitore licenças de dependências

```python
# scripts/check_licenses.py
"""Verifica licenças de dependências."""
import subprocess
import json
from typing import List, Dict


# Licenças permitidas pela empresa
ALLOWED_LICENSES = {
    "MIT",
    "Apache-2.0",
    "BSD-3-Clause",
    "BSD-2-Clause",
    "Python Software Foundation",
    "ISC",
}


def get_licenses() -> List[Dict[str, str]]:
    """Obtém lista de licenças instaladas."""
    result = subprocess.run(
        ["pip-licenses", "--format", "json"],
        capture_output=True,
        text=True,
        check=True
    )
    return json.loads(result.stdout)


def check_licenses() -> None:
    """Verifica se todas as licenças são permitidas."""
    licenses = get_licenses()
    violations = []
    
    for pkg in licenses:
        license_name = pkg.get("License", "Unknown")
        if license_name not in ALLOWED_LICENSES:
            violations.append({
                "name": pkg["Name"],
                "version": pkg["Version"],
                "license": license_name
            })
    
    if violations:
        print("❌ License violations found:\n")
        for v in violations:
            print(f"  {v['name']} ({v['version']}): {v['license']}")
        raise SystemExit(1)
    else:
        print("✅ All licenses are compliant")


if __name__ == "__main__":
    check_licenses()
```

