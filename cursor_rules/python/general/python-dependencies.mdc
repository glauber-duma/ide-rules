### 🔒 **Lock Files e Reprodutibilidade**

```bash
# ==== pip-tools workflow ====
# 1) criar requirements.in
printf "fastapi\nuvicorn\n" > requirements.in

# 2) compilar para requirements.txt (lock)
pip-compile --generate-hashes requirements.in

# 3) instalar dependências exatamente como no lock
pip-sync requirements.txt

# 4) atualizar dependências
pip-compile --upgrade

# 5) verificar atualizações disponíveis
pip list --outdated

# ==== Poetry workflow ====
# adicionar dependências
poetry add fastapi uvicorn

# instalar com lock
poetry install

# atualizar dependências
poetry update

# verificar atualizações disponíveis
poetry show --outdated
```

## 6. Segurança de Dependências

### 🔒 **Auditoria de segurança**

```python
"""
Scripts para auditoria de segurança de dependências
"""
import json
import subprocess
from pathlib import Path


def run_pip_audit(output_path: Path) -> None:
    result = subprocess.run(
        ["pip-audit", "-f", "json"],
        capture_output=True,
        text=True,
        check=False
    )
    output_path.write_text(result.stdout)


def run_safety(output_path: Path) -> None:
    result = subprocess.run(
        ["safety", "check", "--json"],
        capture_output=True,
        text=True,
        check=False
    )
    output_path.write_text(result.stdout)


def main() -> None:
    reports_dir = Path("reports")
    reports_dir.mkdir(exist_ok=True)
    run_pip_audit(reports_dir / "pip-audit.json")
    run_safety(reports_dir / "safety.json")


if __name__ == "__main__":
    main()
```

```python
"""
Security Audit Report
"""
import json
from pathlib import Path


def summarize(report_path: Path) -> dict:
    data = json.loads(report_path.read_text())
    if isinstance(data, dict) and "vulnerabilities" in data:
        vulns = data["vulnerabilities"]
    elif isinstance(data, list):
        vulns = data
    else:
        vulns = []

    return {
        "file": report_path.name,
        "count": len(vulns),
        "ids": sorted({v.get("id") or v.get("cve") for v in vulns if v})
    }


def main() -> None:
    reports_dir = Path("reports")
    summary = [summarize(p) for p in reports_dir.glob("*.json")]
    print(json.dumps(summary, indent=2))


if __name__ == "__main__":
    main()
```

