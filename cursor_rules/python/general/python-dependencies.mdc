            "hiredis==2.3.2",
            "boto3==1.34.162",
        ],
    },
)
```

### ❌ **DON'Ts - Práticas a Evitar**

#### ❌ Não use versões sem restrições

```python
# ❌ ERRADO: Sem versionamento
fastapi
uvicorn
pydantic

# ❌ ERRADO: Muito permissivo
fastapi>=0.100
pydantic>2
sqlalchemy>=2  # Aceita 2.x, 3.x, 4.x...

# ✅ CORRETO: Versionamento específico
fastapi==0.115.5
uvicorn==0.30.6
pydantic==2.8.2

# ✅ CORRETO: Range conservador
fastapi>=0.115.0,<0.116.0
pydantic>=2.8.0,<2.9.0

# Por que evitar:
# - Builds não reproduzíveis
# - Breaking changes inesperados
# - Dificulta debug de problemas
# - Falhas em produção por incompatibilidade
```

#### ❌ Não misture ferramentas inconsistentemente

```python
# ❌ ERRADO: Múltiplas ferramentas sem critério
# Projeto tem:
# - requirements.txt
# - pyproject.toml (Poetry)
# - Pipfile
# - conda.yml
# Resultado: confusão total!

# ❌ ERRADO: pip e poetry ao mesmo tempo
pip install fastapi  # instalado com pip
poetry add uvicorn   # instalado com poetry
# Resultado: poetry.lock não reflete ambiente real

# ❌ ERRADO: Mistura de pip e conda
conda install numpy
pip install pandas
# Resultado: conflitos de versões, ambiente quebrado

# ✅ CORRETO: Escolha UMA ferramenta por projeto
# Opção 1: pip + requirements.txt
pip install -r requirements.txt

# Opção 2: Poetry
poetry install

# Opção 3: Conda (para data science)
conda env create -f environment.yml

# Se precisar misturar (casos raros):
# 1. Use conda para dependências nativas (numpy, scipy)
# 2. Use pip DENTRO do ambiente conda para o resto
conda create -n myenv python=3.11
conda activate myenv
conda install numpy scipy
pip install fastapi uvicorn
```

#### ❌ Não comite arquivos de ambiente virtual

```bash
# ❌ ERRADO: Commitar venv
git add .venv/
git add venv/
git add __pycache__/

# Por que evitar:
# - Tamanho gigante do repo (centenas de MB)
# - Arquivos binários específicos do OS
# - Conflitos em merge
# - Slow clone/pull

# ✅ CORRETO: .gitignore adequado
# .gitignore
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*.so
.Python
build/
dist/
*.egg-info/

# ✅ CORRETO: Commitar apenas especificações
git add requirements.txt
git add requirements/
git add pyproject.toml
git add poetry.lock

# ✅ CORRETO: README com instruções
# README.md
# Setup
python -m venv .venv
source .venv/bin/activate
pip install -r requirements/development.txt
```

#### ❌ Não ignore alertas de segurança

```python
# ❌ ERRADO: Ignorar CVEs
# pip-audit encontra:
# "fastapi 0.95.0 has known security vulnerability CVE-2023-XXXX"
# Desenvolvedor: "Ignora, depois eu atualizo"

# ❌ ERRADO: Suprimir warnings
pip install --no-warn-conflicts fastapi==0.95.0

# ❌ ERRADO: Disable security checks no CI
# .github/workflows/ci.yml
pip-audit || true  # ❌ Ignora falhas
safety check --continue-on-error  # ❌ Continua com vulnerabilidades

# ✅ CORRETO: Trate vulnerabilidades imediatamente
# 1. Atualize a dependência vulnerável
pip install --upgrade fastapi
pip-compile --upgrade-package fastapi

# 2. Se não puder atualizar, documente o motivo
# .safety-policy.yml
security:
  ignore:
    - id: "CVE-2023-XXXX"
      reason: "Aguardando fix no upstream, workaround aplicado"
      expires: "2026-02-01"

# 3. Configure alertas automáticos
# .github/dependabot.yml
version: 2
updates:
  - package-ecosystem: "pip"
    directory: "/"
    schedule:
      interval: "daily"
    open-pull-requests-limit: 10
```

#### ❌ Não misture conda com pip no mesmo ambiente

```bash
# ❌ ERRADO: Instalação misturada
conda create -n myenv python=3.11
conda activate myenv
conda install numpy pandas
pip install scikit-learn tensorflow  # pode quebrar numpy/pandas do conda!

# Por que evitar:
# - Conda e pip usam resolvers diferentes
# - Conflitos de versões
# - Dependências duplicadas
# - Ambiente quebrado difícil de debugar

# ✅ CORRETO: Use apenas conda
conda create -n myenv python=3.11
conda activate myenv
conda install numpy pandas scikit-learn tensorflow

# ✅ CORRETO: Se precisar misturar (última opção)
# 1. Instale tudo que puder pelo conda PRIMEIRO
conda install numpy pandas scipy matplotlib

# 2. Só então use pip para o que não existe no conda
pip install fastapi uvicorn  # não disponível no conda

# 3. NUNCA instale pelo pip algo que já foi instalado pelo conda

# ✅ MELHOR: Use apenas pip/poetry para apps web
python -m venv .venv
source .venv/bin/activate
pip install -r requirements.txt
```

#### ❌ Não use sudo com pip

```bash
# ❌ ERRADO: Instalar globalmente com sudo
sudo pip install fastapi
sudo pip install -r requirements.txt

# Por que evitar:
# - Modifica Python do sistema
# - Conflitos com gerenciador de pacotes do OS (apt, yum)
# - Quebra ferramentas do sistema
# - Problemas de permissão
# - Difícil de reverter

# ✅ CORRETO: Use ambiente virtual
python -m venv .venv
source .venv/bin/activate
pip install fastapi

# ✅ CORRETO: Use --user (se não puder usar venv)
pip install --user fastapi

# ✅ CORRETO: Em Docker, use venv mesmo sendo root
# Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Cria venv mesmo em container
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
CMD ["uvicorn", "main:app", "--host", "0.0.0.0"]
```

